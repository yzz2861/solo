{
  "description": "历史回放样例配置 - 用于验证基线对比功能",
  "version": "1.0.0",

  "log_sources": [
    {
      "name": "current_scan",
      "path": "samples/historical/current_scan.log",
      "type": "file"
    }
  ],

  "time_window": {
    "enabled": true,
    "start": "2026-06-01 00:00:00",
    "end": "2026-06-30 23:59:59",
    "days": null
  },

  "group_by": ["namespace", "severity"],

  "thresholds": [
    {
      "level": "critical",
      "min_cvss": 9.0,
      "label": "严重"
    },
    {
      "level": "high",
      "min_cvss": 7.0,
      "label": "高危"
    },
    {
      "level": "medium",
      "min_cvss": 4.0,
      "label": "中危"
    }
  ]
}
