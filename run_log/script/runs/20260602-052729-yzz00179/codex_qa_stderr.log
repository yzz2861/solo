            ),
            ValidationRule(
                name="面积范围校验",
                field="area",
                rule_type="range",
                parameters={"min": 5, "max": 2000},
                risk_level=RiskLevel.MEDIUM,
                error_message="面积应在5-2000平方米之间"
            ),
            ValidationRule(
                name="必填位置",
                field="location",
                rule_type="required",
                risk_level=RiskLevel.MEDIUM,
                error_message="位置为必填项"
            ),
