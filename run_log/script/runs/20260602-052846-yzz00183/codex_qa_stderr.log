            status = "✅ 通过" if r["passed"] else "❌ 失败"
            print(
                f"{r['test_name']:<40} {status:<10} {r['record_id']:<25} {r['judgment_result']:<10}"
            )

        print(f"\n{'='*60}")
        return passed_count == total_count


async def run_all_tests():
    tester = AcceptanceTester()

    await tester.test_case_1_normal_pass()
    await tester.test_case_2_missing_fields()
    await tester.test_case_3_rule_hit_block()
    await tester.test_case_4_duplicate_submission()
    await tester.test_case_5_pending_review()
    await tester.test_case_6_calibration_error()
    await tester.test_case_7_rule_conflict()
    await tester.test_case_8_task_status_query()
    await tester.test_case_9_data_playback()
    await tester.test_case_10_query_history()
    await tester.test_case_11_statistics()
    await tester.test_case_12_extreme_rainfall()

    all_passed = tester.print_summary()
    return all_passed


if __name__ == "__main__":
    print("雨水泵站启停策略API - 验收测试套件")
    print("确保服务已启动: python -m uvicorn app.main:app --reload")
    print("")

    import sys

    try:
        all_passed = asyncio.run(run_all_tests())
        sys.exit(0 if all_passed else 1)
    except Exception as e:
        print(f"\n❌ 测试执行失败: {e}")
        print("请确保API服务已在 http://localhost:8000 运行")
        sys.exit(1)

