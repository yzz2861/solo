const { PROCESS_STATUS, RISK_LEVEL, BOUNDARY_TYPES, RULE_VERSION, PROCESS_ACTION } = require('../models/constants');

const THRESHOLDS = {
  voltage: {
    min: 3.2,
    max: 3.8,
    criticalMin: 3.0,
    criticalMax: 4.0,
    unit: 'V'
  },
  capacity: {
    min: 95,
    criticalMin: 90,
    unit: '%'
  },
  internalResistance: {
    max: 50,
    criticalMax: 80,
    unit: 'mΩ'
  },
  temperature: {
    max: 45,
    criticalMax: 60,
    unit: '℃'
  },
  formationTime: {
    min: 7200,
    max: 14400,
    criticalMin: 3600,
    criticalMax: 28800,
    unit: '秒'
  }
};

const REQUIRED_STEPS = ['充电', '静置', '放电', '再充电'];

function checkVoltage(item) {
  if (item.voltage === undefined) return { hasIssue: false };
  
  const { min, max, criticalMin, criticalMax, unit } = THRESHOLDS.voltage;
  const details = [];
  
  if (item.voltage < criticalMin) {
    details.push({
      boundaryType: BOUNDARY_TYPES.VOLTAGE_LOW,
      riskLevel: RISK_LEVEL.HIGH,
      actualValue: item.voltage,
      threshold: criticalMin,
      unit,
      description: `电压严重偏低: ${item.voltage}${unit} (临界值: ${criticalMin}${unit})`
    });
  } else if (item.voltage > criticalMax) {
    details.push({
      boundaryType: BOUNDARY_TYPES.VOLTAGE_HIGH,
      riskLevel: RISK_LEVEL.HIGH,
      actualValue: item.voltage,
      threshold: criticalMax,
      unit,
      description: `电压严重偏高: ${item.voltage}${unit} (临界值: ${criticalMax}${unit})`
    });
  } else if (item.voltage < min) {
    details.push({
      boundaryType: BOUNDARY_TYPES.VOLTAGE_LOW,
      riskLevel: RISK_LEVEL.MEDIUM,
      actualValue: item.voltage,
      threshold: min,
      unit,
      description: `电压接近下限: ${item.voltage}${unit} (下限: ${min}${unit})`
    });
  } else if (item.voltage > max) {
    details.push({
      boundaryType: BOUNDARY_TYPES.VOLTAGE_HIGH,
      riskLevel: RISK_LEVEL.MEDIUM,
      actualValue: item.voltage,
      threshold: max,
      unit,
      description: `电压接近上限: ${item.voltage}${unit} (上限: ${max}${unit})`
    });
  }
  
  return { hasIssue: details.length > 0, details };
}

function checkCapacity(item) {
  if (item.capacity === undefined) return { hasIssue: false };
  
  const { min, criticalMin, unit } = THRESHOLDS.capacity;
  const details = [];
  
  if (item.capacity < criticalMin) {
    details.push({
      boundaryType: BOUNDARY_TYPES.CAPACITY_LOW,
      riskLevel: RISK_LEVEL.HIGH,
      actualValue: item.capacity,
      threshold: criticalMin,
      unit,
      description: `容量严重不足: ${item.capacity}${unit} (临界值: ${criticalMin}${unit})`
    });
  } else if (item.capacity < min) {
    details.push({
      boundaryType: BOUNDARY_TYPES.CAPACITY_LOW,
      riskLevel: RISK_LEVEL.MEDIUM,
      actualValue: item.capacity,
      threshold: min,
      unit,
      description: `容量接近下限: ${item.capacity}${unit} (下限: ${min}${unit})`
    });
  }
  
  return { hasIssue: details.length > 0, details };
}

function checkInternalResistance(item) {
  if (item.internalResistance === undefined) return { hasIssue: false };
  
  const { max, criticalMax, unit } = THRESHOLDS.internalResistance;
  const details = [];
  
  if (item.internalResistance > criticalMax) {
    details.push({
      boundaryType: BOUNDARY_TYPES.INTERNAL_RESISTANCE_HIGH,
      riskLevel: RISK_LEVEL.HIGH,
      actualValue: item.internalResistance,
      threshold: criticalMax,
      unit,
      description: `内阻严重偏高: ${item.internalResistance}${unit} (临界值: ${criticalMax}${unit})`
    });
  } else if (item.internalResistance > max) {
    details.push({
      boundaryType: BOUNDARY_TYPES.INTERNAL_RESISTANCE_HIGH,
      riskLevel: RISK_LEVEL.MEDIUM,
      actualValue: item.internalResistance,
      threshold: max,
      unit,
      description: `内阻接近上限: ${item.internalResistance}${unit} (上限: ${max}${unit})`
    });
  }
  
  return { hasIssue: details.length > 0, details };
}

function checkTemperature(item) {
  if (item.temperature === undefined) return { hasIssue: false };
  
  const { max, criticalMax, unit } = THRESHOLDS.temperature;
  const details = [];
  
  if (item.temperature > criticalMax) {
    details.push({
      boundaryType: BOUNDARY_TYPES.TEMPERATURE_HIGH,
      riskLevel: RISK_LEVEL.HIGH,
      actualValue: item.temperature,
      threshold: criticalMax,
      unit,
      description: `温度严重超标: ${item.temperature}${unit} (临界值: ${criticalMax}${unit})`
    });
  } else if (item.temperature > max) {
    details.push({
      boundaryType: BOUNDARY_TYPES.TEMPERATURE_HIGH,
      riskLevel: RISK_LEVEL.MEDIUM,
      actualValue: item.temperature,
      threshold: max,
      unit,
      description: `温度接近上限: ${item.temperature}${unit} (上限: ${max}${unit})`
    });
  }
  
  return { hasIssue: details.length > 0, details };
}

function checkFormationTime(item) {
  if (item.formationTime === undefined) return { hasIssue: false };
  
  const { min, max, criticalMin, criticalMax, unit } = THRESHOLDS.formationTime;
  const details = [];
  
  if (item.formationTime < criticalMin) {
    details.push({
      boundaryType: BOUNDARY_TYPES.TIME_ABNORMAL,
      riskLevel: RISK_LEVEL.HIGH,
      actualValue: item.formationTime,
      threshold: criticalMin,
      unit,
      description: `化成长度严重不足: ${item.formationTime}${unit} (临界值: ${criticalMin}${unit})`
    });
  } else if (item.formationTime > criticalMax) {
    details.push({
      boundaryType: BOUNDARY_TYPES.TIME_ABNORMAL,
      riskLevel: RISK_LEVEL.HIGH,
      actualValue: item.formationTime,
      threshold: criticalMax,
      unit,
      description: `化成长度严重超时: ${item.formationTime}${unit} (临界值: ${criticalMax}${unit})`
    });
  } else if (item.formationTime < min) {
    details.push({
      boundaryType: BOUNDARY_TYPES.TIME_ABNORMAL,
      riskLevel: RISK_LEVEL.MEDIUM,
      actualValue: item.formationTime,
      threshold: min,
      unit,
      description: `化成长度偏短: ${item.formationTime}${unit} (下限: ${min}${unit})`
    });
  } else if (item.formationTime > max) {
    details.push({
      boundaryType: BOUNDARY_TYPES.TIME_ABNORMAL,
      riskLevel: RISK_LEVEL.MEDIUM,
      actualValue: item.formationTime,
      threshold: max,
      unit,
      description: `化成长度偏长: ${item.formationTime}${unit} (上限: ${max}${unit})`
    });
  }
  
  return { hasIssue: details.length > 0, details };
}

function checkSteps(item) {
  if (!item.steps || !Array.isArray(item.steps)) return { hasIssue: false };
  
  const missingSteps = REQUIRED_STEPS.filter(step => !item.steps.includes(step));
  const details = [];
  
  if (missingSteps.length > 0) {
    details.push({
      boundaryType: BOUNDARY_TYPES.STEP_MISSING,
      riskLevel: RISK_LEVEL.HIGH,
      actualValue: item.steps.join(','),
      threshold: REQUIRED_STEPS.join(','),
      unit: '',
      description: `工序缺失: 缺少 ${missingSteps.join(', ')}`
    });
  }
  
  return { hasIssue: details.length > 0, details };
}

function checkDataCompleteness(item) {
  const requiredFields = ['voltage', 'capacity', 'internalResistance'];
  const missingFields = requiredFields.filter(field => item[field] === undefined);
  const details = [];
  
  if (missingFields.length > 0) {
    details.push({
      boundaryType: BOUNDARY_TYPES.DATA_INCOMPLETE,
      riskLevel: RISK_LEVEL.UNDETERMINED,
      actualValue: null,
      threshold: null,
      unit: '',
      description: `数据不全: 缺少 ${missingFields.join(', ')} 字段`
    });
  }
  
  return { hasIssue: details.length > 0, details };
}

function validateItem(item) {
  const allDetails = [];
  
  const completeness = checkDataCompleteness(item);
  if (completeness.hasIssue) {
    allDetails.push(...completeness.details);
  }
  
  const voltage = checkVoltage(item);
  if (voltage.hasIssue) allDetails.push(...voltage.details);
  
  const capacity = checkCapacity(item);
  if (capacity.hasIssue) allDetails.push(...capacity.details);
  
  const ir = checkInternalResistance(item);
  if (ir.hasIssue) allDetails.push(...ir.details);
  
  const temp = checkTemperature(item);
  if (temp.hasIssue) allDetails.push(...temp.details);
  
  const time = checkFormationTime(item);
  if (time.hasIssue) allDetails.push(...time.details);
  
  const steps = checkSteps(item);
  if (steps.hasIssue) allDetails.push(...steps.details);
  
  return {
    cellId: item.cellId,
    details: allDetails,
    hasHighRisk: allDetails.some(d => d.riskLevel === RISK_LEVEL.HIGH),
    hasMediumRisk: allDetails.some(d => d.riskLevel === RISK_LEVEL.MEDIUM),
    hasUndetermined: allDetails.some(d => d.riskLevel === RISK_LEVEL.UNDETERMINED)
  };
}

function determineItemStatus(itemResult, processAction) {
  if (processAction === PROCESS_ACTION.FORCE_PASS) {
    return {
      status: PROCESS_STATUS.PASS,
      reasons: ['强制通过']
    };
  }
  
  if (processAction === PROCESS_ACTION.FORCE_BLOCK) {
    return {
      status: PROCESS_STATUS.BLOCK,
      reasons: ['强制拦截']
    };
  }
  
  if (itemResult.hasUndetermined) {
    return {
      status: PROCESS_STATUS.PENDING_REVIEW,
      reasons: itemResult.details.filter(d => d.riskLevel === RISK_LEVEL.UNDETERMINED).map(d => d.description)
    };
  }
  
  if (itemResult.hasHighRisk) {
    return {
      status: PROCESS_STATUS.BLOCK,
      reasons: itemResult.details.filter(d => d.riskLevel === RISK_LEVEL.HIGH).map(d => d.description)
    };
  }
  

