const { validateRequest, generateRequestHash } = require('../models/request');
const { executeRules } = require('../engine/rules');
const { createAuditRecord, findRecordByHash, getAuditRecord } = require('../models/audit');
const { RULE_VERSION, PROCESS_ACTION } = require('../models/constants');

function processValidationRequest(request, operator) {
  const validation = validateRequest(request);
  if (!validation.isValid) {
    return {
      success: false,
      error: '请求参数验证失败',
      details: validation.errors,
      ruleVersion: RULE_VERSION
    };
  }

  const requestHash = generateRequestHash(request);
  
  const existingRecord = findRecordByHash(requestHash);
  if (existingRecord && request.processAction === PROCESS_ACTION.FIRST_CHECK) {
    return {
      success: true,
      isDuplicate: true,
      message: '重复请求，返回历史处理结果',
      data: buildResponseFromAudit(existingRecord)
    };
  }

  const ruleResult = executeRules(request, requestHash);
  const auditRecord = createAuditRecord(request, ruleResult, operator);

  return {
    success: true,
    isDuplicate: false,
    data: buildResponseFromAudit(auditRecord)
  };
}

function buildResponseFromAudit(auditRecord) {
  return {
    recordId: auditRecord.recordId,
    traceId: auditRecord.traceId,
    batchNo: auditRecord.batchNo,
    status: auditRecord.status,
    riskLevel: auditRecord.riskLevel,
    reasons: auditRecord.reasons,
    boundaryDetails: auditRecord.boundaryDetails,
    ruleVersion: auditRecord.ruleVersion,
    operator: auditRecord.operator,
    itemCount: auditRecord.itemCount,
    passCount: auditRecord.passCount,
    blockCount: auditRecord.blockCount,
    pendingCount: auditRecord.pendingCount,
    createdAt: auditRecord.createdAt,
    requestHash: auditRecord.requestHash
  };
}

function getValidationResult(recordId) {
  const record = getAuditRecord(recordId);
  if (!record) {
    return {
      success: false,
      error: '未找到对应的校验记录'
    };
  }
  return {
    success: true,
    data: buildResponseFromAudit(record)
  };
}

module.exports = {
  processValidationRequest,
  getValidationResult
};

