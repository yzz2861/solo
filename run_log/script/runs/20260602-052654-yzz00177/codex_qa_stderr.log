const { SOURCE_CHANNEL, PROCESS_ACTION } = require('./constants');

function validateRequest(req) {
  const errors = [];

  if (!req.batchNo || typeof req.batchNo !== 'string' || req.batchNo.trim() === '') {
    errors.push('批次号不能为空且必须为字符串');
  }

  if (!req.items || !Array.isArray(req.items) || req.items.length === 0) {
    errors.push('明细项不能为空且必须为数组');
  } else {
    req.items.forEach((item, index) => {
      if (!item.cellId || typeof item.cellId !== 'string') {
        errors.push(`明细项[${index}]: 电芯ID不能为空`);
      }
      if (item.voltage !== undefined && (typeof item.voltage !== 'number' || item.voltage < 0)) {
        errors.push(`明细项[${index}]: 电压必须为非负数字`);
      }
      if (item.capacity !== undefined && (typeof item.capacity !== 'number' || item.capacity < 0)) {
        errors.push(`明细项[${index}]: 容量必须为非负数字`);
      }
      if (item.internalResistance !== undefined && (typeof item.internalResistance !== 'number' || item.internalResistance < 0)) {
        errors.push(`明细项[${index}]: 内阻必须为非负数字`);
      }
      if (item.temperature !== undefined && typeof item.temperature !== 'number') {
        errors.push(`明细项[${index}]: 温度必须为数字`);
      }
      if (item.formationTime !== undefined && (typeof item.formationTime !== 'number' || item.formationTime < 0)) {
        errors.push(`明细项[${index}]: 化成长度必须为非负数字`);
      }
    });
  }

  if (!req.sourceChannel || !Object.values(SOURCE_CHANNEL).includes(req.sourceChannel)) {
    errors.push(`来源渠道必须为: ${Object.values(SOURCE_CHANNEL).join(', ')}`);
  }

  if (!req.processAction || !Object.values(PROCESS_ACTION).includes(req.processAction)) {
    errors.push(`处理动作必须为: ${Object.values(PROCESS_ACTION).join(', ')}`);
  }

  if (req.processAction === PROCESS_ACTION.RECHECK && (!req.reviewOpinion || typeof req.reviewOpinion !== 'string')) {
    errors.push('复核校验时必须提供复核意见');
  }

  if (req.processAction === PROCESS_ACTION.FORCE_PASS && (!req.reviewOpinion || typeof req.reviewOpinion !== 'string')) {
    errors.push('强制通过时必须提供复核意见');
  }

  if (req.processAction === PROCESS_ACTION.FORCE_BLOCK && (!req.reviewOpinion || typeof req.reviewOpinion !== 'string')) {
    errors.push('强制拦截时必须提供复核意见');
  }

  return {
    isValid: errors.length === 0,
    errors
  };
}

function generateRequestHash(req) {
  const itemsStr = JSON.stringify(req.items.map(item => ({
    cellId: item.cellId,
    voltage: item.voltage,
    capacity: item.capacity,
    internalResistance: item.internalResistance,
    temperature: item.temperature,
    formationTime: item.formationTime,
    steps: item.steps
  })).sort((a, b) => a.cellId.localeCompare(b.cellId)));

  const content = `${req.batchNo}|${itemsStr}|${req.sourceChannel}|${req.processAction}|${req.reviewOpinion || ''}`;
  return Buffer.from(content).toString('base64');
}

module.exports = {
  validateRequest,
  generateRequestHash
};

