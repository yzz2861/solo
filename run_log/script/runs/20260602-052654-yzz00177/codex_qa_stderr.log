const RULE_VERSION = 'v2.1.0';

const PROCESS_STATUS = {
  PASS: '通过',
  BLOCK: '拦截',
  PENDING_REVIEW: '待复核'
};

const RISK_LEVEL = {
  LOW: '低风险',
  MEDIUM: '中风险',
  HIGH: '高风险',
  UNDETERMINED: '无法判定'
};

const SOURCE_CHANNEL = {
  MES: 'MES系统',
  PLC: 'PLC设备',
  MANUAL: '人工录入',
  API: '第三方接口'
};

const PROCESS_ACTION = {
  FIRST_CHECK: '首次校验',
  RECHECK: '复核校验',
  FORCE_PASS: '强制通过',
  FORCE_BLOCK: '强制拦截'
};

const BOUNDARY_TYPES = {
  VOLTAGE_LOW: '电压下限',
  VOLTAGE_HIGH: '电压上限',
  CAPACITY_LOW: '容量下限',
  INTERNAL_RESISTANCE_HIGH: '内阻上限',
  TEMPERATURE_HIGH: '温度上限',
  TIME_ABNORMAL: '时长异常',
  STEP_MISSING: '工序缺失',
  DATA_INCOMPLETE: '数据不全'
};

module.exports = {
  RULE_VERSION,
  PROCESS_STATUS,
  RISK_LEVEL,
  SOURCE_CHANNEL,
  PROCESS_ACTION,
  BOUNDARY_TYPES
};

