}

function validateItem(item) {
  const allDetails = [];
  
  const completeness = checkDataCompleteness(item);
  if (completeness.hasIssue) {
    allDetails.push(...completeness.details);
  }
  
  const voltage = checkVoltage(item);
  if (voltage.hasIssue) allDetails.push(...voltage.details);
  
  const capacity = checkCapacity(item);
  if (capacity.hasIssue) allDetails.push(...capacity.details);
  
  const ir = checkInternalResistance(item);
  if (ir.hasIssue) allDetails.push(...ir.details);
  
  const temp = checkTemperature(item);
  if (temp.hasIssue) allDetails.push(...temp.details);
  
  const time = checkFormationTime(item);
  if (time.hasIssue) allDetails.push(...time.details);
  
  const steps = checkSteps(item);
  if (steps.hasIssue) allDetails.push(...steps.details);
  
  return {
    cellId: item.cellId,
    details: allDetails,
    hasHighRisk: allDetails.some(d => d.riskLevel === RISK_LEVEL.HIGH),
    hasMediumRisk: allDetails.some(d => d.riskLevel === RISK_LEVEL.MEDIUM),
    hasUndetermined: allDetails.some(d => d.riskLevel === RISK_LEVEL.UNDETERMINED)
  };
}

function determineItemStatus(itemResult, processAction) {
  if (processAction === PROCESS_ACTION.FORCE_PASS) {
    return {
      status: PROCESS_STATUS.PASS,
      reasons: ['强制通过']
    };
  }
  
  if (processAction === PROCESS_ACTION.FORCE_BLOCK) {
    return {
      status: PROCESS_STATUS.BLOCK,
      reasons: ['强制拦截']
    };
  }
  
  if (itemResult.hasUndetermined) {
    return {
      status: PROCESS_STATUS.PENDING_REVIEW,
      reasons: itemResult.details.filter(d => d.riskLevel === RISK_LEVEL.UNDETERMINED).map(d => d.description)
    };
  }
  
  if (itemResult.hasHighRisk) {
    return {
      status: PROCESS_STATUS.BLOCK,
      reasons: itemResult.details.filter(d => d.riskLevel === RISK_LEVEL.HIGH).map(d => d.description)
    };
  }
  
  if (itemResult.hasMediumRisk) {
    return {
      status: PROCESS_STATUS.PENDING_REVIEW,
      reasons: itemResult.details.filter(d => d.riskLevel === RISK_LEVEL.MEDIUM).map(d => d.description)
    };
  }
  
  return {
    status: PROCESS_STATUS.PASS,
    reasons: ['各项指标正常']
  };
}

function determineOverallRisk(itemResults) {
  const hasHighRisk = itemResults.some(r => r.hasHighRisk);
  const hasMediumRisk = itemResults.some(r => r.hasMediumRisk);
  const hasUndetermined = itemResults.some(r => r.hasUndetermined);
  
  if (hasUndetermined) return RISK_LEVEL.UNDETERMINED;
  if (hasHighRisk) return RISK_LEVEL.HIGH;
  if (hasMediumRisk) return RISK_LEVEL.MEDIUM;
  return RISK_LEVEL.LOW;
}

function determineOverallStatus(itemStatuses, processAction) {
  if (processAction === PROCESS_ACTION.FORCE_PASS) {
    return PROCESS_STATUS.PASS;
  }
  
  if (processAction === PROCESS_ACTION.FORCE_BLOCK) {
    return PROCESS_STATUS.BLOCK;
  }
  
  const hasBlock = itemStatuses.some(s => s.status === PROCESS_STATUS.BLOCK);
  const hasPending = itemStatuses.some(s => s.status === PROCESS_STATUS.PENDING_REVIEW);
  
  if (hasBlock) return PROCESS_STATUS.BLOCK;
  if (hasPending) return PROCESS_STATUS.PENDING_REVIEW;
  return PROCESS_STATUS.PASS;
}

function executeRules(request, requestHash) {
  const itemResults = request.items.map(item => validateItem(item));
  const itemStatuses = itemResults.map(r => determineItemStatus(r, request.processAction));
  
  const overallRisk = determineOverallRisk(itemResults);
  const overallStatus = determineOverallStatus(itemStatuses, request.processAction);
  
  const allReasons = [...new Set(itemStatuses.flatMap(s => s.reasons))];
  const allBoundaryDetails = itemResults.flatMap(r => r.details);
  
  return {
    status: overallStatus,
    riskLevel: overallRisk,
    reasons: allReasons,
    boundaryDetails: allBoundaryDetails,
    ruleVersion: RULE_VERSION,
    requestHash,
    itemResults: itemResults.map((r, i) => ({
      cellId: r.cellId,
      status: itemStatuses[i].status,
      riskLevel: r.hasUndetermined ? RISK_LEVEL.UNDETERMINED :
                 r.hasHighRisk ? RISK_LEVEL.HIGH :
                 r.hasMediumRisk ? RISK_LEVEL.MEDIUM : RISK_LEVEL.LOW,
      reasons: itemStatuses[i].reasons,
      boundaryDetails: r.details
    }))
  };
}

module.exports = {
  executeRules,
  THRESHOLDS,
  REQUIRED_STEPS
};

