const { v4: uuidv4 } = require('uuid');

const auditRecords = new Map();
const requestHashCache = new Map();

function createAuditRecord(request, result, operator) {
  const recordId = `AUD-${Date.now()}-${uuidv4().substring(0, 8).toUpperCase()}`;
  
  const record = {
    recordId,
    traceId: `TRACE-${request.batchNo}-${Date.now()}`,
    batchNo: request.batchNo,
    sourceChannel: request.sourceChannel,
    processAction: request.processAction,
    reviewOpinion: request.reviewOpinion || null,
    operator: operator || 'system',
    status: result.status,
    riskLevel: result.riskLevel,
    reasons: result.reasons,
    boundaryDetails: result.boundaryDetails || [],
    ruleVersion: result.ruleVersion,
    itemCount: request.items.length,
    passCount: result.itemResults ? result.itemResults.filter(r => r.status === '通过').length : 0,
    blockCount: result.itemResults ? result.itemResults.filter(r => r.status === '拦截').length : 0,
    pendingCount: result.itemResults ? result.itemResults.filter(r => r.status === '待复核').length : 0,
    createdAt: new Date().toISOString(),
    requestHash: result.requestHash
  };

  auditRecords.set(recordId, record);
  requestHashCache.set(result.requestHash, recordId);

  return record;
}

function getAuditRecord(recordId) {
  return auditRecords.get(recordId) || null;
}

function getAuditRecordsByBatch(batchNo) {
  return Array.from(auditRecords.values()).filter(r => r.batchNo === batchNo);
}

function findRecordByHash(requestHash) {
  const recordId = requestHashCache.get(requestHash);
  return recordId ? auditRecords.get(recordId) : null;
}

function getAllAuditRecords() {
  return Array.from(auditRecords.values());
}

module.exports = {
  createAuditRecord,
  getAuditRecord,
  getAuditRecordsByBatch,
  findRecordByHash,
  getAllAuditRecords
};

