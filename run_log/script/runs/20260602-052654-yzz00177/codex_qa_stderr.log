const express = require('express');
const router = express.Router();
const { processValidationRequest, getValidationResult } = require('../services/validationService');
const { getAllAuditRecords, getAuditRecordsByBatch } = require('../models/audit');
const { RULE_VERSION, PROCESS_STATUS, RISK_LEVEL, SOURCE_CHANNEL, PROCESS_ACTION, BOUNDARY_TYPES } = require('../models/constants');
const { THRESHOLDS, REQUIRED_STEPS } = require('../engine/rules');

router.post('/validate', (req, res) => {
  const operator = req.headers['x-operator'] || 'system';
  const result = processValidationRequest(req.body, operator);
  
  if (!result.success) {
    return res.status(400).json(result);
  }
  
  res.json(result);
});

router.get('/result/:recordId', (req, res) => {
  const result = getValidationResult(req.params.recordId);
  
  if (!result.success) {
    return res.status(404).json(result);
  }
  
  res.json(result);
});

router.get('/audit', (req, res) => {
  const { batchNo } = req.query;
  
  if (batchNo) {
    const records = getAuditRecordsByBatch(batchNo);
    return res.json({
      success: true,
      count: records.length,
      data: records
    });
  }
  
  const allRecords = getAllAuditRecords();
  res.json({
    success: true,
    count: allRecords.length,
    data: allRecords
  });
});

router.get('/config', (req, res) => {
  res.json({
    success: true,
    data: {
      ruleVersion: RULE_VERSION,
      processStatus: PROCESS_STATUS,
      riskLevel: RISK_LEVEL,
      sourceChannel: SOURCE_CHANNEL,
      processAction: PROCESS_ACTION,
      boundaryTypes: BOUNDARY_TYPES,
      thresholds: THRESHOLDS,
      requiredSteps: REQUIRED_STEPS
    }
  });
});

module.exports = router;

