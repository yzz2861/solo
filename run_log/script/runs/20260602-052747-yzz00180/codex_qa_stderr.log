class TestRuleConflict:
    def test_locked_tenant_gets_locked_disposition(self, client, normal_payload):
        normal_payload["details"][0]["tenant_id"] = "LOCKED-TENANT-X"
        resp = client.post("/api/v1/quota/batch", json=normal_payload)
        data = resp.json()

        locked_detail = [d for d in data["details"] if d["tenant_id"] == "LOCKED-TENANT-X"][0]
        assert locked_detail["disposition"] == "locked"
        assert locked_detail["risk_label"] == "high_risk"
        assert "锁定状态" in locked_detail["failure_reason"]

    def test_needs_supplement_for_storage_type(self, client, normal_payload):
        normal_payload["details"][0]["quota_type"] = "storage"
        normal_payload["details"][0]["current_value"] = 100
        normal_payload["details"][0]["requested_value"] = 110
        resp = client.post("/api/v1/quota/batch", json=normal_payload)
        data = resp.json()

        storage_detail = [d for d in data["details"] if d["quota_type"] == "storage"][0]
        assert storage_detail["disposition"] == "needs_supplement"
        assert storage_detail["risk_label"] == "warning"

    def test_overage_triggers_needs_supplement(self, client, normal_payload):
        normal_payload["details"][0]["current_value"] = 100
        normal_payload["details"][0]["requested_value"] = 150
        normal_payload["details"][0]["quota_type"] = "users"
        resp = client.post("/api/v1/quota/batch", json=normal_payload)
        data = resp.json()

        overage_detail = data["details"][0]
        assert overage_detail["disposition"] == "needs_supplement"
        assert overage_detail["risk_label"] == "warning"
        assert "超出" in overage_detail["failure_reason"]

    def test_cross_batch_conflict_detected(self, client, normal_payload):
        resp1 = client.post("/api/v1/quota/batch", json=normal_payload)
        assert resp1.status_code == 200

        conflict_payload = {
            "batch_no": "BATCH-002",
            "details": [
                {
                    "tenant_id": "TENANT-A",
                    "quota_type": "users",
                    "quota_key": "standard",
                    "requested_value": 200,
                    "current_value": 80,
                    "unit": "count",
                }
            ],
            "source_channel": "api_direct",
            "action": "apply",
            "operator": "admin_lisi",
        }
        resp2 = client.post("/api/v1/quota/batch", json=conflict_payload)
        data = resp2.json()

        assert data["summary"]["failed"] == 1
        detail = data["details"][0]
        assert detail["disposition"] == "failed"
        assert detail["risk_label"] == "conflict"
        assert "已有生效记录" in detail["failure_reason"]

    def test_locked_tenant_not_affected_by_conflict_rule(self, client, normal_payload):
        normal_payload["details"][0]["tenant_id"] = "LOCKED-TENANT-Y"
        normal_payload["details"][0]["quota_type"] = "users"
        resp = client.post("/api/v1/quota/batch", json=normal_payload)
        data = resp.json()

        locked = [d for d in data["details"] if d["tenant_id"] == "LOCKED-TENANT-Y"][0]
        assert locked["disposition"] == "locked"
        assert locked["risk_label"] == "high_risk"
        assert "锁定" in locked["failure_reason"]
        assert "冲突" not in locked["failure_reason"]

    def test_boundary_scenarios_do_not_overlap(self, client):
        payload = {
            "batch_no": "BATCH-BOUNDARY",
            "details": [
                {
                    "tenant_id": "LOCKED-A",
                    "quota_type": "users",
                    "quota_key": "standard",
                    "requested_value": 45,
                    "current_value": 40,
                    "unit": "count",
                },
                {
                    "tenant_id": "NORMAL-B",
                    "quota_type": "storage",
                    "quota_key": "premium",
                    "requested_value": 200,
                    "current_value": 180,
                    "unit": "gb",
                },
                {
                    "tenant_id": "NORMAL-C",
                    "quota_type": "users",
                    "quota_key": "basic",
                    "requested_value": 45,
                    "current_value": 40,
                    "unit": "count",
                },
            ],
            "source_channel": "admin_portal",
            "action": "apply",
            "review_opinion": "边界场景混合测试",
            "operator": "admin_test",
        }
        resp = client.post("/api/v1/quota/batch", json=payload)
        data = resp.json()

        locked = [d for d in data["details"] if d["tenant_id"] == "LOCKED-A"]
        supplement = [d for d in data["details"] if d["tenant_id"] == "NORMAL-B"]
        processable = [d for d in data["details"] if d["tenant_id"] == "NORMAL-C"]

        assert len(locked) == 1 and locked[0]["disposition"] == "locked"
        assert len(supplement) == 1 and supplement[0]["disposition"] == "needs_supplement"
        assert len(processable) == 1 and processable[0]["disposition"] == "processable"

        dispositions = [d["disposition"] for d in data["details"]]
        unique_dispositions = set(dispositions)
        assert len(dispositions) == len(unique_dispositions) + 0  # allow same dispositions for different categories


