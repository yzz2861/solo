import { v4 as uuidv4 } from 'uuid';
import {
  SortingRequest,
  SortingResponse,
  MaterialStatus,
  AuditRecord,
  RuleConfig
} from '../types';
import {
  RULE_CONFIGS,
  DEFAULT_RULE_VERSION,
  isValidBusinessNo,
  isValidTimeWindow,
  isTimeInRange
} from '../config/rules';

export class RuleEngine {
  private ruleConfigs: Map<string, RuleConfig>;
  private resultCache: Map<string, SortingResponse>;
  private auditLogs: AuditRecord[];

  constructor() {
    this.ruleConfigs = RULE_CONFIGS;
    this.resultCache = new Map();
    this.auditLogs = [];
  }

  private generateCacheKey(request: SortingRequest): string {
    return `${request.businessNo}-${request.objectStatus}-${request.timeWindow.start}-${request.timeWindow.end}-${request.ruleVersion}`;
  }

  private createAuditRecord(
    request: SortingRequest,
    status: MaterialStatus,
    reason?: string
  ): AuditRecord {
    return {
      id: uuidv4(),
      businessNo: request.businessNo,
      operator: request.operator,
      operationTime: new Date().toISOString(),
      requestDetails: JSON.parse(JSON.stringify(request)),
      resultDetails: {
        status,
        reason
      },
      ruleVersion: request.ruleVersion,
      isRechecked: false
    };
  }

  public validateRequest(request: SortingRequest): { valid: boolean; error?: string } {
    if (!request.businessNo) {
      return { valid: false, error: '业务编号不能为空' };
    }
    if (!isValidBusinessNo(request.businessNo)) {
      return { valid: false, error: '业务编号格式错误，应为2位前缀+10位数字' };
    }
    if (!request.objectStatus) {
      return { valid: false, error: '对象状态不能为空' };
    }
    if (!request.timeWindow || !request.timeWindow.start || !request.timeWindow.end) {
      return { valid: false, error: '时间窗口参数不完整' };
    }
    if (!isValidTimeWindow(request.timeWindow.start, request.timeWindow.end)) {
      return { valid: false, error: '时间窗口格式无效或开始时间晚于结束时间' };
    }
    if (!request.ruleVersion) {
      return { valid: false, error: '规则版本不能为空' };
    }
    if (!this.ruleConfigs.has(request.ruleVersion)) {
      return { valid: false, error: `规则版本 ${request.ruleVersion} 不存在` };
    }
    if (!request.operator) {
      return { valid: false, error: '操作人不能为空' };
    }
    return { valid: true };
  }

  public checkTimeBoundary(request: SortingRequest): { inRange: boolean; error?: string } {
    const ruleConfig = this.ruleConfigs.get(request.ruleVersion);
    if (!ruleConfig) {
      return { inRange: false, error: '规则配置不存在' };
    }
    const midTime = new Date(
      (new Date(request.timeWindow.start).getTime() + new Date(request.timeWindow.end).getTime()) / 2
    ).toISOString();
    if (!isTimeInRange(midTime, ruleConfig.effectiveTime.start, ruleConfig.effectiveTime.end)) {
      return {
        inRange: false,
        error: `请求时间超出规则版本 ${request.ruleVersion} 的有效时间范围 (${ruleConfig.effectiveTime.start} ~ ${ruleConfig.effectiveTime.end})`
      };
    }
    return { inRange: true };
  }

  public process(request: SortingRequest): SortingResponse {
    const cacheKey = this.generateCacheKey(request);
    if (this.resultCache.has(cacheKey)) {
      console.log(`[CACHE_HIT] 业务编号 ${request.businessNo} 使用缓存结果`);
      return this.resultCache.get(cacheKey)!;
    }
    const validation = this.validateRequest(request);
    if (!validation.valid) {
      const auditRecord = this.createAuditRecord(request, '失败', validation.error);
      const response: SortingResponse = {
        businessNo: request.businessNo,
        status: '失败',
        failedReason: validation.error,
        ruleVersion: request.ruleVersion || DEFAULT_RULE_VERSION,
        operator: request.operator,
        auditRecord
      };
      this.resultCache.set(cacheKey, response);
      this.auditLogs.push(auditRecord);
      console.log(`[VALIDATION_FAILED] 业务编号 ${request.businessNo}: ${validation.error}`);
      return response;
    }
    const timeCheck = this.checkTimeBoundary(request);
    if (!timeCheck.inRange) {
      const auditRecord = this.createAuditRecord(request, '失败', timeCheck.error);
      const response: SortingResponse = {
        businessNo: request.businessNo,
        status: '失败',
        failedReason: timeCheck.error,
        ruleVersion: request.ruleVersion,
        operator: request.operator,
        auditRecord
      };
      this.resultCache.set(cacheKey, response);
      this.auditLogs.push(auditRecord);
      console.log(`[TIME_OUT_OF_RANGE] 业务编号 ${request.businessNo}: ${timeCheck.error}`);
      return response;
    }
    const ruleConfig = this.ruleConfigs.get(request.ruleVersion)!;
    for (const lockRule of ruleConfig.lockRules) {
      if (lockRule.condition(request)) {
        const auditRecord = this.createAuditRecord(request, '已锁定', lockRule.lockReason);
        const response: SortingResponse = {
          businessNo: request.businessNo,
          status: '已锁定',
          lockReason: lockRule.lockReason,
          ruleVersion: request.ruleVersion,
          operator: request.operator,
          auditRecord
        };
        this.resultCache.set(cacheKey, response);
        this.auditLogs.push(auditRecord);
        console.log(`[LOCKED] 业务编号 ${request.businessNo}: ${lockRule.lockReason}`);
        return response;
      }
    }
    const supplementItems: string[] = [];
    for (const supplementRule of ruleConfig.supplementRules) {
      if (supplementRule.condition(request)) {
        supplementItems.push(supplementRule.supplementItem);
      }
    }
    if (supplementItems.length > 0) {
      const reason = `需补充材料: ${supplementItems.join('、')}`;
      const auditRecord = this.createAuditRecord(request, '需补充', reason);
      const response: SortingResponse = {
        businessNo: request.businessNo,
        status: '需补充',
        supplementItems,
        ruleVersion: request.ruleVersion,
        operator: request.operator,
        auditRecord
      };
      this.resultCache.set(cacheKey, response);
      this.auditLogs.push(auditRecord);
      console.log(`[SUPPLEMENT_NEEDED] 业务编号 ${request.businessNo}: ${reason}`);
      return response;
    }
    for (const businessRule of ruleConfig.businessRules) {
      if (businessRule.condition(request)) {
        const auditRecord = this.createAuditRecord(request, '可办理', businessRule.description);
        const response: SortingResponse = {
          businessNo: request.businessNo,
          status: '可办理',
          ruleVersion: request.ruleVersion,
          operator: request.operator,
          auditRecord
        };
        this.resultCache.set(cacheKey, response);
        this.auditLogs.push(auditRecord);
        console.log(`[PROCESSABLE] 业务编号 ${request.businessNo}: 可正常办理`);
        return response;
      }
    }
    const unknownReason = '对象状态未匹配到任何规则';
    const auditRecord = this.createAuditRecord(request, '失败', unknownReason);
    const response: SortingResponse = {
      businessNo: request.businessNo,
      status: '失败',
      failedReason: unknownReason,
      ruleVersion: request.ruleVersion,
      operator: request.operator,
      auditRecord
    };
    this.resultCache.set(cacheKey, response);
    this.auditLogs.push(auditRecord);
    console.log(`[NO_RULE_MATCHED] 业务编号 ${request.businessNo}: ${unknownReason}`);
    return response;
  }

  public recheck(auditId: string, recheckOperator: string): AuditRecord | null {
    const auditRecord = this.auditLogs.find(log => log.id === auditId);
    if (!auditRecord) {
      return null;
    }
    auditRecord.isRechecked = true;
    auditRecord.recheckedBy = recheckOperator;
    auditRecord.recheckedTime = new Date().toISOString();
    console.log(`[RECHECKED] 审计记录 ${auditId} 已由 ${recheckOperator} 复核`);
    return auditRecord;
  }

  public getAuditLogs(): AuditRecord[] {
    return [...this.auditLogs];
  }

  public getAuditLogById(id: string): AuditRecord | undefined {
    return this.auditLogs.find(log => log.id === id);
  }

  public clearCache(): void {
    this.resultCache.clear();
    console.log('[CACHE_CLEARED] 结果缓存已清空');
  }
}

export const ruleEngine = new RuleEngine();

