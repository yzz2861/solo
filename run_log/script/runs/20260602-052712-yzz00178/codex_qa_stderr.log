    16	class CompensationProcessor:
    17	    """赔付业务处理器
    18	
    19	    负责核心业务流程：
    20	    1. 重复提交检测
    21	    2. 数据校验
    22	    3. 规则引擎检查
    23	    4. 状态分流（可办理、需补充、已锁定、需人工复核、失败）
    24	    5. 后续闭环处理
    25	    """
    26	
    27	    @classmethod
    28	    def process(cls, request: CompensationRequest) -> CompensationResponse:
    29	        """处理赔付请求
    30	
    31	        Args:
    32	            request: 赔付请求
    33	
    34	        Returns:
    35	            赔付响应
    36	        """
    37	        trace_id = TraceIdGenerator.generate(
    38	            batch_no=request.batch_no,
    39	            user_id=request.operator_id
    40	        )
    41	
    42	        try:
    43	            response = cls._process_internal(request, trace_id)
    44	
    45	            request_dict = json.loads(request.model_dump_json())
    46	            response_dict = json.loads(response.model_dump_json())
    47	            storage.record_process_history(trace_id, request.batch_no, request_dict, response_dict)
    48	
    49	            return response
    50	
    51	        except Exception as e:
    52	            return CompensationResponse(
    53	                trace_id=trace_id,
    54	                batch_no=request.batch_no,
    55	                process_status=ProcessStatus.FAILED,
    56	                total_count=len(request.details),
    57	                failed_count=len(request.details),
    58	                failure_details=[
    59	                    FailureDetail(
    60	                        failure_category=FailureCategory.SYSTEM_ERROR,
    61	                        failure_code="SYS_ERR_001",
    62	                        failure_message=f"系统处理异常: {str(e)}",
    63	                        suggestion="请联系技术支持或稍后重试"
    64	                    )
    65	                ]
    66	            )
    67	
    68	    @classmethod
    69	    def _process_internal(
    70	        cls,
    71	        request: CompensationRequest,
    72	        trace_id: str
    73	    ) -> CompensationResponse:
    74	        """内部处理逻辑
    75	
    76	        分流规则：
    77	        - 重复提交 → 直接返回 FAILED + DUPLICATE_SUBMIT
    78	        - 校验错误 → FAILED + VALIDATION_ERROR（按明细项分流）
    79	        - 规则命中(锁定类如黑名单) → LOCKED + RULE_HIT
    80	        - 材料缺失 → NEED_SUPPLEMENT
    81	        - 需人工复核 → MANUAL_REVIEW（独立分流，不混入 failure_details）
    82	        - 全部通过 → PROCESSABLE
    83	        """
    84	
    85	        total_count = len(request.details)
    86	        processable_details: List[DetailItem] = []
    87	        need_supplement_details: List[SupplementInfo] = []
    88	        locked_details: List[DetailItem] = []
    89	        review_details: List[ReviewInfo] = []
    90	        validation_failures: List[FailureDetail] = []
    91	        locked_failures: List[FailureDetail] = []
    92	
    93	        if request.process_action != ProcessAction.SUPPLEMENT:
    94	            duplicate_check_result = cls._check_duplicate_submit(request)
    95	            if duplicate_check_result:
    96	                return CompensationResponse(
    97	                    trace_id=trace_id,
    98	                    batch_no=request.batch_no,
    99	                    process_status=ProcessStatus.FAILED,
   100	                    total_count=total_count,
   101	                    failed_count=total_count,
   102	                    duplicate_submit_count=total_count,
   103	                    failure_details=[duplicate_check_result]
   104	                )
   105	
   106	        all_validation_failures = DataValidator.validate_request(request)
   107	        if all_validation_failures:
   108	            has_critical_errors = any(
   109	                f.detail_id is None and f.failure_category == FailureCategory.VALIDATION_ERROR
   110	                for f in all_validation_failures
   111	            )
   112	
   113	            if has_critical_errors:
   114	                return CompensationResponse(
   115	                    trace_id=trace_id,
   116	                    batch_no=request.batch_no,
   117	                    process_status=ProcessStatus.FAILED,
   118	                    total_count=total_count,
   119	                    failed_count=total_count,
   120	                    validation_error_count=len(all_validation_failures),
   121	                    failure_details=all_validation_failures
   122	                )
   123	
   124	        valid_detail_ids = {d.detail_id for d in request.details}
   125	        all_validation_failures = [
   126	            f for f in all_validation_failures
   127	            if f.detail_id is None or f.detail_id in valid_detail_ids
   128	        ]
   129	
   130	        context = storage.get_context_data()
   131	        context['source_channel'] = request.source_channel
   132	        context['process_action'] = request.process_action
   133	        context['review_opinion'] = request.review_opinion
   134	
   135	        rule_results = rule_engine.check_details(request.details, context)
   136	
   137	        for detail in request.details:
   138	            detail_validation_failures = [
   139	                f for f in all_validation_failures if f.detail_id == detail.detail_id
   140	            ]
   141	
   142	            if detail_validation_failures:
   143	                validation_failures.extend(detail_validation_failures)
   144	                continue
   145	
   146	            rule_result = rule_results.get(detail.detail_id, {})
   147	            locked_rules = rule_result.get('locked_rules', [])
   148	            review_rules = rule_result.get('review_rules', [])
   149	
   150	            if locked_rules:
   151	                locked_failures.extend(locked_rules)
   152	                locked_details.append(detail)
   153	                continue
   154	
   155	            missing_materials = DataValidator.check_missing_materials(detail)
   156	            if missing_materials:
   157	                supplement_deadline = datetime.now() + timedelta(days=DataValidator.MAX_SUPPLEMENT_DAYS)
   158	                need_supplement_details.append(SupplementInfo(
   159	                    detail_id=detail.detail_id,
   160	                    missing_materials=missing_materials,
   161	                    supplement_deadline=supplement_deadline
   162	                ))
   163	                continue
   164	
   165	            if review_rules:
   166	                reason_parts = [f"{r.rule_name or r.failure_code}: {r.failure_message}" for r in review_rules]
   167	                review_details.append(ReviewInfo(
   168	                    detail_id=detail.detail_id,
   169	                    review_reason="；".join(reason_parts),
   170	                    review_rules=review_rules
   171	                ))
   172	                continue
   173	
   174	            processable_details.append(detail)
   175	
   176	        for detail in processable_details:
   177	            storage.mark_detail_processed(detail.detail_id)
   178	            comp_amount = detail.compensation_amount or detail.claim_amount
   179	            storage.record_user_loss(detail.user_id, detail.loss_time, comp_amount)
   180	            storage.record_device_loss(detail.powerbank_sn, detail.loss_time)
   181	
   182	        if processable_details or locked_details or need_supplement_details or review_details:
   183	            storage.mark_batch_processed(request.batch_no)
   184	
   185	        all_failures = validation_failures + locked_failures
   186	
   187	        rule_hit_count = len(locked_failures)
   188	        manual_review_count = sum(len(r.review_rules) for r in review_details)
   189	        dup_count = 0
   190	        val_err_count = len(validation_failures)
   191	
   192	        process_status = cls._determine_process_status(
   193	            processable_count=len(processable_details),
   194	            need_supplement_count=len(need_supplement_details),
   195	            locked_count=len(locked_details),
   196	            review_count=len(review_details),
   197	            failed_count=len(all_failures)
   198	        )
   199	
   200	        response = CompensationResponse(
   201	            trace_id=trace_id,
   202	            batch_no=request.batch_no,
   203	            process_status=process_status,
   204	            processable_count=len(processable_details),
   205	            need_supplement_count=len(need_supplement_details),
   206	            locked_count=len(locked_details),
   207	            review_count=len(review_details),
   208	            failed_count=len(all_failures),
   209	            total_count=total_count,
   210	            rule_hit_count=rule_hit_count,
   211	            manual_review_count=manual_review_count,
   212	            duplicate_submit_count=dup_count,
   213	            validation_error_count=val_err_count,
   214	            processable_details=processable_details,
   215	            need_supplement_details=need_supplement_details,
   216	            locked_details=locked_details,
   217	            review_details=review_details,
   218	            failure_details=all_failures
   219	        )
   220	
   221	        cls._add_remark(request, response)
   222	
   223	        return response
   224	
   225	    @classmethod
   226	    def _check_duplicate_submit(cls, request: CompensationRequest) -> Optional[FailureDetail]:
   227	        """检查重复提交"""
   228	
   229	        if request.process_action == ProcessAction.SUPPLEMENT:
   230	            return None
   231	
   232	        if storage.is_batch_processed(request.batch_no):
   233	            process_time = storage.get_batch_process_time(request.batch_no)
   234	            batch_status = storage.get_batch_status(request.batch_no)
   235	
   236	            time_str = process_time.strftime("%Y-%m-%d %H:%M:%S") if process_time else "未知"
   237	
   238	            return FailureDetail(
   239	                failure_category=FailureCategory.DUPLICATE_SUBMIT,
   240	                failure_code="DUP_BAT_001",
   241	                failure_message=f"批次号[{request.batch_no}]已在{time_str}处理过，当前状态: {batch_status}",
   242	                suggestion="请勿重复提交同一批次，如需补充材料请使用SUPPLEMENT动作"
   243	            )
   244	
   245	        duplicate_details = []
   246	        for detail in request.details:
   247	            if storage.is_detail_processed(detail.detail_id):
   248	                duplicate_details.append(detail.detail_id)
   249	
   250	        if duplicate_details:
   251	            return FailureDetail(
   252	                failure_category=FailureCategory.DUPLICATE_SUBMIT,
   253	                failure_code="DUP_DTL_001",
   254	                failure_message=f"以下明细项ID已处理过: {', '.join(duplicate_details)}",
   255	                suggestion="请检查明细项ID，请勿重复处理同一明细项"
   256	            )
   257	
   258	        return None
   259	
   260	    @classmethod
   261	    def _determine_process_status(
   262	        cls,
   263	        processable_count: int,
   264	        need_supplement_count: int,
   265	        locked_count: int,
   266	        review_count: int,
   267	        failed_count: int
   268	    ) -> ProcessStatus:
   269	        """确定整体处理状态
   270	
   271	        优先级：PROCESSABLE > LOCKED > MANUAL_REVIEW > NEED_SUPPLEMENT > FAILED
   272	        只要有可办理项就优先标记为 PROCESSABLE，让调用方关注可处理的部分
   273	        """
   274	
   275	        if processable_count > 0 and need_supplement_count == 0 and locked_count == 0 and review_count == 0 and failed_count == 0:
   276	            return ProcessStatus.PROCESSABLE
   277	
   278	        if locked_count > 0 and processable_count == 0 and need_supplement_count == 0 and review_count == 0 and failed_count == locked_count:
   279	            return ProcessStatus.LOCKED
   280	

