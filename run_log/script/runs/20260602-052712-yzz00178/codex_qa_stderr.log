from typing import List, Dict, Optional, Callable, Tuple
from datetime import datetime, timedelta
from app.models.schemas import (
    DetailItem, FailureDetail, FailureCategory, SourceChannel
)


class Rule:
    """规则定义"""

    def __init__(
        self,
        rule_id: str,
        rule_name: str,
        rule_type: str,
        check_func: Callable,
        failure_code: str,
        failure_message: str,
        suggestion: str,
        priority: int = 0,
        enabled: bool = True
    ):
        self.rule_id = rule_id
        self.rule_name = rule_name
        self.rule_type = rule_type
        self.check_func = check_func
        self.failure_code = failure_code
        self.failure_message = failure_message
        self.suggestion = suggestion
        self.priority = priority
        self.enabled = enabled

    def check(self, detail: DetailItem, context: Dict = None) -> Optional[FailureDetail]:
        """执行规则检查"""
        if not self.enabled:
            return None

        context = context or {}
        is_violated = self.check_func(detail, context)

        if is_violated:
            return FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.RULE_HIT,
                failure_code=self.failure_code,
                failure_message=self.failure_message,
                rule_id=self.rule_id,
                rule_name=self.rule_name,
                suggestion=self.suggestion
            )

        return None


class RuleEngine:
    """规则引擎

    负责业务规则判断和阈值检测，包括：
    - 赔付金额阈值规则
    - 用户历史赔付规则
    - 黑名单规则
    - 高风险设备规则
    - 高风险地区规则
    - 频繁申请规则
    - 人工复核规则
    """

    def __init__(self):
        self._rules: List[Rule] = []
        self._init_default_rules()

    def _init_default_rules(self):
        """初始化默认规则"""

        def check_amount_threshold(detail, context):
            """金额阈值规则：单台赔付超过200元需人工复核"""
            threshold = context.get('high_amount_threshold', 200.0)
            claim_amount = detail.compensation_amount or detail.claim_amount
            return claim_amount > threshold

        def check_frequent_loss(detail, context):
            """频繁遗失规则：用户90天内遗失超过3次"""
            user_loss_history = context.get('user_loss_history', {})
            user_id = detail.user_id
            loss_count = user_loss_history.get(user_id, {}).get('count_90d', 0)
            return loss_count >= 3

        def check_blacklist_user(detail, context):
            """黑名单规则：用户在黑名单中"""
            blacklist = context.get('user_blacklist', [])
            return detail.user_id in blacklist

        def check_high_risk_device(detail, context):
            """高风险设备规则：设备型号存在异常高遗失率"""
            high_risk_models = context.get('high_risk_models', [])
            return detail.device_model in high_risk_models

        def check_high_risk_location(detail, context):
            """高风险地区规则：遗失地点为高风险区域"""
            high_risk_locations = context.get('high_risk_locations', [])
            return detail.loss_location in high_risk_locations

        def check_total_compensation(detail, context):
            """累计赔付规则：用户累计赔付超过500元"""
            user_loss_history = context.get('user_loss_history', {})
            user_id = detail.user_id
            total_comp = user_loss_history.get(user_id, {}).get('total_compensation', 0)
            current_amount = detail.compensation_amount or detail.claim_amount
            return (total_comp + current_amount) > 500

        def check_same_device_loss(detail, context):
            """同设备重复遗失规则：同一设备180天内重复遗失"""
            device_loss_history = context.get('device_loss_history', {})
            sn = detail.powerbank_sn
            last_loss_time = device_loss_history.get(sn, {}).get('last_loss_time')
            if last_loss_time:
                if isinstance(last_loss_time, str):
                    last_loss_time = datetime.fromisoformat(last_loss_time.replace('Z', '+00:00'))
                days_diff = (detail.loss_time - last_loss_time).days
                return days_diff <= 180
            return False

        def check_manual_review_required(detail, context):
            """人工复核规则：来自第三方渠道且金额超过100元"""
            source_channel = context.get('source_channel')
            amount = detail.compensation_amount or detail.claim_amount
            return source_channel == SourceChannel.THIRD_PARTY and amount > 100

        self._rules = [
            Rule(
                rule_id="RULE_AMT_001",
                rule_name="高额赔付复核规则",
                rule_type="AMOUNT",
                check_func=check_amount_threshold,
                failure_code="RUL_AMT_001",
                failure_message="单台赔付金额超过阈值，需人工复核",
                suggestion="请人工复核该笔申请的合理性",
                priority=10,
                enabled=True
            ),
            Rule(
                rule_id="RULE_FRQ_001",
                rule_name="频繁遗失规则",
                rule_type="FREQUENCY",
                check_func=check_frequent_loss,
                failure_code="RUL_FRQ_001",
                failure_message="用户90天内遗失次数超过阈值",
                suggestion="请核实用户遗失情况的真实性",
                priority=20,
                enabled=True
            ),
            Rule(
                rule_id="RULE_BLK_001",
                rule_name="用户黑名单规则",
                rule_type="BLACKLIST",
                check_func=check_blacklist_user,
                failure_code="RUL_BLK_001",
                failure_message="用户在黑名单中，不予赔付",
                suggestion="该用户存在恶意索赔记录，请直接拒赔",
                priority=100,
                enabled=True
            ),
            Rule(
                rule_id="RULE_DEV_001",
                rule_name="高风险设备规则",
                rule_type="DEVICE",
                check_func=check_high_risk_device,
                failure_code="RUL_DEV_001",
                failure_message="该设备型号存在异常高遗失率",
                suggestion="请核实设备是否存在质量问题",
                priority=30,
                enabled=True
            ),
            Rule(
                rule_id="RULE_LOC_001",
                rule_name="高风险地区规则",
                rule_type="LOCATION",
                check_func=check_high_risk_location,
                failure_code="RUL_LOC_001",
                failure_message="遗失地点为高风险区域",
                suggestion="请核实该地点遗失情况，必要时联系用户确认",
                priority=40,
                enabled=True
            ),
            Rule(
                rule_id="RULE_TOT_001",
                rule_name="累计赔付超限规则",
                rule_type="AMOUNT",
                check_func=check_total_compensation,
                failure_code="RUL_TOT_001",
                failure_message="用户累计赔付金额超过阈值",
                suggestion="请核实用户累计赔付情况，评估是否继续赔付",
                priority=15,
                enabled=True
            ),
            Rule(
                rule_id="RULE_DUP_001",
                rule_name="同设备重复遗失规则",
                rule_type="FREQUENCY",
                check_func=check_same_device_loss,
                failure_code="RUL_DUP_001",
                failure_message="该设备180天内存在重复遗失记录",
                suggestion="请核实是否为同一设备重复遗失，是否存在欺诈",
                priority=25,
                enabled=True
            ),
            Rule(
                rule_id="RULE_MNL_001",
                rule_name="第三方渠道复核规则",
                rule_type="MANUAL",
                check_func=check_manual_review_required,
                failure_code="RUL_MNL_001",
                failure_message="第三方渠道且金额超过100元，需人工复核",
                suggestion="请人工复核第三方渠道提交的申请",
                priority=50,
                enabled=True
            )
        ]

        self._rules.sort(key=lambda r: r.priority, reverse=True)

    def add_rule(self, rule: Rule):
        """添加规则"""
        self._rules.append(rule)
        self._rules.sort(key=lambda r: r.priority, reverse=True)

    def enable_rule(self, rule_id: str):
        """启用规则"""
        for rule in self._rules:
            if rule.rule_id == rule_id:
                rule.enabled = True
                break

    def disable_rule(self, rule_id: str):
        """禁用规则"""
        for rule in self._rules:
            if rule.rule_id == rule_id:
                rule.enabled = False
                break

    def check_detail(
        self,
        detail: DetailItem,
        context: Dict = None,
        stop_on_first_hit: bool = False
    ) -> Tuple[List[FailureDetail], List[FailureDetail]]:
        """检查单条明细项的规则

        Args:
            detail: 明细项
            context: 上下文数据（用户历史、黑名单等）
            stop_on_first_hit: 是否在命中第一条规则后停止

        Returns:
            (需锁定的规则, 需人工复核的规则)
        """
        context = context or {}
        locked_rules: List[FailureDetail] = []
        review_rules: List[FailureDetail] = []

        for rule in self._rules:
            result = rule.check(detail, context)
            if result:
                if rule.rule_type == 'BLACKLIST':
                    locked_rules.append(result)
                else:
                    result.failure_category = FailureCategory.MANUAL_REVIEW
                    review_rules.append(result)

                if stop_on_first_hit:
                    break

        return locked_rules, review_rules

    def check_details(
        self,
        details: List[DetailItem],
        context: Dict = None
    ) -> Dict[str, Dict]:
        """批量检查明细项

        Args:
            details: 明细项列表
            context: 上下文数据

        Returns:
            检查结果字典，key为detail_id
        """
        results = {}
        for detail in details:
            locked, review = self.check_detail(detail, context)
            results[detail.detail_id] = {
                'locked_rules': locked,
                'review_rules': review,
                'should_lock': len(locked) > 0,
                'should_review': len(review) > 0 and len(locked) == 0
            }
        return results

    def get_all_rules(self) -> List[Dict]:
        """获取所有规则信息"""
        return [
            {
                'rule_id': r.rule_id,
                'rule_name': r.rule_name,
                'rule_type': r.rule_type,
                'failure_code': r.failure_code,
                'priority': r.priority,
                'enabled': r.enabled
            }
            for r in self._rules
        ]


