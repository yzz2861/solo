from typing import List, Tuple, Optional
from datetime import datetime, timedelta
from app.models.schemas import (
    CompensationRequest, DetailItem, FailureDetail,
    FailureCategory, SourceChannel, ProcessAction
)


class DataValidator:
    """数据校验服务

    负责请求参数合法性校验，包括：
    - 必填字段校验
    - 格式规范校验
    - 业务逻辑校验
    - 边界条件校验
    """

    POWERBANK_SN_PATTERN_PREFIXES = ['PB', 'CH', 'SP']
    MAX_CLAIM_AMOUNT = 10000.0
    MAX_SUPPLEMENT_DAYS = 30

    @classmethod
    def validate_request(cls, request: CompensationRequest) -> List[FailureDetail]:
        """校验整个请求

        Args:
            request: 赔付请求

        Returns:
            校验失败详情列表，空列表表示全部通过
        """
        failures = []

        batch_failures = cls._validate_batch(request)
        failures.extend(batch_failures)

        channel_failures = cls._validate_source_channel(request)
        failures.extend(channel_failures)

        action_failures = cls._validate_process_action(request)
        failures.extend(action_failures)

        detail_ids = set()
        for detail in request.details:
            detail_failures = cls._validate_detail(detail)
            failures.extend(detail_failures)

            if detail.detail_id in detail_ids:
                failures.append(FailureDetail(
                    detail_id=detail.detail_id,
                    failure_category=FailureCategory.VALIDATION_ERROR,
                    failure_code="VLD_DUP_001",
                    failure_message=f"明细项ID重复: {detail.detail_id}",
                    suggestion="请检查明细项ID，确保唯一"
                ))
            detail_ids.add(detail.detail_id)

        return failures

    @classmethod
    def _validate_batch(cls, request: CompensationRequest) -> List[FailureDetail]:
        """校验批次号"""
        failures = []
        batch_no = request.batch_no

        if len(batch_no) < 8:
            failures.append(FailureDetail(
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_BAT_001",
                failure_message=f"批次号长度不足，当前长度: {len(batch_no)}，最小长度: 8",
                suggestion="请输入不少于8位的批次号"
            ))

        if len(batch_no) > 32:
            failures.append(FailureDetail(
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_BAT_002",
                failure_message=f"批次号长度超限，当前长度: {len(batch_no)}，最大长度: 32",
                suggestion="请输入不超过32位的批次号"
            ))

        return failures

    @classmethod
    def _validate_source_channel(cls, request: CompensationRequest) -> List[FailureDetail]:
        """校验来源渠道"""
        failures = []

        valid_channels = [e.value for e in SourceChannel]
        if request.source_channel.value not in valid_channels:
            failures.append(FailureDetail(
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_CHN_001",
                failure_message=f"无效的来源渠道: {request.source_channel}",
                suggestion=f"请选择有效的来源渠道: {', '.join(valid_channels)}"
            ))

        return failures

    @classmethod
    def _validate_process_action(cls, request: CompensationRequest) -> List[FailureDetail]:
        """校验处理动作"""
        failures = []

        valid_actions = [e.value for e in ProcessAction]
        if request.process_action.value not in valid_actions:
            failures.append(FailureDetail(
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_ACT_001",
                failure_message=f"无效的处理动作: {request.process_action}",
                suggestion=f"请选择有效的处理动作: {', '.join(valid_actions)}"
            ))

        if request.process_action in [ProcessAction.APPROVE, ProcessAction.REJECT, ProcessAction.REVIEW]:
            if not request.review_opinion or len(request.review_opinion.strip()) == 0:
                failures.append(FailureDetail(
                    failure_category=FailureCategory.VALIDATION_ERROR,
                    failure_code="VLD_ACT_002",
                    failure_message=f"处理动作为{request.process_action.value}时，复核意见不能为空",
                    suggestion="请填写复核意见后再提交"
                ))

        return failures

    @classmethod
    def _validate_detail(cls, detail: DetailItem) -> List[FailureDetail]:
        """校验单个明细项"""
        failures = []

        id_failures = cls._validate_detail_id(detail)
        failures.extend(id_failures)

        sn_failures = cls._validate_powerbank_sn(detail)
        failures.extend(sn_failures)

        user_failures = cls._validate_user_id(detail)
        failures.extend(user_failures)

        time_failures = cls._validate_loss_time(detail)
        failures.extend(time_failures)

        amount_failures = cls._validate_amounts(detail)
        failures.extend(amount_failures)

        return failures

    @classmethod
    def _validate_detail_id(cls, detail: DetailItem) -> List[FailureDetail]:
        """校验明细项ID"""
        failures = []

        if not detail.detail_id or len(detail.detail_id.strip()) == 0:
            failures.append(FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_DTL_001",
                failure_message="明细项ID不能为空",
                suggestion="请填写明细项ID"
            ))
        elif len(detail.detail_id) > 64:
            failures.append(FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_DTL_002",
                failure_message=f"明细项ID长度超限: {len(detail.detail_id)}，最大长度: 64",
                suggestion="明细项ID请控制在64字符以内"
            ))

        return failures

    @classmethod
    def _validate_powerbank_sn(cls, detail: DetailItem) -> List[FailureDetail]:
        """校验充电宝序列号"""
        failures = []
        sn = detail.powerbank_sn

        if not sn or len(sn.strip()) == 0:
            failures.append(FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_SN_001",
                failure_message="充电宝序列号不能为空",
                suggestion="请填写充电宝序列号"
            ))
            return failures

        valid_prefix = False
        for prefix in cls.POWERBANK_SN_PATTERN_PREFIXES:
            if sn.startswith(prefix):
                valid_prefix = True
                break

        if not valid_prefix:
            failures.append(FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_SN_002",
                failure_message=f"充电宝序列号格式错误: {sn}，应以{', '.join(cls.POWERBANK_SN_PATTERN_PREFIXES)}开头",
                suggestion="请检查充电宝序列号格式"
            ))

        if len(sn) < 8:
            failures.append(FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_SN_003",
                failure_message=f"充电宝序列号长度不足: {len(sn)}，最小长度: 8",
                suggestion="请输入完整的充电宝序列号"
            ))

        if len(sn) > 32:
            failures.append(FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_SN_004",
                failure_message=f"充电宝序列号长度超限: {len(sn)}，最大长度: 32",
                suggestion="请检查充电宝序列号是否正确"
            ))

        return failures

    @classmethod
    def _validate_user_id(cls, detail: DetailItem) -> List[FailureDetail]:
        """校验用户ID"""
        failures = []

        if not detail.user_id or len(detail.user_id.strip()) == 0:
            failures.append(FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_USR_001",
                failure_message="用户ID不能为空",
                suggestion="请填写用户ID"
            ))

        return failures

    @classmethod
    def _validate_loss_time(cls, detail: DetailItem) -> List[FailureDetail]:
        """校验遗失时间"""
        failures = []
        loss_time = detail.loss_time

        if not loss_time:
            failures.append(FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_LTM_001",
                failure_message="遗失时间不能为空",
                suggestion="请填写遗失时间"
            ))
            return failures

        now = datetime.now()

        if loss_time > now:
            failures.append(FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_LTM_002",
                failure_message=f"遗失时间不能晚于当前时间: {loss_time.strftime('%Y-%m-%d %H:%M:%S')}",
                suggestion="请检查遗失时间是否正确"
            ))

        earliest_allowed = now - timedelta(days=365)
        if loss_time < earliest_allowed:
            failures.append(FailureDetail(
                detail_id=detail.detail_id,
                failure_category=FailureCategory.VALIDATION_ERROR,
                failure_code="VLD_LTM_003",
                failure_message=f"遗失时间超出追溯期限: {loss_time.strftime('%Y-%m-%d %H:%M:%S')}，仅支持1年内的遗失申请",
                suggestion="遗失时间超过1年的申请需走特殊审批流程"
            ))

        return failures

    @classmethod
    def _validate_amounts(cls, detail: DetailItem) -> List[FailureDetail]:
        """校验金额"""
from typing import Dict, List, Optional, Set, Tuple
from datetime import datetime
from collections import defaultdict


class InMemoryStorage:
    """内存存储

    用于存储：
    - 已处理的批次号（防重复提交）
    - 已处理的明细项ID（防重复处理）
    - 用户历史遗失记录
    - 设备历史遗失记录
    - 处理历史记录（用于历史回放）
    """

    def __init__(self):
        self._processed_batches: Dict[str, datetime] = {}
        self._processed_details: Dict[str, datetime] = {}
        self._user_loss_history: Dict[str, Dict] = defaultdict(lambda: {
            'count_90d': 0,
            'total_compensation': 0,
            'loss_records': []
        })
        self._device_loss_history: Dict[str, Dict] = defaultdict(lambda: {
            'last_loss_time': None,
            'loss_count': 0
        })
        self._user_blacklist: Set[str] = set()
        self._high_risk_models: Set[str] = set()
        self._high_risk_locations: Set[str] = set()
        self._process_history: List[Dict] = []
        self._batch_processing_status: Dict[str, str] = {}

    def is_batch_processed(self, batch_no: str) -> bool:
        """检查批次是否已处理"""
        return batch_no in self._processed_batches

    def mark_batch_processed(self, batch_no: str, status: str = 'COMPLETED'):
        """标记批次为已处理"""
        self._processed_batches[batch_no] = datetime.now()
        self._batch_processing_status[batch_no] = status

    def get_batch_status(self, batch_no: str) -> Optional[str]:
        """获取批次处理状态"""
        return self._batch_processing_status.get(batch_no)

    def get_batch_process_time(self, batch_no: str) -> Optional[datetime]:
        """获取批次处理时间"""
        return self._processed_batches.get(batch_no)

    def is_detail_processed(self, detail_id: str) -> bool:
        """检查明细项是否已处理"""
        return detail_id in self._processed_details

    def mark_detail_processed(self, detail_id: str):
        """标记明细项为已处理"""
        self._processed_details[detail_id] = datetime.now()

    def record_user_loss(self, user_id: str, loss_time: datetime, compensation_amount: float):
        """记录用户遗失记录"""
        history = self._user_loss_history[user_id]
        history['count_90d'] += 1
        history['total_compensation'] += compensation_amount or 0
        history['loss_records'].append({
            'loss_time': loss_time,
            'compensation_amount': compensation_amount
        })
        self._cleanup_old_user_records(user_id)

    def _cleanup_old_user_records(self, user_id: str):
        """清理超过90天的用户记录"""
        history = self._user_loss_history[user_id]
        now = datetime.now()
        recent_records = []
        count_90d = 0

        for record in history['loss_records']:
            days_diff = (now - record['loss_time']).days
            if days_diff <= 90:
                recent_records.append(record)
                count_90d += 1

        history['loss_records'] = recent_records
        history['count_90d'] = count_90d

    def record_device_loss(self, powerbank_sn: str, loss_time: datetime):
        """记录设备遗失记录"""
        history = self._device_loss_history[powerbank_sn]
        history['last_loss_time'] = loss_time
        history['loss_count'] += 1

    def get_user_history(self, user_id: str) -> Dict:
        """获取用户历史记录"""
        return self._user_loss_history.get(user_id, {
            'count_90d': 0,
            'total_compensation': 0,
            'loss_records': []
        })

    def get_device_history(self, powerbank_sn: str) -> Dict:
        """获取设备历史记录"""
        return self._device_loss_history.get(powerbank_sn, {
            'last_loss_time': None,
            'loss_count': 0
        })

    def add_to_blacklist(self, user_id: str):
        """添加用户到黑名单"""
        self._user_blacklist.add(user_id)

    def remove_from_blacklist(self, user_id: str):
        """从黑名单移除用户"""
        self._user_blacklist.discard(user_id)

    def is_user_blacklisted(self, user_id: str) -> bool:
        """检查用户是否在黑名单"""
        return user_id in self._user_blacklist

    def add_high_risk_model(self, model: str):
        """添加高风险设备型号"""
        self._high_risk_models.add(model)

    def remove_high_risk_model(self, model: str):
        """移除高风险设备型号"""
        self._high_risk_models.discard(model)

    def add_high_risk_location(self, location: str):
        """添加高风险地区"""
        self._high_risk_locations.add(location)

    def remove_high_risk_location(self, location: str):
        """移除高风险地区"""
        self._high_risk_locations.discard(location)

    def get_context_data(self) -> Dict:
        """获取规则引擎需要的上下文数据"""
        return {
            'user_loss_history': dict(self._user_loss_history),
            'device_loss_history': dict(self._device_loss_history),
            'user_blacklist': list(self._user_blacklist),
            'high_risk_models': list(self._high_risk_models),
            'high_risk_locations': list(self._high_risk_locations)
        }

    def record_process_history(self, trace_id: str, batch_no: str, request_data: Dict, response_data: Dict):
        """记录处理历史（用于历史回放）"""
        self._process_history.append({
            'trace_id': trace_id,
            'batch_no': batch_no,
            'request': request_data,
            'response': response_data,
            'process_time': datetime.now()
        })

    def get_process_history(self, batch_no: str = None, trace_id: str = None) -> List[Dict]:
        """查询处理历史"""
        results = self._process_history

        if batch_no:
            results = [h for h in results if h['batch_no'] == batch_no]

        if trace_id:
            results = [h for h in results if h['trace_id'] == trace_id]

        return sorted(results, key=lambda x: x['process_time'], reverse=True)

    def clear_all(self):
        """清空所有数据（用于测试）"""
        self._processed_batches.clear()
        self._processed_details.clear()
        self._user_loss_history.clear()
        self._device_loss_history.clear()
        self._user_blacklist.clear()
        self._high_risk_models.clear()
        self._high_risk_locations.clear()
        self._process_history.clear()
        self._batch_processing_status.clear()

    def get_statistics(self) -> Dict:
        """获取统计信息"""
        return {
            'processed_batches': len(self._processed_batches),
            'processed_details': len(self._processed_details),
            'users_with_history': len(self._user_loss_history),
            'devices_with_history': len(self._device_loss_history),
            'blacklist_users': len(self._user_blacklist),
            'high_risk_models': len(self._high_risk_models),
            'high_risk_locations': len(self._high_risk_locations),
            'process_history_records': len(self._process_history)
        }


