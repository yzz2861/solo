async def add_high_risk_location(location: str = Query(..., description="地点名称")):
    """添加高风险地区"""
    storage.add_high_risk_location(location)
    return {"status": "success", "message": f"地点{location}已加入高风险列表"}


@app.post("/api/admin/clear", tags=["管理接口"])
async def clear_all_data():
