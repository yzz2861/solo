class TestTaskStatus:
    def test_full_lifecycle_pass(self):
        state = TaskState(business_id="ST001")
        assert state.current_status == TaskStatus.SUBMITTED
        state.transition(TaskStatus.PROCESSING)
        assert state.current_status == TaskStatus.PROCESSING
        state.transition(TaskStatus.PASSED)
        assert state.current_status == TaskStatus.PASSED
        assert state.is_terminal()

    def test_full_lifecycle_review_approved(self):
        state = TaskState(business_id="ST002")
        state.transition(TaskStatus.PROCESSING)
        state.transition(TaskStatus.PENDING_REVIEW)
        state.transition(TaskStatus.REVIEW_APPROVED)
        assert state.is_terminal()

    def test_invalid_transition_raises(self):
        state = TaskState(business_id="ST003")
        with pytest.raises(InvalidTransitionError):
            state.transition(TaskStatus.PASSED)

    def test_cannot_transition_from_terminal(self):
        state = TaskState(business_id="ST004")
        state.transition(TaskStatus.PROCESSING)
        state.transition(TaskStatus.PASSED)
        with pytest.raises(InvalidTransitionError):
            state.transition(TaskStatus.PROCESSING)


