        assert data["review_count"] == 1
        assert data["locked_count"] == 0
        assert data["manual_review_count"] >= 1
        assert data["rule_hit_count"] == 0
        assert len(data["review_details"]) == 1
        assert len(data["failure_details"]) == 0

    def test_duplicate_not_mixed_with_validation_error(self):
