class TestTraceableIdCases:
    """可追溯编号测试"""

    def test_trace_id_format(self):
        """测试：追溯编号格式正确性"""
        detail = create_detail_item(detail_id="DTL001")
        request = CompensationRequest(
            batch_no="BATCH20240101027",
            source_channel=SourceChannel.ONLINE_APP,
            process_action=ProcessAction.SUBMIT,
            details=[detail]
        )

        response = client.post(
            "/api/compensation/process",
            json=request.model_dump(mode='json')
        )

        assert response.status_code == 200
        data = response.json()
        trace_id = data["trace_id"]

        parts = trace_id.split("-")
        assert len(parts) == 5
        assert parts[0] == "CP"
        assert parts[1] == "CMP"
        assert len(parts[2]) == 14
        assert len(parts[3]) == 8
        assert len(parts[4]) == 4

    def test_trace_id_uniqueness(self):
        """测试：追溯编号唯一性"""
        trace_ids = set()
        for i in range(10):
            detail = create_detail_item(detail_id=f"DTL{i:03d}")
            request = CompensationRequest(
                batch_no=f"BATCH20240101{i:03d}",
                source_channel=SourceChannel.ONLINE_APP,
                process_action=ProcessAction.SUBMIT,
                details=[detail]
            )
            response = client.post(
                "/api/compensation/process",
                json=request.model_dump(mode='json')
            )
            data = response.json()
            trace_id = data["trace_id"]
            assert trace_id not in trace_ids
            trace_ids.add(trace_id)

        assert len(trace_ids) == 10

    def test_trace_id_parse(self):
        """测试：追溯编号解析功能"""
        trace_id = TraceIdGenerator.generate(batch_no="TEST001", user_id="USR001")
        parsed = TraceIdGenerator.parse_trace_id(trace_id)

        assert parsed["is_valid"] == True
        assert parsed["business_prefix"] == "CP"
        assert parsed["module_code"] == "CMP"
        assert "datetime" in parsed


