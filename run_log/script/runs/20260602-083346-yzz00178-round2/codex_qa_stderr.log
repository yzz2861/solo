class TestCategorySeparation:
    """分类分离验证：规则命中/人工复核/重复提交/校验错误严格分开"""

    def test_rule_hit_not_mixed_with_manual_review(self):
        """测试：规则命中（锁定类）不与人工复核混淆"""
        storage.add_to_blacklist("USR_BLK")
        detail = create_detail_item(detail_id="DTL001", user_id="USR_BLK", claim_amount=99.0)
        request = CompensationRequest(
            batch_no="BATCH_SEP_001",
            source_channel=SourceChannel.ONLINE_APP,
            process_action=ProcessAction.SUBMIT,
            details=[detail]
        )

        response = client.post(
            "/api/compensation/process",
            json=request.model_dump(mode='json')
        )

        data = response.json()
        assert data["process_status"] == ProcessStatus.LOCKED.value
        assert data["locked_count"] == 1
        assert data["review_count"] == 0
        assert data["rule_hit_count"] == 1
        assert data["manual_review_count"] == 0
        assert data["duplicate_submit_count"] == 0
        assert data["validation_error_count"] == 0
        assert all(f["failure_category"] == FailureCategory.RULE_HIT.value for f in data["failure_details"])

    def test_manual_review_not_mixed_with_rule_hit(self):
        """测试：人工复核不与规则命中（锁定类）混淆"""
