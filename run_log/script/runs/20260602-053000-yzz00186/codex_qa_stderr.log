import pandas as pd
from click.testing import CliRunner

from tea_grading_cli.cli import cli
from tea_grading_cli.reader import DataReader
from tea_grading_cli.validator import ValidationEngine
from tea_grading_cli.grader import TeaGrader
from tea_grading_cli.exporter import ResultExporter
from tea_grading_cli.models import GradeLevel, BadRowReason

DATA_DIR = os.path.join(os.path.dirname(__file__), 'data')


class CompliantSampleTest(TestCase):
    """合规样例：所有记录通过校验与定级"""

    def setUp(self):
        self.scenario_dir = os.path.join(DATA_DIR, 'compliant')
        self.output_dir = tempfile.mkdtemp()
        self.main_file = os.path.join(self.scenario_dir, 'main_list.csv')
        self.supplement_file = os.path.join(self.scenario_dir, 'supplement.csv')
        self.rules_file = os.path.join(self.scenario_dir, 'validation_rules.json')
        self.criteria_file = os.path.join(self.scenario_dir, 'grading_criteria.json')

    def tearDown(self):
        shutil.rmtree(self.output_dir, ignore_errors=True)

    def test_cli_run_compliant(self):
        runner = CliRunner()
        result = runner.invoke(cli, [
            'run',
            '--main', self.main_file,
            '--supplement', self.supplement_file,
            '--rules', self.rules_file,
            '--criteria', self.criteria_file,
            '--output-dir', self.output_dir,
        ])
        self.assertEqual(result.exit_code, 0, msg=result.output)
        self.assertIn('处理完成', result.output)

    def test_all_records_graded(self):
        main_records, bad_rows = DataReader.read_main_list(self.main_file)
        self.assertEqual(len(bad_rows), 0, f"合规样例不应有坏行: {bad_rows}")
        self.assertEqual(len(main_records), 5)

    def test_success_result_file_exists(self):
        runner = CliRunner()
        runner.invoke(cli, [
            'run',
            '--main', self.main_file,
            '--supplement', self.supplement_file,
            '--rules', self.rules_file,
            '--criteria', self.criteria_file,
            '--output-dir', self.output_dir,
        ])
        success_files = list(Path(self.output_dir).glob('定级成功结果_*.csv'))
        self.assertTrue(len(success_files) > 0, "应生成成功结果文件")
        df = pd.read_csv(success_files[0])
        self.assertEqual(len(df), 5, f"应有5条成功记录，实际{len(df)}")

    def test_bad_records_file_empty(self):
        runner = CliRunner()
        runner.invoke(cli, [
            'run',
            '--main', self.main_file,
            '--supplement', self.supplement_file,
            '--rules', self.rules_file,
            '--criteria', self.criteria_file,
            '--output-dir', self.output_dir,
        ])
        bad_files = list(Path(self.output_dir).glob('坏行记录_*.csv'))
        if bad_files:
            try:
                df = pd.read_csv(bad_files[0])
                self.assertEqual(len(df), 0, "合规样例不应有坏行记录")
            except pd.errors.EmptyDataError:
                pass

    def test_operation_log_exists(self):
        runner = CliRunner()
        runner.invoke(cli, [
            'run',
            '--main', self.main_file,
            '--supplement', self.supplement_file,
            '--rules', self.rules_file,
            '--criteria', self.criteria_file,
            '--output-dir', self.output_dir,
        ])
        log_files = list(Path(self.output_dir).glob('操作日志_*.log'))
        self.assertTrue(len(log_files) > 0, "应生成操作日志文件")

    def test_summary_json_exists(self):
        runner = CliRunner()
        runner.invoke(cli, [
            'run',
            '--main', self.main_file,
            '--supplement', self.supplement_file,
            '--rules', self.rules_file,
            '--criteria', self.criteria_file,
            '--output-dir', self.output_dir,
        ])
        summary_files = list(Path(self.output_dir).glob('处理汇总_*.json'))
        self.assertTrue(len(summary_files) > 0, "应生成处理汇总JSON")
        with open(summary_files[0], 'r', encoding='utf-8') as f:
            summary = json.load(f)
        self.assertEqual(summary['成功记录数'], 5)
        self.assertEqual(summary['坏行记录数'], 0)

    def test_grade_distribution(self):
        main_records, _ = DataReader.read_main_list(self.main_file)
        supplements = DataReader.read_supplement(self.supplement_file)
        rules = DataReader.read_validation_rules(self.rules_file)
        criteria = DataReader.read_grading_criteria(self.criteria_file)

        validation_engine = ValidationEngine(rules)
        seen = set()
        val_results = {}
        for m in main_records:
            is_valid, err, diff = validation_engine.validate_main_record(m, supplements, seen)
            val_results[m.id] = (is_valid, err, diff)
            seen.add(m.id)

        grader = TeaGrader(criteria)
        result = grader.grade_records(main_records, supplements, val_results)

        grade_values = [r.final_grade for r in result.graded_records]
        self.assertTrue(all(g != GradeLevel.REJECT for g in grade_values),
                        "合规样例不应有不合格等级")

    def test_console_output_shows_success_count(self):
        runner = CliRunner()
        result = runner.invoke(cli, [
            'run',
            '--main', self.main_file,
            '--supplement', self.supplement_file,
            '--rules', self.rules_file,
            '--criteria', self.criteria_file,
            '--output-dir', self.output_dir,
        ])
        self.assertIn('5', result.output, "控制台应显示5条成功记录")


