        self.rules_file = os.path.join(self.scenario_dir, 'validation_rules.json')
        self.criteria_file = os.path.join(self.scenario_dir, 'grading_criteria.json')

    def tearDown(self):
        shutil.rmtree(self.output_dir, ignore_errors=True)

    def test_dry_run_no_output_files(self):
        runner = CliRunner()
        result = runner.invoke(cli, [
            'run',
            '--main', self.main_file,
            '--supplement', self.supplement_file,
            '--rules', self.rules_file,
            '--criteria', self.criteria_file,
            '--output-dir', self.output_dir,
