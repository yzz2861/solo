    81	            if count >= limit:
    82	                break
    83	            if '主清单' in diff:
    84	                desc = f"主清单={diff['主清单']}, 实际={diff['实际检测']}, 差值={diff['差值']}"
    85	            elif 'history' in diff:
    86	                desc = f"历史={diff['history']}, 当前={diff['current']}, 差异={diff['diff']}"
    87	            else:
    88	                desc = str(diff)
    89	            table.add_row(r.main_record.id, field, desc)
    90	            count += 1
    91	    if len(diff_records) > limit:
    92	        table.add_row("...", "", f"(共 {count} 项差异)")
