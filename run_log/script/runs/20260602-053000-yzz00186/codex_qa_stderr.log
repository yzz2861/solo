import os
import sys
import json
from datetime import datetime
from pathlib import Path

import click
from rich.console import Console
from rich.table import Table
from rich.panel import Panel

from .reader import DataReader
from .validator import ValidationEngine
from .grader import TeaGrader
from .exporter import ResultExporter
from .models import GradeLevel, ProcessingResult

console = Console()


def _print_summary(result: ProcessingResult, dry_run: bool):
    mode = "[yellow]DRY-RUN[/yellow] " if dry_run else ""
    console.print(Panel(
        f"{mode}处理完成",
        style="bold green" if result.bad_count == 0 else "bold yellow"
    ))

    table = Table(title=f"{mode}处理汇总", show_header=True, header_style="bold cyan")
    table.add_column("指标", style="dim")
    table.add_column("值", justify="right")
    table.add_row("总记录数", str(result.success_count + result.bad_count))
    table.add_row("成功记录数", str(result.success_count), style="green")
    table.add_row("坏行记录数", str(result.bad_count), style="red" if result.bad_count > 0 else "green")
    table.add_row("总结算金额(元)", f"{result.total_amount:,.2f}")
    console.print(table)

    if result.graded_records or result.bad_records:
        grade_dist = {}
        for r in result.graded_records:
            grade_dist[r.final_grade.value] = grade_dist.get(r.final_grade.value, 0) + 1
        for r in result.bad_records:
            grade_dist[r.final_grade.value] = grade_dist.get(r.final_grade.value, 0) + 1

        gt = Table(title="等级分布", show_header=True, header_style="bold cyan")
        gt.add_column("等级")
        gt.add_column("数量", justify="right")
        for grade in GradeLevel:
            cnt = grade_dist.get(grade.value, 0)
            if cnt:
                style = "red" if grade == GradeLevel.REJECT else None
                gt.add_row(grade.value, str(cnt), style=style)
        console.print(gt)


def _print_bad_rows_preview(result: ProcessingResult, limit: int = 10):
    if not result.bad_records:
        return
    table = Table(title="坏行预览", show_header=True, header_style="bold red")
    table.add_column("记录编号")
    table.add_column("供应商")
    table.add_column("坏行原因")
    for r in result.bad_records[:limit]:
        table.add_row(r.main_record.id, r.main_record.supplier_name, r.bad_reason or "")
    if len(result.bad_records) > limit:
        table.add_row("...", f"(共 {len(result.bad_records)} 条)", "")
    console.print(table)


def _print_diff_preview(result: ProcessingResult, limit: int = 10):
    all_records = result.graded_records + result.bad_records
    diff_records = [r for r in all_records if r.diff_fields]
    if not diff_records:
        return
    table = Table(title="差异预览", show_header=True, header_style="bold yellow")
    table.add_column("记录编号")
    table.add_column("差异字段")
    table.add_column("说明")
    count = 0
    for r in diff_records:
        for field, diff in r.diff_fields.items():
            if count >= limit:
                break
            if '主清单' in diff:
                desc = f"主清单={diff['主清单']}, 实际={diff['实际检测']}, 差值={diff['差值']}"
            elif 'history' in diff:
                desc = f"历史={diff['history']}, 当前={diff['current']}, 差异={diff['diff']}"
            else:
                desc = str(diff)
            table.add_row(r.main_record.id, field, desc)
            count += 1
    if len(diff_records) > limit:
        table.add_row("...", "", f"(共 {count} 项差异)")
    console.print(table)


@click.group()
@click.version_option(version="1.0.0", prog_name="tea-grading")
def cli():
    """茶叶鲜叶收购定级CLI工具"""
    pass


@cli.command()
@click.option('--main', 'main_file', required=True, help='主清单文件路径 (CSV/XLSX/JSON)')
@click.option('--supplement', 'supplement_file', required=True, help='补充表文件路径 (CSV/XLSX/JSON)')
@click.option('--rules', 'rules_file', required=True, help='校验规则文件路径 (JSON)')
@click.option('--criteria', 'criteria_file', required=True, help='定级标准文件路径 (JSON)')
@click.option('--output-dir', 'output_dir', default='./output', help='输出目录 (默认: ./output)')
@click.option('--dry-run', is_flag=True, default=False, help='仅预览，不输出正式结果文件')
@click.option('--history', 'history_file', default=None, help='历史记录文件路径 (用于历史回放比对)')
@click.option('--use-actual/--no-use-actual', default=True, help='是否使用补充表实际检测值定级 (默认: 使用)')
@click.option('--strict', is_flag=True, default=False, help='严格模式：缺少补充记录的行标记为坏行')
def run(main_file, supplement_file, rules_file, criteria_file, output_dir,
        dry_run, history_file, use_actual, strict):
    """执行茶叶鲜叶收购定级全流程"""

    console.print(Panel("茶叶鲜叶收购定级", style="bold cyan"))

    validation_engine_for_params = ValidationEngine([])
    param_errors = validation_engine_for_params.validate_parameters(
        main_file, supplement_file, rules_file, output_dir if not dry_run else output_dir
    )
    if not os.path.exists(criteria_file):
        param_errors.append(f"定级标准文件不存在: {criteria_file}")
    if param_errors:
        for err in param_errors:
            console.print(f"[red]参数错误: {err}[/red]")
        sys.exit(1)

    console.print(f"[dim]主清单: {main_file}[/dim]")
    console.print(f"[dim]补充表: {supplement_file}[/dim]")
    console.print(f"[dim]校验规则: {rules_file}[/dim]")
    console.print(f"[dim]定级标准: {criteria_file}[/dim]")
    if history_file:
        console.print(f"[dim]历史记录: {history_file}[/dim]")
    if dry_run:
        console.print("[yellow]DRY-RUN 模式: 仅预览，不输出正式结果[/yellow]")

    main_records, bad_rows = DataReader.read_main_list(main_file)
    supplements = DataReader.read_supplement(supplement_file)
    rules = DataReader.read_validation_rules(rules_file)
    criteria = DataReader.read_grading_criteria(criteria_file)

    history_data = {}
    if history_file:
        history_data = DataReader.read_history_record(history_file)

    validation_engine = ValidationEngine(rules)
    validation_results = {}
    seen_ids = set()

    for main in main_records:
        if strict and main.id not in supplements:
            validation_results[main.id] = (
                False,
                "严格模式: 缺少补充记录",
                {}
            )
            seen_ids.add(main.id)
            continue

        is_valid, error_msg, hist_diff = validation_engine.validate_main_record(
            main, supplements, seen_ids, history_data
        )
        validation_results[main.id] = (is_valid, error_msg, hist_diff)
        seen_ids.add(main.id)

    grader = TeaGrader(criteria, use_actual_values=use_actual)
    result = grader.grade_records(
        main_records, supplements, validation_results,
        initial_bad_rows=bad_rows
    )

    _print_summary(result, dry_run)
    _print_bad_rows_preview(result)
    _print_diff_preview(result)

    if result.bad_records:
        console.print("\n[bold yellow]坏行记录可使用以下命令复核:[/bold yellow]")
        for r in result.bad_records[:5]:
            console.print(f"  tea-grading review --record-id {r.main_record.id} --output-dir {output_dir}")

    exporter = ResultExporter(output_dir, dry_run=dry_run)
    exported_files = exporter.export_all(result)

    if not dry_run:
        for r in result.bad_records:
            exporter.generate_review_link(r.main_record.id)

    console.print("\n[bold green]处理完成[/bold green]")
    if not dry_run:
        console.print("[dim]导出文件:[/dim]")
        for name, path in exported_files.items():
            console.print(f"  [dim]{name}: {path}[/dim]")

    return result


@cli.command()
@click.option('--record-id', 'record_id', required=True, help='待复核的记录编号')
@click.option('--output-dir', 'output_dir', default='./output', help='输出目录')
def review(record_id, output_dir):
    """复核坏行记录"""

    review_files = list(Path(output_dir).glob(f'review_{record_id}_*.json'))

    if not review_files:
        console.print(f"[red]未找到记录 {record_id} 的复核信息[/red]")
        console.print("[dim]请先运行 tea-grading run 生成复核文件[/dim]")
        sys.exit(1)

    latest_review = sorted(review_files)[-1]
    with open(latest_review, 'r', encoding='utf-8') as f:
        review_data = json.load(f)

    console.print(Panel(f"复核记录: {record_id}", style="bold cyan"))

    table = Table(show_header=True, header_style="bold cyan")
    table.add_column("字段")
    table.add_column("值")
    for key, value in review_data.items():
        if key == '相关文件':
            value = '\n'.join(f"  {k}: {v}" for k, v in value.items())
        table.add_row(key, str(value))
    console.print(table)

    bad_file = Path(output_dir) / f"坏行记录_*.csv"
    bad_files = list(Path(output_dir).glob(f"坏行记录_*.csv"))
    if bad_files:
        console.print(f"\n[bold]坏行记录文件:[/bold]")
        for bf in bad_files:
            console.print(f"  {bf}")

    return review_data


@cli.command()
@click.option('--output-dir', 'output_dir', default='./output', help='输出目录')
def history_check(output_dir):
    """检查历史回放差异"""

    diff_files = list(Path(output_dir).glob('差异表_*.csv'))
    if not diff_files:
        console.print("[yellow]未找到差异表文件[/yellow]")
        return

    import pandas as pd
    latest_diff = sorted(diff_files)[-1]
    df = pd.read_csv(latest_diff)

    console.print(Panel("历史差异检查", style="bold cyan"))
    console.print(f"[dim]差异表: {latest_diff}[/dim]")
    console.print(f"[dim]共 {len(df)} 条差异记录[/dim]")

    if len(df) > 0:
        table = Table(show_header=True, header_style="bold yellow")
        for col in df.columns:
            table.add_column(col)
        for _, row in df.head(20).iterrows():
            table.add_row(*[str(v) for v in row.values])

