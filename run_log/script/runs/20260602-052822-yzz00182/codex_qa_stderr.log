            export_files.append(history_file)
            logger.info(f"已导出历史轨迹: {history_file}")
        
        if self.history_trace:
            self.history_trace[-1]['export_files'] = export_files
            self._save_history()
        
        return export_files
    
    def print_report(self):
        print("\n" + "="*80)
        print("高铁动车组保洁交路关键记录审计报告")
        print("="*80)
        
        print(f"\n【审计概览】")
        print(f"  总记录数: {self.statistics['summary']['total_records']}")
        print(f"  时间窗口: {self.statistics['summary']['time_window']}")
        print(f"  审计时间: {self.statistics['summary']['audit_time']}")
        
        print(f"\n【风险分布】")
        for level in RISK_LEVELS:
            count = self.statistics['risk_distribution']['counts'].get(level, 0)
            pct = self.statistics['risk_distribution']['percentages'].get(level, '0.00%')
            bar = '█' * int(count / max(1, self.statistics['summary']['total_records']) * 50)
            print(f"  {level}: {count:5d} ({pct:7s}) {bar}")
        
        print(f"\n【阈值配置】")
        for level, threshold in self.statistics['thresholds'].items():
            print(f"  {level}: 风险得分 >= {threshold}")
        
        print(f"\n【状态分布】")
        for status, count in self.statistics['status_distribution'].items():
            print(f"  {status}: {count}")
        
        if self.statistics['group_statistics']:
            print(f"\n【分组统计】")
            for group_col, group_data in self.statistics['group_statistics'].items():
                print(f"\n  按 {group_col}:")
                for name, data in list(group_data.items())[:5]:
                    print(f"    {name}: 总{data['total']}, 高{data['高风险']}, 中{data['中风险']}, 低{data['低风险']}")
                if len(group_data) > 5:
                    print(f"    ... 还有 {len(group_data) - 5} 个分组")
        
        if self.statistics['problem_matches']:
            print(f"\n【高频问题】")
            for problem, count in list(self.statistics['problem_matches'].items())[:5]:
                print(f"  {problem}: {count} 次")
        
        if self.trend_summary.get('analysis'):
            print(f"\n【趋势分析】")
            print(f"  {self.trend_summary['analysis']}")
        
        print(f"\n【异常样本统计】")
        print(f"  高风险样本: {len(self.anomaly_samples.get('high_risk_samples', []))} 条")
        print(f"  中风险样本: {len(self.anomaly_samples.get('medium_risk_samples', []))} 条")
        print(f"  无法判定: {len(self.anomaly_samples.get('undetermined_samples', []))} 条")
        
        if self.anomaly_samples.get('high_risk_samples'):
            print(f"\n【高风险示例】")
            sample = self.anomaly_samples['high_risk_samples'][0]
            print(f"  记录ID: {sample['record_id']}")
            print(f"  风险等级: {sample['risk_level']}")
            print(f"  状态: {sample['status']}")
            print(f"  原因: {sample['reason'][:100]}..." if len(sample['reason']) > 100 else f"  原因: {sample['reason']}")
            print(f"  阈值解释: {sample['threshold_explanation']}")
        
        print(f"\n【历史轨迹】")
        print(f"  累计审计次数: {len(self.history_trace)}")
        if self.history_trace:
            recent = self.history_trace[-1]
            print(f"  本次审计ID: {recent['audit_id']}")
            print(f"  本次时间: {recent['audit_time']}")
        
        print("\n" + "="*80)
        print("审计完成")
        print("="*80 + "\n")


def main():
    parser = argparse.ArgumentParser(description='高铁动车组保洁交路关键记录审计系统')
    parser.add_argument('--records', required=True, help='业务记录文件路径 (.xlsx/.csv/.json)')
    parser.add_argument('--problems', required=True, help='问题字典文件路径 (.xlsx/.csv/.json)')
    parser.add_argument('--template', help='报表模板文件路径 (可选)')
    parser.add_argument('--config', help='配置文件路径 (可选)')
    parser.add_argument('--output', default='output', help='输出目录 (默认: output)')
    parser.add_argument('--no-report', action='store_true', help='不打印报告')
    
    args = parser.parse_args()
    
    try:
        auditor = CleaningRouteAuditor(args.config)
        auditor.load_data(args.records, args.problems, args.template)
        auditor.run_audit()
        export_files = auditor.export_results(args.output)
        
        if not args.no_report:
            auditor.print_report()
        
        print(f"\n导出文件列表:")
        for f in export_files:
            print(f"  - {f}")
        
        return 0
        
    except Exception as e:
        logger.error(f"审计执行失败: {e}", exc_info=True)
        return 1


if __name__ == '__main__':
    sys.exit(main())

