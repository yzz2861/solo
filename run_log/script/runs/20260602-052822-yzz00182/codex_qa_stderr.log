 succeeded in 0ms:
        for _, record in records.iterrows():
            result = self._judge_single_record(record, problem_rules)
            self.audit_results.append(result)
        
        self._ensure_consistency()
    
    def _build_problem_rules(self):
        rules = defaultdict(list)
        
        for _, problem in self.problem_dict.iterrows():
            problem_type = str(problem['问题类型']).strip()
            rules[problem_type].append({
                'problem_type': problem_type,
                'description': str(problem['问题描述']),
                'risk_level': str(problem['风险等级']),
                'judge_rule': str(problem['判定规则']),
                'threshold': problem.get('阈值', 0.5)
            })
        
        return rules
    
    def _judge_single_record(self, record, problem_rules):
        matched_problems = []
        risk_scores = []
        reasons = []
        
        for problem_type, rules in problem_rules.items():
            for rule in rules:
                is_match, match_detail = self._apply_rule(record, rule)
                if is_match:
                    matched_problems.append(rule)
                    risk_scores.append(self._risk_to_score(rule['risk_level']))
                    reasons.append(f"{rule['problem_type']}: {rule['description']} - {match_detail}")
        
        if not matched_problems:
            final_risk = '低风险'
            reason = '未匹配到问题规则，记录正常'
            status = '通过'
        else:
            max_score = max(risk_scores)
            final_risk = self._score_to_risk(max_score)
            
            if final_risk == '高风险':
                status = '不通过'
            elif final_risk == '中风险':
                status = '待复核'
            else:
                status = '通过'
            
            reason = '; '.join(reasons)
        
        record_dict = record.to_dict()
        record_dict = {k: (v if pd.notna(v) else '') for k, v in record_dict.items()}
        
        return {
            'record_id': record.get('_record_id', ''),
            'record_data': record_dict,
            'matched_problems': [p['description'] for p in matched_problems],
            'risk_level': final_risk,
            'risk_score': max(risk_scores) if risk_scores else 0.0,
            'status': status,
            'reason': reason,
            'judge_time': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
            'time_window': f"{self.time_window_start.strftime('%Y-%m-%d')} ~ {self.time_window_end.strftime('%Y-%m-%d')}",
            'threshold_explanation': self._explain_threshold(final_risk, max(risk_scores) if risk_scores else 0.0)
        }
    
    def _apply_rule(self, record, rule):
        judge_rule = rule['judge_rule']
        is_match = False
        detail = ""
        
        try:
            if '>' in judge_rule:
                col, val = judge_rule.split('>', 1)
                col = col.strip()
                val = float(val.strip())
                if col in record and pd.notna(record[col]):
                    record_val = float(record[col])
                    is_match = record_val > val
                    detail = f"{col}={record_val} > 阈值{val}"
            elif '<' in judge_rule:
                col, val = judge_rule.split('<', 1)
                col = col.strip()
                val = float(val.strip())
                if col in record and pd.notna(record[col]):
                    record_val = float(record[col])
                    is_match = record_val < val
                    detail = f"{col}={record_val} < 阈值{val}"
            elif '=' in judge_rule:
                col, val = judge_rule.split('=', 1)
                col = col.strip()
                val = val.strip().strip("'\"")
                if col in record and pd.notna(record[col]):
                    record_val = str(record[col]).strip()
                    is_match = record_val == val
                    detail = f"{col}='{record_val}' == 期望值'{val}'"
            elif '包含' in judge_rule:
                col, val = judge_rule.split('包含', 1)
                col = col.strip()
                val = val.strip().strip("'\"")
                if col in record and pd.notna(record[col]):
                    record_val = str(record[col])
                    is_match = val in record_val
                    detail = f"{col}包含'{val}'"
            elif '不包含' in judge_rule:
                col, val = judge_rule.split('不包含', 1)
                col = col.strip()
                val = val.strip().strip("'\"")
                if col in record and pd.notna(record[col]):
                    record_val = str(record[col])
                    is_match = val not in record_val
                    detail = f"{col}不包含'{val}'"
        except Exception as e:
            logger.warning(f"规则应用失败 {judge_rule}: {e}")
            is_match = False
        
        return is_match, detail
    
    def _risk_to_score(self, risk_level):
        thresholds = self.config['risk_thresholds']
        mapping = {
            '低风险': thresholds['低风险'] + 0.05,
            '中风险': (thresholds['中风险'] + thresholds['高风险']) / 2,
            '高风险': thresholds['高风险'] + 0.05,
            '无法判定': 0.0
        }
        return mapping.get(risk_level, 0.0)
    
    def _score_to_risk(self, score):
        thresholds = self.config['risk_thresholds']
        if score >= thresholds['高风险']:
            return '高风险'
        elif score >= thresholds['中风险']:
            return '中风险'
        elif score >= thresholds['低风险']:
            return '低风险'
        else:
            return '无法判定'
    
    def _explain_threshold(self, risk_level, score):
        thresholds = self.config['risk_thresholds']
        explanations = {
            '高风险': f"风险得分 {score:.2f} >= {thresholds['高风险']}，判定为高风险",
            '中风险': f"{thresholds['中风险']} <= 风险得分 {score:.2f} < {thresholds['高风险']}，判定为中风险",
            '低风险': f"{thresholds['低风险']} <= 风险得分 {score:.2f} < {thresholds['中风险']}，判定为低风险",
            '无法判定': f"风险得分 {score:.2f} < {thresholds['低风险']}，无法判定"
        }
        return explanations.get(risk_level, f"风险得分 {score:.2f}")
    
    def _ensure_consistency(self):
        valid_risk_count = sum(1 for r in self.audit_results if r['risk_level'] in RISK_LEVELS)
        if valid_risk_count != len(self.audit_results):
            invalid_count = len(self.audit_results) - valid_risk_count
            logger.warning(f"发现 {invalid_count} 条无效风险等级，已修正为'无法判定'")
            
            for result in self.audit_results:
                if result['risk_level'] not in RISK_LEVELS:
                    result['risk_level'] = '无法判定'
                    result['status'] = '待复核'
                    result['reason'] = result['reason'] + ' [风险等级修正：原状态无效]'
        
        for result in self.audit_results:
            if result['risk_level'] == '高风险' and result['status'] != '不通过':
                result['status'] = '不通过'
                result['reason'] = result['reason'] + ' [状态修正：高风险自动标记为不通过]'
    
    def _generate_statistics(self):
        total = len(self.audit_results)
        
        risk_counts = Counter(r['risk_level'] for r in self.audit_results)
        status_counts = Counter(r['status'] for r in self.audit_results)
        
        risk_percentages = {
            level: f"{risk_counts.get(level, 0) / total * 100:.2f}%" if total > 0 else "0.00%"
            for level in RISK_LEVELS
        }
        
        group_stats = {}
        for group_col in self.config.get('group_columns', []):
            group_data = defaultdict(lambda: {'total': 0, '高风险': 0, '中风险': 0, '低风险': 0, '无法判定': 0})
            for result in self.audit_results:
                group_val = result['record_data'].get(group_col, '未知')
                group_data[group_val]['total'] += 1
                group_data[group_val][result['risk_level']] += 1
            
            group_stats[group_col] = dict(group_data)
        
        problem_matches = Counter()
        for result in self.audit_results:
            for problem in result['matched_problems']:
                problem_matches[problem] += 1
        
        self.statistics = {
            'summary': {
                'total_records': total,
                'time_window': f"{self.time_window_start.strftime('%Y-%m-%d')} ~ {self.time_window_end.strftime('%Y-%m-%d')}",
                'audit_time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')
            },
            'risk_distribution': {
                'counts': dict(risk_counts),
                'percentages': risk_percentages
            },
            'status_distribution': dict(status_counts),
            'group_statistics': group_stats,
            'problem_matches': dict(problem_matches.most_common(10)),
            'thresholds': self.config['risk_thresholds']
        }
        
        logger.info(f"统计完成 - 总记录:{total}, "
                   f"高风险:{risk_counts.get('高风险', 0)}, "
                   f"中风险:{risk_counts.get('中风险', 0)}, "
                   f"低风险:{risk_counts.get('低风险', 0)}, "
                   f"无法判定:{risk_counts.get('无法判定', 0)}")
    
    def _extract_anomaly_samples(self):
        high_risk = [r for r in self.audit_results if r['risk_level'] == '高风险']
        medium_risk = [r for r in self.audit_results if r['risk_level'] == '中风险']
        undetermined = [r for r in self.audit_results if r['risk_level'] == '无法判定']
        
        sample_size = self.config.get('anomaly_sample_size', 20)
        
        self.anomaly_samples = {
            'high_risk_samples': high_risk[:sample_size],
            'medium_risk_samples': medium_risk[:sample_size],
            'undetermined_samples': undetermined[:sample_size]
        }
        
        logger.info(f"提取异常样本 - 高风险:{len(high_risk)}, 中风险:{len(medium_risk)}, 无法判定:{len(undetermined)}")
    
    def _generate_trend_summary(self):
