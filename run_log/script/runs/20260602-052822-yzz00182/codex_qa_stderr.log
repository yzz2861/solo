   206	    def _deduplicate(self, records):
   207	        records['_record_id'] = records.apply(self._generate_record_id, axis=1)
   208	        duplicate_count = records.duplicated(subset=['_record_id']).sum()
   209	        
   210	        if duplicate_count > 0:
   211	            logger.info(f"去重 - 发现重复记录: {duplicate_count} 条")
   212	            logger.info(f"去重键: {', '.join(self.dedup_keys)}")
   213	        
   214	        deduplicated = records.drop_duplicates(subset=['_record_id'], keep='first').copy()
   215	        return deduplicated
