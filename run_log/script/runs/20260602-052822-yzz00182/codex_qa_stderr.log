   201	        logger.info(f"准入解释: 时间窗口 {self.time_window_start.strftime('%Y-%m-%d')} ~ {self.time_window_end.strftime('%Y-%m-%d')}, "
   202	                   f"分组维度 {', '.join(self.config.get('group_columns', []))}")
   203	        
   204	        return filtered
