#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
高铁动车组保洁交路关键记录审计脚本

功能：
1. 准入判断 - 根据时间窗口、分组维度对业务记录进行筛选
2. 差异提示 - 对比业务记录与问题字典，标记异常
3. 结果归档 - 按风险等级分类，生成统计报告和导出文件

风险等级：低风险、中风险、高风险、无法判定
"""

import os
import sys
import json
import hashlib
import logging
import argparse
from datetime import datetime, timedelta
from collections import defaultdict, Counter
from pathlib import Path

import pandas as pd
import numpy as np

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[
        logging.StreamHandler(sys.stdout),
        logging.FileHandler('audit_log.log', encoding='utf-8')
    ]
)
logger = logging.getLogger(__name__)

RISK_LEVELS = ['低风险', '中风险', '高风险', '无法判定']


class CleaningRouteAuditor:
    def __init__(self, config_path=None):
        self.config = self._load_default_config()
        if config_path and os.path.exists(config_path):
            self._load_config(config_path)
        
        self.business_records = None
        self.problem_dict = None
        self.report_template = None
        self.dedup_keys = []
        
        self.time_window_start = None
        self.time_window_end = None
        
        self.audit_results = []
        self.statistics = {}
        self.anomaly_samples = []
        self.trend_summary = {}
        self.history_trace = []
    
    def _load_default_config(self):
        return {
            'time_column': '记录时间',
            'group_columns': ['车次号', '车组号', '保洁班组'],
            'risk_thresholds': {
                '低风险': 0.3,
                '中风险': 0.6,
                '高风险': 0.9
            },
            'time_window_days': 7,
            'dedup_keys': ['车次号', '车组号', '保洁日期', '作业类型'],
            'export_formats': ['xlsx', 'csv', 'json'],
            'history_file': 'audit_history.json',
            'anomaly_sample_size': 20
        }
    
    def _load_config(self, config_path):
        try:
            with open(config_path, 'r', encoding='utf-8') as f:
                user_config = json.load(f)
                self.config.update(user_config)
            logger.info(f"已加载配置文件: {config_path}")
        except Exception as e:
            logger.warning(f"加载配置文件失败，使用默认配置: {e}")
    
    def load_data(self, records_path, problem_dict_path, template_path=None):
        logger.info("开始加载数据...")
        
        self.business_records = self._read_file(records_path)
        logger.info(f"加载业务记录: {len(self.business_records)} 条")
        
        self.problem_dict = self._read_file(problem_dict_path)
        logger.info(f"加载问题字典: {len(self.problem_dict)} 条")
        
        if template_path and os.path.exists(template_path):
            self.report_template = self._read_file(template_path)
            logger.info(f"加载报表模板: {len(self.report_template)} 条")
        
        self.dedup_keys = self.config.get('dedup_keys', [])
        self._validate_columns()
        self._set_time_window()
        self._load_history()
    
    def _read_file(self, file_path):
        if not os.path.exists(file_path):
            raise FileNotFoundError(f"文件不存在: {file_path}")
        
        ext = os.path.splitext(file_path)[1].lower()
        
        if ext in ['.xlsx', '.xls']:
            return pd.read_excel(file_path)
        elif ext == '.csv':
            return pd.read_csv(file_path, encoding='utf-8')
        elif ext == '.json':
            return pd.read_json(file_path)
        else:
            raise ValueError(f"不支持的文件格式: {ext}")
    
    def _validate_columns(self):
        required_cols = [self.config['time_column']] + self.dedup_keys
        
        for col in required_cols:
            if col not in self.business_records.columns:
                raise ValueError(f"业务记录缺少必要列: {col}")
        
        problem_required = ['问题类型', '问题描述', '风险等级', '判定规则']
        for col in problem_required:
            if col not in self.problem_dict.columns:
                raise ValueError(f"问题字典缺少必要列: {col}")
        
        self.business_records[self.config['time_column']] = pd.to_datetime(
            self.business_records[self.config['time_column']]
        )
    
    def _set_time_window(self):
        time_col = self.config['time_column']
        days = self.config.get('time_window_days', 7)
        
        max_time = self.business_records[time_col].max()
        self.time_window_end = max_time
        self.time_window_start = max_time - timedelta(days=days)
        
        logger.info(f"时间窗口: {self.time_window_start.strftime('%Y-%m-%d')} 至 {self.time_window_end.strftime('%Y-%m-%d')}")
    
    def _load_history(self):
        history_file = self.config.get('history_file', 'audit_history.json')
        if os.path.exists(history_file):
            try:
                with open(history_file, 'r', encoding='utf-8') as f:
                    self.history_trace = json.load(f)
                logger.info(f"加载历史审计轨迹: {len(self.history_trace)} 条")
            except Exception as e:
                logger.warning(f"加载历史轨迹失败: {e}")
                self.history_trace = []
    
    def _save_history(self):
        history_file = self.config.get('history_file', 'audit_history.json')
        try:
            with open(history_file, 'w', encoding='utf-8') as f:
                json.dump(self.history_trace, f, ensure_ascii=False, indent=2)
            logger.info(f"历史轨迹已保存: {len(self.history_trace)} 条")
        except Exception as e:
            logger.error(f"保存历史轨迹失败: {e}")
    
    def _generate_record_id(self, record):
        key_parts = [str(record.get(k, '')) for k in self.dedup_keys]
        key_str = '|'.join(key_parts)
        return hashlib.md5(key_str.encode('utf-8')).hexdigest()
    
    def run_audit(self):
        logger.info("开始执行审计...")
        
        filtered_records = self._admission_filter()
        logger.info(f"准入筛选后记录: {len(filtered_records)} 条")
        
        deduplicated_records = self._deduplicate(filtered_records)
        logger.info(f"去重后记录: {len(deduplicated_records)} 条")
        
        self._judge_risk(deduplicated_records)
        self._generate_statistics()
        self._extract_anomaly_samples()
        self._generate_trend_summary()
        self._update_history_trace()
        
        logger.info("审计完成")
    
    def _admission_filter(self):
        time_col = self.config['time_column']
        
        mask = (
            (self.business_records[time_col] >= self.time_window_start) &
            (self.business_records[time_col] <= self.time_window_end)
        )
        
        filtered = self.business_records[mask].copy()
        
        for col in self.config.get('group_columns', []):
            if col in filtered.columns:
                filtered = filtered.dropna(subset=[col])
        
        logger.info(f"准入判断 - 剔除时间窗口外记录: {len(self.business_records) - len(filtered)} 条")
        logger.info(f"准入解释: 时间窗口 {self.time_window_start.strftime('%Y-%m-%d')} ~ {self.time_window_end.strftime('%Y-%m-%d')}, "
                   f"分组维度 {', '.join(self.config.get('group_columns', []))}")
        
        return filtered
    
    def _deduplicate(self, records):
        records['_record_id'] = records.apply(self._generate_record_id, axis=1)
        duplicate_count = records.duplicated(subset=['_record_id']).sum()
        
        if duplicate_count > 0:
            logger.info(f"去重 - 发现重复记录: {duplicate_count} 条")
            logger.info(f"去重键: {', '.join(self.dedup_keys)}")
        
        deduplicated = records.drop_duplicates(subset=['_record_id'], keep='first').copy()
        return deduplicated
    
