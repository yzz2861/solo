/Users/bill/.codex/sessions/2026/06/02/rollout-2026-06-02T03-07-30-019e8495-7e72-7451-834a-b5aec9bf905b.jsonl:28:{"timestamp":"2026-06-01T19:09:47.802Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_ptvy5thPQTVoMefoV6cPrNYz","output":"Chunk ID: 5fc5a1\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 651\nOutput:\nfrom __future__ import annotations\n\nfrom typing import Dict, List, Optional\n\nfrom fastapi import APIRouter, HTTPException\nfrom pydantic import BaseModel, Field\n\nfrom app.engine.calculator import AllowanceEngine\nfrom app.models.object import CalculateRequest, TeacherObject, TimeWindow\nfrom app.models.record import CalculateResult\nfrom app.models.rule import RuleAction\nfrom app.models.state import TaskStatus\n\nrouter = APIRouter(prefix=\"/api/v1/allowance\", tags=[\"课时津贴核算\"])\n\nengine = AllowanceEngine()\n\n\nclass ReviewRequest(BaseModel):\n    business_id: str = Field(..., description=\"业务编号\")\n    approved: bool = Field(..., description=\"是否通过复核\")\n    operator: str = Field(..., description=\"复核操作人\")\n    reason: str = Field(default=\"\", description=\"复核原因说明\")\n\n\nclass BatchCalculateRequest(BaseModel):\n    requests: List[CalculateRequest] = Field(..., description=\"批量核算请求列表\")\n\n\nclass ReplayResponse(BaseModel):\n    business_id: str\n    audit_records: List[Dict] = Field(default_factory=list)\n    state_transitions: List[Dict] = Field(default_factory=list)\n\n\n@router.post(\"/calculate\", response_model=CalculateResult)\ndef calculate_allowance(request: CalculateRequest):\n    result = engine.calculate(request)\n    return result\n\n\n@router.post(\"/batch-calculate\", response_model=List[CalculateResult])\ndef batch_calculate(request: BatchCalculateRequest):\n    results = engine.batch_calculate(request.requests)\n    return results\n\n\n@router.post(\"/review\", response_model=CalculateResult)\ndef review_task(request: ReviewRequest):\n    result = engine.review(\n        business_id=request.business_id,\n        approved=request.approved,\n        operator=request.operator,\n        reason=request.reason,\n    )\n    return result\n\n\n@router.get(\"/replay/{business_id}\", response_model=List[Dict])\ndef replay_business(business_id: str):\n    data = engine.replay(business_id)\n    if not data:\n        raise HTTPException(status_code=404, detail=f\"未找到业务编号 {business_id} 的记录\")\n    return data\n\n\n@router.get(\"/status/{business_id}\")\ndef get_task_status(business_id: str):\n    state = engine.get_state(business_id)\n    if not state:\n        raise HTTPException(status_code=404, detail=f\"未找到业务编号 {business_id} 的状态\")\n    result = engine.store.get_result(business_id)\n    return {\n        \"business_id\": business_id,\n        \"current_status\": state.current_status.value,\n        \"is_terminal\": state.is_terminal(),\n        \"transitions\": state.replay(),\n        \"result\": result.model_dump() if result else None,\n    }\n"}}
/Users/bill/.codex/sessions/2026/06/02/rollout-2026-06-02T03-07-30-019e8495-7e72-7451-834a-b5aec9bf905b.jsonl:29:{"timestamp":"2026-06-01T19:09:47.802Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_5bo2V7N8URVRZqNO0f5N2cMP","output":"Chunk ID: bb7f71\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 2288\nOutput:\nfrom __future__ import annotations\n\nfrom typing import Dict, List, Optional, Tuple\n\nfrom app.models.object import CalculateRequest, TeacherObject, TeacherStatus, CourseType\nfrom app.models.record import (\n    AuditRecord,\n    CalculateResult,\n    RecordStore,\n    RuleHitDetail,\n)\nfrom app.models.rule import (\n    RuleAction,\n    RuleDefinition,\n    RiskLevel,\n    calculate_allowance,\n    get_rules,\n)\nfrom app.models.state import (\n    InvalidTransitionError,\n    TaskState,\n    TaskStatus,\n)\n\n\nclass AllowanceEngine:\n    def __init__(self, store: Optional[RecordStore] = None) -> None:\n        self.store = store or RecordStore()\n        self._states: Dict[str, TaskState] = {}\n\n    def _get_state(self, business_id: str) -> TaskState:\n        if business_id not in self._states:\n            self._states[business_id] = TaskState(business_id=business_id)\n        return self._states[business_id]\n\n    def _evaluate_condition(self, teacher: TeacherObject, condition) -> bool:\n        field = condition.field\n        op = condition.operator\n        val = condition.value\n\n        actual = getattr(teacher, field, None)\n        if actual is None:\n            return False\n\n        if isinstance(actual, bool):\n            actual_str = str(actual).lower()\n        elif hasattr(actual, \"value\"):\n            actual_str = str(actual.value)\n        else:\n            actual_str = str(actual)\n\n        if op == \"eq\":\n            return actual_str == val\n        elif op == \"neq\":\n            return actual_str != val\n        elif op == \"gt\":\n            try:\n                return float(actual_str) > float(val)\n            except (ValueError, TypeError):\n                return False\n        elif op == \"lt\":\n            try:\n                return float(actual_str) < float(val)\n            except (ValueError, TypeError):\n                return False\n        elif op == \"in\":\n            return actual_str in val.split(\",\")\n        elif op == \"not_in\":\n            return actual_str not in val.split(\",\")\n        return False\n\n    def _evaluate_rules(\n        self, teacher: TeacherObject, rules: List[RuleDefinition]\n    ) -> Tuple[RuleAction, List[RuleHitDetail], List[str]]:\n        hits: List[RuleHitDetail] = []\n        risk_flags: List[str] = []\n\n        sorted_rules = sorted(\n            [r for r in rules if r.enabled], key=lambda r: -r.priority\n        )\n\n        for rule in sorted_rules:\n            all_match = all(\n                self._evaluate_condition(teacher, c) for c in rule.conditions\n            )\n            if all_match and rule.conditions:\n                hits.append(\n                    RuleHitDetail(\n                        rule_id=rule.rule_id,\n                        rule_name=rule.name,\n                        risk_level=rule.risk_level,\n                        action=rule.action,\n                        reason=rule.description,\n                    )\n                )\n                risk_flags.append(f\"{rule.rule_id}:{rule.risk_level.value}\")\n\n        if not hits:\n            return RuleAction.PASS, hits, risk_flags\n\n        has_block = any(h.action == RuleAction.BLOCK for h in hits)\n        has_pending = any(h.action == RuleAction.PENDING_REVIEW for h in hits)\n\n        if has_block:\n            return RuleAction.BLOCK, hits, risk_flags\n        if has_pending:\n            return RuleAction.PENDING_REVIEW, hits, risk_flags\n\n        return RuleAction.PASS, hits, risk_flags\n\n    def _build_reason(\n        self,\n        action: RuleAction,\n        hits: List[RuleHitDetail],\n        teacher: TeacherObject,\n        amount: float,\n    ) -> str:\n        if action == RuleAction.PASS and not hits:\n            return (\n                f\"教师{teacher.name}({teacher.teacher_id})核算通过，\"\n                f\"课时{teacher.course_hours}，津贴{amount}元\"\n            )\n        if action == RuleAction.BLOCK:\n            reasons = \"；\".join(h.reason for h in hits if h.action == RuleAction.BLOCK)\n            return f\"核算拦截：{reasons}\"\n        if action == RuleAction.PENDING_REVIEW:\n            reasons = \"；\".join(\n                h.reason for h in hits if h.action == RuleAction.PENDING_REVIEW\n            )\n            return f\"待人工复核：{reasons}\"\n        return \"核算通过\"\n\n    def calculate(self, request: CalculateRequest) -> CalculateResult:\n        state = self._get_state(request.business_id)\n\n        if state.current_status not in (\n            TaskStatus.SUBMITTED,\n            TaskStatus.BLOCKED,\n            TaskStatus.REVIEW_REJECTED,\n        ):\n            return CalculateResult(\n                business_id=request.business_id,\n                teacher_id=request.teacher.teacher_id,\n                final_action=RuleAction.BLOCK,\n                task_status=state.current_status,\n                readable_reason=f\"任务状态为{state.current_status.value}，不允许重复核算\",\n            )\n\n        state.transition(TaskStatus.PROCESSING, operator=request.operator)\n\n        rules = get_rules(request.rule_version)\n        action, hits, risk_flags = self._evaluate_rules(request.teacher, rules)\n\n        amount = calculate_allowance(\n            course_hours=request.teacher.course_hours,\n            course_type=request.teacher.course_type,\n            teacher_status=request.teacher.status,\n            base_rate=request.teacher.base_rate,\n        )\n\n        course_type_name = request.teacher.course_type.value\n        status_name = request.teacher.status.value\n        multiplier = {\n            CourseType.LECTURE: 1.0,\n            CourseType.LAB: 1.2,\n            CourseType.SEMINAR: 1.1,\n            CourseType.PRACTICE: 1.3,\n        }.get(request.teacher.course_type, 1.0)\n        status_factor = {\n            TeacherStatus.ACTIVE: 1.0,\n            TeacherStatus.SUSPENDED: 0.0,\n            TeacherStatus.RETIRED: 0.5,\n            TeacherStatus.ON_LEAVE: 0.3,\n        }.get(request.teacher.status, 0.0)\n\n        calc_detail = (\n            f\"课时{request.teacher.course_hours} × 基础费率{request.teacher.base_rate}元\"\n            f\" × 课程类型系数{multiplier}({course_type_name})\"\n            f\" × 状态系数{status_factor}({status_name})\"\n            f\" = {amount}元\"\n        )\n\n        readable_reason = self._build_reason(action, hits, request.teacher, amount)\n\n        if action == RuleAction.PASS and not hits:\n            state.transition(TaskStatus.PASSED, operator=request.operator)\n            task_status = TaskStatus.PASSED\n        elif action == RuleAction.BLOCK:\n            state.transition(\n                TaskStatus.BLOCKED, operator=request.operator, reason=readable_reason\n            )\n            task_status = TaskStatus.BLOCKED\n        elif action == RuleAction.PENDING_REVIEW:\n            state.transition(\n                TaskStatus.PENDING_REVIEW,\n                operator=request.operator,\n                reason=readable_reason,\n            )\n            task_status = TaskStatus.PENDING_REVIEW\n        else:\n            state.transition(TaskStatus.PASSED, operator=request.operator)\n            task_status = TaskStatus.PASSED\n\n        result = CalculateResult(\n            business_id=request.business_id,\n            teacher_id=request.teacher.teacher_id,\n            allowance_amount=amount,\n            calculation_detail=calc_detail,\n            final_action=action,\n            task_status=task_status,\n            readable_reason=readable_reason,\n            rule_hits=hits,\n            risk_flags=risk_flags,\n        )\n\n        self.store.save_result(request.business_id, result)\n\n        self.store.append_record(\n            AuditRecord(\n                record_id=f\"{request.business_id}-calc\",\n                business_id=request.business_id,\n                teacher_id=request.teacher.teacher_id,\n                operator=request.operator,\n                action=f\"calculate:{action.value}\",\n                detail=readable_reason,\n                metadata=result.model_dump(),\n            )\n        )\n\n        return result\n\n    def review(\n        self,\n        business_id: str,\n        approved: bool,\n        operator: str,\n        reason: str = \"\",\n    ) -> CalculateResult:\n        state = self._get_state(business_id)\n\n        if state.current_status != TaskStatus.PENDING_REVIEW:\n            return CalculateResult(\n                business_id=business_id,\n                teacher_id=\"\",\n                final_action=RuleAction.BLOCK,\n                task_status=state.current_status,\n                readable_reason=f\"当前状态{state.current_status.value}不可复核，仅待复核状态允许复核\",\n            )\n\n        if approved:\n            state.transition(\n                TaskStatus.REVIEW_APPROVED, operator=operator, reason=reason\n            )\n            existing = self.store.get_result(business_id)\n            task_status = TaskStatus.REVIEW_APPROVED\n            if existing:\n                existing.task_status = task_status\n                existing.final_action = RuleAction.PASS\n                existing.readable_reason = f\"复核通过：{reason}\" if reason else \"复核通过\"\n                self.store.save_result(business_id, existing)\n"}}
/Users/bill/.codex/sessions/2026/06/02/rollout-2026-06-02T03-07-30-019e8495-7e72-7451-834a-b5aec9bf905b.jsonl:30:{"timestamp":"2026-06-01T19:09:47.802Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_5zsHfaFJ9dOAcgpeg9CZ3osv","output":"Chunk ID: c918b6\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 2426\nOutput:\nfrom __future__ import annotations\n\nimport pytest\n\nfrom app.engine.calculator import AllowanceEngine\nfrom app.models.object import CalculateRequest, CourseType, TeacherObject, TeacherStatus, TimeWindow\nfrom app.models.record import RecordStore\nfrom app.models.rule import RuleAction, calculate_allowance\nfrom app.models.state import InvalidTransitionError, TaskState, TaskStatus\n\n\ndef _make_teacher(\n    teacher_id: str = \"T001\",\n    name: str = \"张三\",\n    status: TeacherStatus = TeacherStatus.ACTIVE,\n    course_hours: float = 80.0,\n    course_type: CourseType = CourseType.LECTURE,\n    base_rate: float = 50.0,\n    materials_submitted: bool = True,\n) -> TeacherObject:\n    return TeacherObject(\n        teacher_id=teacher_id,\n        name=name,\n        status=status,\n        course_hours=course_hours,\n        course_type=course_type,\n        base_rate=base_rate,\n        materials_submitted=materials_submitted,\n    )\n\n\ndef _make_request(\n    business_id: str = \"BIZ001\",\n    teacher: TeacherObject | None = None,\n    rule_version: str = \"v1\",\n    operator: str = \"admin\",\n) -> CalculateRequest:\n    return CalculateRequest(\n        business_id=business_id,\n        teacher=teacher or _make_teacher(),\n        time_window=TimeWindow(start_date=\"2026-05-01\", end_date=\"2026-05-31\"),\n        rule_version=rule_version,\n        operator=operator,\n    )\n\n\nclass TestSingleSuccess:\n    def test_active_teacher_normal_hours_pass(self):\n        engine = AllowanceEngine()\n        req = _make_request(business_id=\"BIZ-S001\", teacher=_make_teacher(course_hours=80))\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.PASS\n        assert result.task_status == TaskStatus.PASSED\n        assert result.allowance_amount == 80 * 50 * 1.0 * 1.0\n        assert \"核算通过\" in result.readable_reason\n        assert \"80\" in result.calculation_detail\n        assert len(result.rule_hits) == 0\n\n    def test_lab_course_multiplier(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=60, course_type=CourseType.LAB)\n        req = _make_request(business_id=\"BIZ-S002\", teacher=teacher)\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.PASS\n        assert result.allowance_amount == 60 * 50 * 1.2 * 1.0\n\n    def test_practice_course_multiplier(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=40, course_type=CourseType.PRACTICE)\n        req = _make_request(business_id=\"BIZ-S003\", teacher=teacher)\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.PASS\n        assert result.allowance_amount == 40 * 50 * 1.3 * 1.0\n\n    def test_custom_base_rate(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=100, base_rate=80.0)\n        req = _make_request(business_id=\"BIZ-S004\", teacher=teacher)\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.PASS\n        assert result.allowance_amount == 100 * 80.0 * 1.0 * 1.0\n\n\nclass TestBatchPartialFailure:\n    def test_batch_with_mixed_results(self):\n        engine = AllowanceEngine()\n        requests = [\n            _make_request(\n                business_id=\"BIZ-B001\",\n                teacher=_make_teacher(teacher_id=\"T1\", course_hours=80),\n            ),\n            _make_request(\n                business_id=\"BIZ-B002\",\n                teacher=_make_teacher(\n                    teacher_id=\"T2\", course_hours=80, materials_submitted=False\n                ),\n            ),\n            _make_request(\n                business_id=\"BIZ-B003\",\n                teacher=_make_teacher(\n                    teacher_id=\"T3\", course_hours=210\n                ),\n            ),\n        ]\n        results = engine.batch_calculate(requests)\n\n        assert len(results) == 3\n        assert results[0].final_action == RuleAction.PASS\n        assert results[0].task_status == TaskStatus.PASSED\n\n        assert results[1].final_action == RuleAction.BLOCK\n        assert results[1].task_status == TaskStatus.BLOCKED\n        assert \"材料\" in results[1].readable_reason\n\n        assert results[2].final_action == RuleAction.PENDING_REVIEW\n        assert results[2].task_status == TaskStatus.PENDING_REVIEW\n        assert \"上限\" in results[2].readable_reason\n\n\nclass TestManualReview:\n    def test_non_active_teacher_enters_review(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(status=TeacherStatus.RETIRED, course_hours=60)\n        req = _make_request(business_id=\"BIZ-R001\", teacher=teacher)\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.PENDING_REVIEW\n        assert result.task_status == TaskStatus.PENDING_REVIEW\n        assert \"复核\" in result.readable_reason\n\n    def test_exceed_max_hours_enters_review(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=210)\n        req = _make_request(business_id=\"BIZ-R002\", teacher=teacher)\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.PENDING_REVIEW\n        assert result.task_status == TaskStatus.PENDING_REVIEW\n\n    def test_review_approved(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(status=TeacherStatus.RETIRED, course_hours=60)\n        req = _make_request(business_id=\"BIZ-R003\", teacher=teacher)\n        engine.calculate(req)\n\n        review_result = engine.review(\n            business_id=\"BIZ-R003\",\n            approved=True,\n            operator=\"reviewer1\",\n            reason=\"退休教师返聘，材料齐全\",\n        )\n\n        assert review_result.task_status == TaskStatus.REVIEW_APPROVED\n        assert review_result.final_action == RuleAction.PASS\n        assert \"复核通过\" in review_result.readable_reason\n\n    def test_review_rejected(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(status=TeacherStatus.RETIRED, course_hours=60)\n        req = _make_request(business_id=\"BIZ-R004\", teacher=teacher)\n        engine.calculate(req)\n\n        review_result = engine.review(\n            business_id=\"BIZ-R004\",\n            approved=False,\n            operator=\"reviewer1\",\n            reason=\"材料不属实\",\n        )\n\n        assert review_result.task_status == TaskStatus.REVIEW_REJECTED\n        assert review_result.final_action == RuleAction.BLOCK\n\n    def test_review_only_allowed_in_pending_review(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=80)\n        req = _make_request(business_id=\"BIZ-R005\", teacher=teacher)\n        engine.calculate(req)\n\n        review_result = engine.review(\n            business_id=\"BIZ-R005\",\n            approved=True,\n            operator=\"reviewer1\",\n            reason=\"不应到达此处\",\n        )\n\n        assert \"不可复核\" in review_result.readable_reason\n\n    def test_missing_materials_blocks_not_review(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=80, materials_submitted=False)\n        req = _make_request(business_id=\"BIZ-R006\", teacher=teacher)\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.BLOCK\n        assert result.task_status == TaskStatus.BLOCKED\n        assert \"材料\" in result.readable_reason\n\n    def test_high_risk_and_missing_materials_blocks(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(\n            course_hours=210, materials_submitted=False\n        )\n        req = _make_request(business_id=\"BIZ-R007\", teacher=teacher)\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.BLOCK\n        assert result.task_status == TaskStatus.BLOCKED\n        assert \"材料\" in result.readable_reason\n\n\nclass TestDuplicateSubmission:\n    def test_duplicate_submission_blocked(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=80)\n        req1 = _make_request(business_id=\"BIZ-D001\", teacher=teacher)\n        result1 = engine.calculate(req1)\n\n        assert result1.final_action == RuleAction.PASS\n        assert result1.task_status == TaskStatus.PASSED\n\n        result2 = engine.calculate(req1)\n        assert \"重复核算\" in result2.readable_reason\n\n    def test_resubmit_after_block(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=80, materials_submitted=False)\n        req1 = _make_request(business_id=\"BIZ-D002\", teacher=teacher)\n        result1 = engine.calculate(req1)\n\n        assert result1.task_status == TaskStatus.BLOCKED\n\n        teacher_fixed = _make_teacher(course_hours=80, materials_submitted=True)\n        req2 = _make_request(business_id=\"BIZ-D002\", teacher=teacher_fixed)\n        result2 = engine.calculate(req2)\n\n        assert result2.final_action == RuleAction.PASS\n        assert result2.task_status == TaskStatus.PASSED\n\n    def test_resubmit_after_review_rejected(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(status=TeacherStatus.RETIRED, course_hours=60)\n        req1 = _make_request(business_id=\"BIZ-D003\", teacher=teacher)\n        engine.calculate(req1)\n\n        engine.review(\"BIZ-D003\", approved=False, operator=\"reviewer1\", reason=\"拒绝\")\n\n        state = engine.get_state(\"BIZ-D003\")\n        assert state.current_status == TaskStatus.REVIEW_REJECTED\n\n        teacher2 = _make_teacher(status=TeacherStatus.ACTIVE, course_hours=60)\n        req2 = _make_request(business_id=\"BIZ-D003\", teacher=teacher2)\n        result2 = engine.calculate(req2)\n\n        assert result2.final_action == RuleAction.PASS\n        assert result2.task_status == TaskStatus.PASSED\n\n"}}
