ter.post(\"/batch-calculate\", response_model=List[CalculateResult])\n    43\tdef batch_calculate(request: BatchCalculateRequest):\n    44\t    results = engine.batch_calculate(request.requests)\n    45\t    return results\n    46\t\n    47\t\n    48\t@router.post(\"/review\", response_model=CalculateResult)\n    49\tdef review_task(request: ReviewRequest):\n    50\t    result = engine.review(\n    51\t        business_id=request.business_id,\n    52\t        approved=request.approved,\n    53\t        operator=request.operator,\n    54\t        reason=request.reason,\n    55\t    )\n    56\t    return result\n    57\t\n    58\t\n    59\t@router.get(\"/replay/{business_id}\", response_model=List[Dict])\n    60\tdef replay_business(business_id: str):\n    61\t    data = engine.replay(business_id)\n    62\t    if not data:\n    63\t        raise HTTPException(status_code=404, detail=f\"未找到业务编号 {business_id} 的记录\")\n    64\t    return data\n    65\t\n    66\t\n    67\t@router.get(\"/status/{business_id}\")\n    68\tdef get_task_status(business_id: str):\n    69\t    state = engine.get_state(business_id)\n    70\t    if not state:\n    71\t        raise HTTPException(status_code=404, detail=f\"未找到业务编号 {business_id} 的状态\")\n    72\t    result = engine.store.get_result(business_id)\n    73\t    return {\n    74\t        \"business_id\": business_id,\n    75\t        \"current_status\": state.current_status.value,\n    76\t        \"is_terminal\": state.is_terminal(),\n    77\t        \"transitions\": state.replay(),\n    78\t        \"result\": result.model_dump() if result else None,\n    79\t    }\n"}}
