复核，仅待复核状态允许复核\",\n            )\n\n        if approved:\n            state.transition(\n                TaskStatus.REVIEW_APPROVED, operator=operator, reason=reason\n            )\n            existing = self.store.get_result(business_id)\n            task_status = TaskStatus.REVIEW_APPROVED\n            if existing:\n                existing.task_status = task_status\n                existing.final_action = RuleAction.PASS\n                existing.readable_reason = f\"复核通过：{reason}\" if reason else \"复核通过\"\n                self.store.save_result(business_id, existing)\n        else:\n            state.transition(\n                TaskStatus.REVIEW_REJECTED, operator=operator, reason=reason\n            )\n            existing = self.store.get_result(business_id)\n            task_status = TaskStatus.REVIEW_REJECTED\n            if existing:\n                existing.task_status = task_status\n                existing.final_action = RuleAction.BLOCK\n                existing.readable_reason = f\"复核驳回：{reason}\" if reason else \"复核驳回\"\n                self.store.save_result(business_id, existing)\n\n        self.store.append_record(\n            AuditRecord(\n                record_id=f\"{business_id}-review\",\n                business_id=business_id,\n                teacher_id=existing.teacher_id if existing else \"\",\n                operator=operator,\n                action=f\"review:{'approved' if approved else 'rejected'}\",\n                detail=reason,\n            )\n        )\n\n        return self.store.get_result(business_id) or CalculateResult(\n            business_id=business_id,\n            teacher_id=\"\",\n            final_action=RuleAction.BLOCK,\n            task_status=task_status,\n            readable_reason=\"复核完成\",\n        )\n\n    def batch_calculate(\n        self, requests: List[CalculateRequest]\n    ) -> List[CalculateResult]:\n        return [self.calculate(req) for req in requests]\n\n    def get_state(self, business_id: str) -> Optional[TaskState]:\n        return self._states.get(business_id)\n\n    def replay(self, business_id: str) -> List[Dict]:\n        records = self.store.replay_by_business_id(business_id)\n        state = self._states.get(business_id)\n        if not records and state is None:\n            return []\n        result = {\n            \"audit_records\": [r.model_dump() for r in records],\n            \"state_transitions\": state.replay() if state else [],\n        }\n        return [result]\n"}}
/Users/bill/.codex/sessions/2026/06/02/rollout-2026-06-02T03-07-30-019e8495-7e72-7451-834a-b5aec9bf905b.jsonl:41:{"timestamp":"2026-06-01T19:09:58.953Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_D19viZebKbUaxkdc2cmvVb6k","output":"Chunk ID: 4be405\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 1214\nOutput:\nfrom __future__ import annotations\n\nfrom enum import Enum\nfrom typing import Dict, List, Optional\nfrom pydantic import BaseModel, Field\n\nfrom app.models.object import CourseType, TeacherStatus\n\n\nclass RiskLevel(str, Enum):\n    LOW = \"low\"\n    MEDIUM = \"medium\"\n    HIGH = \"high\"\n\n\nclass RuleAction(str, Enum):\n    PASS = \"pass\"\n    BLOCK = \"block\"\n    PENDING_REVIEW = \"pending_review\"\n\n\nclass RuleCondition(BaseModel):\n    field: str\n    operator: str\n    value: str\n\n\nclass RuleDefinition(BaseModel):\n    rule_id: str\n    name: str\n    description: str\n    risk_level: RiskLevel = RiskLevel.LOW\n    action: RuleAction = RuleAction.PASS\n    conditions: List[RuleCondition] = Field(default_factory=list)\n    priority: int = Field(default=0)\n    enabled: bool = Field(default=True)\n\n\nclass RuleVersion(BaseModel):\n    version: str\n    effective_from: str\n    effective_to: Optional[str] = None\n    rules: List[RuleDefinition] = Field(default_factory=list)\n\n\nCOURSE_TYPE_MULTIPLIER: Dict[CourseType, float] = {\n    CourseType.LECTURE: 1.0,\n    CourseType.LAB: 1.2,\n    CourseType.SEMINAR: 1.1,\n    CourseType.PRACTICE: 1.3,\n}\n\nSTATUS_ALLOWANCE_FACTOR: Dict[TeacherStatus, float] = {\n    TeacherStatus.ACTIVE: 1.0,\n    TeacherStatus.SUSPENDED: 0.0,\n    TeacherStatus.RETIRED: 0.5,\n    TeacherStatus.ON_LEAVE: 0.3,\n}\n\nMAX_HOURS_PER_MONTH = 200.0\nHIGH_RISK_HOURS_THRESHOLD = 160.0\n\nDEFAULT_RULES_V1: List[RuleDefinition] = [\n    RuleDefinition(\n        rule_id=\"R001\",\n        name=\"教师状态校验\",\n        description=\"教师状态异常(停职/退休/休假)时触发复核\",\n        risk_level=RiskLevel.MEDIUM,\n        action=RuleAction.PENDING_REVIEW,\n        conditions=[RuleCondition(field=\"status\", operator=\"not_in\", value=\"active\")],\n        priority=10,\n    ),\n    RuleDefinition(\n        rule_id=\"R002\",\n        name=\"材料完整性校验\",\n        description=\"教师未提交完整材料时拦截\",\n        risk_level=RiskLevel.HIGH,\n        action=RuleAction.BLOCK,\n        conditions=[RuleCondition(field=\"materials_submitted\", operator=\"eq\", value=\"false\")],\n        priority=20,\n    ),\n    RuleDefinition(\n        rule_id=\"R003\",\n        name=\"课时上限校验\",\n        description=\"课时超出月度上限200时触发复核\",\n        risk_level=RiskLevel.HIGH,\n        action=RuleAction.PENDING_REVIEW,\n        conditions=[RuleCondition(field=\"course_hours\", operator=\"gt\", value=str(MAX_HOURS_PER_MONTH))],\n        priority=15,\n    ),\n    RuleDefinition(\n        rule_id=\"R004\",\n        name=\"高风险课时校验\",\n        description=\"课时超过160但未超上限时标记为中等风险\",\n        risk_level=RiskLevel.MEDIUM,\n        action=RuleAction.PASS,\n        conditions=[RuleCondition(field=\"course_hours\", operator=\"gt\", value=str(HIGH_RISK_HOURS_THRESHOLD))],\n        priority=5,\n    ),\n]\n\nDEFAULT_RULES_V2: List[RuleDefinition] = [\n    RuleDefinition(\n        rule_id=\"R001\",\n        name=\"教师状态校验\",\n        description=\"教师状态异常(停职/退休/休假)时触发复核\",\n        risk_level=RiskLevel.MEDIUM,\n        action=RuleAction.PENDING_REVIEW,\n        conditions=[RuleCondition(field=\"status\", operator=\"not_in\", value=\"active\")],\n        priority=10,\n    ),\n    RuleDefinition(\n        rule_id=\"R002\",\n        name=\"材料完整性校验\",\n        description=\"教师未提交完整材料时拦截\",\n        risk_level=RiskLevel.HIGH,\n        action=RuleAction.BLOCK,\n        conditions=[RuleCondition(field=\"materials_submitted\", operator=\"eq\", value=\"false\")],\n        priority=20,\n    ),\n    RuleDefinition(\n        rule_id=\"R003\",\n        name=\"课时上限校验\",\n        description=\"课时超出月度上限200时触发复核\",\n        risk_level=RiskLevel.HIGH,\n        action=RuleAction.PENDING_REVIEW,\n        conditions=[RuleCondition(field=\"course_hours\", operator=\"gt\", value=str(MAX_HOURS_PER_MONTH))],\n        priority=15,\n    ),\n    RuleDefinition(\n        rule_id=\"R005\",\n        name=\"v2-课时超额阶梯校验\",\n        description=\"v2新增: 课时超过150即触发复核（比v1更严格）\",\n        risk_level=RiskLevel.MEDIUM,\n        action=RuleAction.PENDING_REVIEW,\n        conditions=[RuleCondition(field=\"course_hours\", operator=\"gt\", value=\"150\")],\n        priority=8,\n    ),\n]\n\nRULE_REGISTRY: Dict[str, List[RuleDefinition]] = {\n    \"v1\": DEFAULT_RULES_V1,\n    \"v2\": DEFAULT_RULES_V2,\n}\n\n\ndef get_rules(version: str) -> List[RuleDefinition]:\n    return RULE_REGISTRY.get(version, DEFAULT_RULES_V1)\n\n\ndef calculate_allowance(\n    course_hours: float,\n    course_type: CourseType,\n    teacher_status: TeacherStatus,\n    base_rate: float,\n) -> float:\n    multiplier = COURSE_TYPE_MULTIPLIER.get(course_type, 1.0)\n    status_factor = STATUS_ALLOWANCE_FACTOR.get(teacher_status, 0.0)\n    return round(course_hours * base_rate * multiplier * status_factor, 2)\n"}}
/Users/bill/.codex/sessions/2026/06/02/rollout-2026-06-02T03-07-30-019e8495-7e72-7451-834a-b5aec9bf905b.jsonl:42:{"timestamp":"2026-06-01T19:09:58.953Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_4K1fzJ0wzmi3VBCSHqYZtwQm","output":"Chunk ID: b11207\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 563\nOutput:\nfrom __future__ import annotations\n\nfrom datetime import datetime\nfrom enum import Enum\nfrom typing import Dict, List, Optional\nfrom pydantic import BaseModel, Field\n\n\nclass TaskStatus(str, Enum):\n    SUBMITTED = \"submitted\"\n    PROCESSING = \"processing\"\n    PASSED = \"passed\"\n    BLOCKED = \"blocked\"\n    PENDING_REVIEW = \"pending_review\"\n    REVIEW_APPROVED = \"review_approved\"\n    REVIEW_REJECTED = \"review_rejected\"\n\n\nVALID_TRANSITIONS: Dict[TaskStatus, List[TaskStatus]] = {\n    TaskStatus.SUBMITTED: [TaskStatus.PROCESSING],\n    TaskStatus.PROCESSING: [TaskStatus.PASSED, TaskStatus.BLOCKED, TaskStatus.PENDING_REVIEW],\n    TaskStatus.PENDING_REVIEW: [TaskStatus.REVIEW_APPROVED, TaskStatus.REVIEW_REJECTED],\n    TaskStatus.PASSED: [],\n    TaskStatus.BLOCKED: [TaskStatus.PROCESSING],\n    TaskStatus.REVIEW_APPROVED: [],\n    TaskStatus.REVIEW_REJECTED: [TaskStatus.PROCESSING],\n}\n\nTERMINAL_STATES = {\n    TaskStatus.PASSED,\n    TaskStatus.REVIEW_APPROVED,\n}\n\n\nclass StateTransition(BaseModel):\n    from_status: TaskStatus\n    to_status: TaskStatus\n    timestamp: str = Field(default_factory=lambda: datetime.utcnow().isoformat())\n    operator: str = \"\"\n    reason: str = \"\"\n\n\nclass TaskState(BaseModel):\n    business_id: str\n    current_status: TaskStatus = TaskStatus.SUBMITTED\n    transitions: List[StateTransition] = Field(default_factory=list)\n\n    def can_transition(self, target: TaskStatus) -> bool:\n        return target in VALID_TRANSITIONS.get(self.current_status, [])\n\n    def transition(self, target: TaskStatus, operator: str = \"\", reason: str = \"\") -> None:\n        if not self.can_transition(target):\n            raise InvalidTransitionError(\n                f\"不允许从 {self.current_status.value} 转到 {target.value}\"\n            )\n        record = StateTransition(\n            from_status=self.current_status,\n            to_status=target,\n            operator=operator,\n            reason=reason,\n        )\n        self.transitions.append(record)\n        self.current_status = target\n\n    def is_terminal(self) -> bool:\n        return self.current_status in TERMINAL_STATES\n\n    def replay(self) -> List[Dict]:\n        return [t.model_dump() for t in self.transitions]\n\n\nclass InvalidTransitionError(Exception):\n    pass\n"}}
