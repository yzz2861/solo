\nVALID_FINAL_LABELS = {\"ACCEPT\", \"NEEDS_REVISION\", \"REJECT\"}\nVALID_DIFFICULTIES = {\"easy\", \"medium\", \"hard\"}\nVALID_CONFIDENCE = {\"low\", \"medium\", \"high\"}\nLABEL_TO_USABILITY = {\n    \"ACCEPT\": \"✅可用\",\n    \"NEEDS_REVISION\": \"⚠️需修改\",\n    \"REJECT\": \"❌不可用\",\n}\nLABEL_TO_ALLOWED_SCORES = {\n    \"ACCEPT\": {\"5\"},\n    \"NEEDS_REVISION\": {\"2\", \"3\", \"4\"},\n    \"REJECT\": {\"1\"},\n}\nREQUIRED_META_KEYS = {\n    \"instance_id\",\n    \"reviewer\",\n    \"review_date\",\n    \"final_label\",\n    \"difficulty\",\n    \"repo_understanding\",\n    \"problem_statement_review\",\n    \"test_alignment_review\",\n    \"test_script_review\",\n    \"rollout_audit\",\n    \"recommended_fixes\",\n    \"feature_add\",\n    \"confidence\",\n}\n\n\ndef run(cmd: list[str], cwd: Path | None = None) -> subprocess.CompletedProcess[str]:\n    return subprocess.run(\n        cmd,\n        cwd=str(cwd) if cwd else None,\n        check=False,\n        text=True,\n        stdout=subprocess.PIPE,\n        stderr=subprocess.PIPE,\n    )\n\n\ndef run_checked(cmd: list[str], cwd: Path | None = None) -> str:\n    proc = run(cmd, cwd=cwd)\n    if proc.returncode != 0:\n        sys.stderr.write(proc.stdout or \"\")\n        sys.stderr.write(proc.stderr or \"\")\n        raise SystemExit(proc.returncode)\n    return proc.stdout\n\n\ndef load_json_file(path: Path, label: str) -> object:\n    try:\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    except json.JSONDecodeError as exc:\n        raise SystemExit(f\"{label} is not valid JSON: {path}\\n{exc}\") from exc\n\n\ndef load_payload(path: Path) -> dict:\n    payload = load_json_file(path, \"Payload\")\n    if not isinstance(payload, dict):\n        raise SystemExit(\"Payload must be a JSON object.\")\n    if LEGACY_POST_REVISION_REASON_FIELD in payload:\n        legacy_reason = payload.pop(LEGACY_POST_REVISION_REASON_FIELD)\n        current_reason = payload.get(POST_REVISION_REASON_FIELD)\n        if current_reason not in (None, \"\", legacy_reason):\n            raise SystemExit(\n                f\"Payload contains conflicting {LEGACY_POST_REVISION_REASON_FIELD} \"\n                f\"and {POST_REVISION_REASON_FIELD} values.\"\n            )\n        payload[POST_REVISION_REASON_FIELD] = legacy_reason\n    protected = sorted(set(payload) & IMMUTABLE_SOURCE_FIELDS)\n    if protected:\n        raise SystemExit(f\"Payload must not modify immutable source fields: {protected}\")\n    unknown = sorted(set(payload) - set(ALLOWED_TEXT_AND_SELECT_FIELDS))\n    if unknown:\n        raise SystemExit(f\"Payload contains unsupported fields: {unknown}\")\n    missing = sorted(set(REQUIRED_TEXT_AND_SELECT_FIELDS) - set(payload))\n    if missing:\n        raise SystemExit(f\"Payload is missing required fields: {missing}\")\n    for field, value in payload.items():\n        if not isinstance(value, str) or not value.strip():\n            raise SystemExit(f\"Payload field must be a non-empty string: {field}\")\n    if payload[\"完备性评分（1-5分）\"] not in VALID_SCORES:\n        raise SystemExit(\"Payload score must be one of: 1, 2, 3, 4, 5\")\n    post_revision_score = payload.get(POST_REVISION_SCORE_FIELD)\n    if post_revision_score is not None and post_revision_score not in VALID_SCORES:\n        raise SystemExit(f\"Payload {POST_REVISION_SCORE_FIELD} must be one of: 1, 2, 3, 4, 5\")\n    if post_revision_score is not None and int(post_revision_score) < int(payload[\"完备性评分（1-5分）\"]):\n        raise SystemExit(\n            f\"Payload {POST_REVISION_SCORE_FIELD} must not be lower than \"\n            \"完备性评分（1-5分）. Preserve the original score as the floor for reruns.\"\n        )\n    if payload[\"是否可用\"] not in VALID_USABILITY:\n        raise SystemExit(f\"Payload 是否可用 must be one of: {sorted(VALID_USABILITY)}\")\n    if \"任务难度\" in payload and payload[\"任务难度\"] not in VALID_DIFFICULTIES:\n        raise SystemExit(f\"Payload 任务难度 must be one of: {sorted(VALID_DIFFICULTIES)}\")\n    return payload\n\n\ndef require_keys(obj: dict, required: set[str], label: str, allow_extra: bool = False) -> None:\n    missing = sorted(required - set(obj))\n    if missing:\n        raise SystemExit(f\"{label} is missing required keys: {missing}\")\n    if not allow_extra:\n        extra = sorted(set(obj) - required)\n        if extra:\n            raise SystemExit(f\"{label} contains unsupported keys: {extra}\")\n\n\ndef require_str(obj: dict, key: str, label: str, allowed: set[str] | None = None) -> None:\n    value = obj.get(key)\n    if not isinstance(value, str) or not value.strip():\n        raise SystemExit(f\"{label}.{key} must be a non-empty string\")\n    if allowed is not None and value not in allowed:\n        raise SystemExit(f\"{label}.{key} must be one of: {sorted(allowed)}\")\n\n\ndef require_bool(obj: dict, key: str, label: str) -> None:\n    if not isinstance(obj.get(key), bool):\n        raise SystemExit(f\"{label}.{key} must be a JSON boolean true/false\")\n\n\ndef require_str_list(obj: dict, key: str, label: str) -> None:\n    value = obj.get(key)\n    if not isinstance(value, list) or not all(isinstance(item, str) for item in value):\n        raise SystemExit(f\"{label}.{key} must be an array of strings\")\n\n\ndef require_fr_unit_list(obj: dict, key: str, label: str) -> None:\n    require_str_list(obj, key, label)\n    value = obj[key]\n    pattern = re.compile(r\"^FR-\\d+(?:\\s*/\\s*FR-\\d+)*(?:\\s|:|：|-|—|，|,).+\")\n    for index, item in enumerate(value, 1):\n        stripped = item.strip()\n        if not pattern.match(stripped):\n            raise SystemExit(\n                f\"{label}.{key}[{index}] must start with FR unit format, \"\n                \"for example: FR-3 未说明...\"\n            )\n\n\nENV_REQUIREMENT_MIRROR_RE = re.compile(\n    r\"((需求|题面|题目|文档|spec|statement|problem statement|PRD).{0,50}\"\n    r\"(版本|依赖|环境|运行方式|声明|要求|python|node|go|java|jdk|maven|gradle|rust|cuda|torch|tensorflow)\"\n    r\"|\"\n    r\"(版本|依赖|环境|运行方式|python|node|go|java|jdk|maven|gradle|rust|cuda|torch|tensorflow).{0,50}\"\n    r\"(需求|题面|题目|文档|spec|statement|problem statement|PRD)\"\n    r\"|版本误导|版本错误|依赖误导|运行方式写错|环境前提缺失)\",\n    re.I,\n)\n\n\ndef require_environment_requirement_mirror(ps: dict, script: dict) -> None:\n    mirrored = [\n        item\n        for item in script.get(\"test_environment_issues\", [])\n        if ENV_REQUIREMENT_MIRROR_RE.search(item)\n    ]\n    if mirrored and not ps.get(\"missing_requirements\"):\n        preview = \"; \".join(item[:160] for item in mirrored[:3])\n        raise SystemExit(\n            \"meta.test_script_review.test_environment_issues contains requirement-document \"\n            \"environment/dependency/version issues, so meta.problem_statement_review.\"\n"}}
