   raise SystemExit(\n            \"Payload score does not match meta.final_label: \"\n            f\"{payload['完备性评分（1-5分）']!r} vs {meta['final_label']!r}\"\n        )\n    if \"任务难度\" in payload and payload[\"任务难度\"] != meta[\"difficulty\"]:\n        raise SystemExit(\n            \"Payload 任务难度 does not match meta.difficulty: \"\n            f\"{payload['任务难度']!r} vs {meta['difficulty']!r}\"\n        )\n    if meta[\"final_label\"] != \"ACCEPT\" and not meta[\"recommended_fixes\"]:\n        raise SystemExit(\"meta.recommended_fixes must be non-empty when final_label is not ACCEPT\")\n\n    repo = meta[\"repo_understanding\"]\n    if not isinstance(repo, dict):\n        raise SystemExit(\"meta.repo_understanding must be a JSON object\")\n    require_keys(repo, {\"repo_url\", \"repo_purpose_summary\"}, \"meta.repo_understanding\")\n    require_str(repo, \"repo_url\", \"meta.repo_understanding\")\n    require_str(repo, \"repo_purpose_summary\", \"meta.repo_understanding\")\n\n    ps = meta[\"problem_statement_review\"]\n    if not isinstance(ps, dict):\n        raise SystemExit(\"meta.problem_statement_review must be a JSON object\")\n    require_keys(\n        ps,\n        {\n            \"problem_statement_unclear\",\n            \"missing_requirements\",\n            \"over_specified_or_leaky_details\",\n            \"untestable_requirements\",\n        },\n        \"meta.problem_statement_review\",\n    )\n    require_bool(ps, \"problem_statement_unclear\", \"meta.problem_statement_review\")\n    require_fr_unit_list(ps, \"missing_requirements\", \"meta.problem_statement_review\")\n    require_str_list(ps, \"over_specified_or_leaky_details\", \"meta.problem_statement_review\")\n    require_str_list(ps, \"untestable_requirements\", \"meta.problem_statement_review\")\n\n    alignment = meta[\"test_alignment_review\"]\n    if not isinstance(alignment, dict):\n        raise SystemExit(\"meta.test_alignment_review must be a JSON object\")\n    require_keys(\n        