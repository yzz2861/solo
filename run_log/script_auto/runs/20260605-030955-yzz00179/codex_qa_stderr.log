6\t            actual_str = str(actual).lower()\n    47\t        elif hasattr(actual, \"value\"):\n    48\t            actual_str = str(actual.value)\n    49\t        else:\n    50\t            actual_str = str(actual)\n    51\t\n    52\t        if op == \"eq\":\n    53\t            return actual_str == val\n    54\t        elif op == \"neq\":\n    55\t            return actual_str != val\n    56\t        elif op == \"gt\":\n    57\t            try:\n    58\t                return float(actual_str) > float(val)\n    59\t            except (ValueError, TypeError):\n    60\t                return False\n    61\t        elif op == \"lt\":\n    62\t            try:\n    63\t                return float(actual_str) < float(val)\n    64\t            except (ValueError, TypeError):\n    65\t                return False\n    66\t        elif op == \"in\":\n    67\t            return actual_str in val.split(\",\")\n    68\t        elif op == \"not_in\":\n    69\t            return actual_str not in val.split(\",\")\n    70\t        return False\n    71\t\n    72\t    def _evaluate_rules(\n    73\t        self, teacher: TeacherObject, rules: List[RuleDefinition]\n    74\t    ) -> Tuple[RuleAction, List[RuleHitDetail], List[str]]:\n    75\t        hits: List[RuleHitDetail] = []\n    76\t        risk_flags: List[str] = []\n    77\t\n    78\t        sorted_rules = sorted(\n    79\t            [r for r in rules if r.enabled], key=lambda r: -r.priority\n    80\t        )\n    81\t\n    82\t        for rule in sorted_rules:\n    83\t            all_match = all(\n    84\t                self._evaluate_condition(teacher, c) for c in rule.conditions\n    85\t            )\n    86\t            if all_match and rule.conditions:\n    87\t                hits.append(\n    88\t                    RuleHitDetail(\n    89\t                        rule_id=rule.rule_id,\n    90\t                        rule_name=rule.name,\n    91\t                        risk_level=rule.risk_level,\n    92\t                        action=rule.action,\n    93\t                        reason=rule.description,\n    94\t                    )\n    95\t                )\n    96\t                risk_flags.append(f\"{rule.rule_id}:{rule.risk_level.value}\")\n    97\t\n    98\t        if not hits:\n    99\t            return RuleAction.PASS, hits, risk_flags\n   100\t\n   101\t        has_block = any(h.action == RuleAction.BLOCK for h in hits)\n   102\t        has_pending = any(h.action == RuleAction.PENDING_REVIEW for h in hits)\n   103\t\n   104\t        if has_block:\n   105\t            return RuleAction.BLOCK, hits, risk_flags\n   106\t        if has_pending:\n   107\t            return RuleAction.PENDING_REVIEW, hits, risk_flags\n   108\t\n   109\t        return RuleAction.PASS, hits, risk_flags\n   110\t\n   111\t    def _build_reason(\n   112\t        self,\n   113\t        action: RuleAction,\n   114\t        hits: List[RuleHitDetail],\n   115\t        teacher: TeacherObject,\n   116\t        amount: float,\n   117\t    ) -> str:\n   118\t        if action == RuleAction.PASS and not hits:\n   119\t            return (\n   120\t                f\"教师{teacher.name}({teacher.teacher_id})核算通过，\"\n   121\t                f\"课时{teacher.course_hours}，津贴{amount}元\"\n   122\t            )\n   123\t        if action == RuleAction.BLOCK:\n   124\t            reasons = \"；\".join(h.reason for h in hits if h.action == RuleAction.BLOCK)\n   125\t            return f\"核算拦截：{reasons}\"\n   126\t        if action == RuleAction.PENDING_REVIEW:\n   127\t            reasons = \"；\".join(\n   128\t                h.reason for h in hits if h.action == RuleAction.PENDING_REVIEW\n   129\t            )\n   130\t            return f\"待人工复核：{reasons}\"\n   131\t        return \"核算通过\"\n   132\t\n   133\t    def calculate(self, request: CalculateRequest) -> CalculateResult:\n   134\t        state = self._get_state(request.business_id)\n   135\t\n   136\t        if state.current_status not in (\n   