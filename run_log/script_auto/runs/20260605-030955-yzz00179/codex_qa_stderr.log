\t\n   102\tDEFAULT_RULES_V2: List[RuleDefinition] = [\n   103\t    RuleDefinition(\n   104\t        rule_id=\"R001\",\n   105\t        name=\"教师状态校验\",\n   106\t        description=\"教师状态异常(停职/退休/休假)时触发复核\",\n   107\t        risk_level=RiskLevel.MEDIUM,\n   108\t        action=RuleAction.PENDING_REVIEW,\n   109\t        conditions=[RuleCondition(field=\"status\", operator=\"not_in\", value=\"active\")],\n   110\t        priority=10,\n   111\t    ),\n   112\t    RuleDefinition(\n   113\t        rule_id=\"R002\",\n   114\t        name=\"材料完整性校验\",\n   115\t        description=\"教师未提交完整材料时拦截\",\n   116\t        risk_level=RiskLevel.HIGH,\n   117\t        action=RuleAction.BLOCK,\n   118\t        conditions=[RuleCondition(field=\"materials_submitted\", operator=\"eq\", value=\"false\")],\n   119\t        priority=20,\n   120\t    ),\n   121\t    RuleDefinition(\n   122\t        rule_id=\"R003\",\n   123\t        name=\"课时上限校验\",\n   124\t        description=\"课时超出月度上限200时触发复核\",\n   125\t        risk_level=RiskLevel.HIGH,\n   126\t        action=RuleAction.PENDING_REVIEW,\n   127\t        conditions=[RuleCondition(field=\"course_hours\", operator=\"gt\", value=str(MAX_HOURS_PER_MONTH))],\n   128\t        priority=15,\n   129\t    ),\n   130\t    RuleDefinition(\n   131\t        rule_id=\"R005\",\n   132\t        name=\"v2-课时超额阶梯校验\",\n   133\t        description=\"v2新增: 课时超过150即触发复核（比v1更严格）\",\n   134\t        risk_level=RiskLevel.MEDIUM,\n   135\t        action=RuleAction.PENDING_REVIEW,\n   136\t        conditions=[RuleCondition(field=\"course_hours\", operator=\"gt\", value=\"150\")],\n   137\t        priority=8,\n   138\t    ),\n   139\t]\n   140\t\n   141\tRULE_REGISTRY: Dict[str, List[RuleDefinition]] = {\n   142\t    \"v1\": DEFAULT_RULES_V1,\n   143\t    \"v2\": DEFAULT_RULES_V2,\n   144\t}\n   145\t\n   146\t\n   147\tdef get_rules(version: str) -> List[RuleDefinition]:\n   148\t    return RULE_REGISTRY.get(version, DEFAULT_RULES_V1)\n   149\t\n   150\t\n   151\tdef calculate_allowance(\n   152\t    course_hours: float,\n   153\t    course_type: CourseType,\n   154\t    teacher_status: TeacherStatus,\n   155\t    base_rate: float,\n   156\t) -> float:\n   157\t    multiplier = COURSE_TYPE_MULTIPLIER.get(course_type, 1.0)\n   158\t    status_factor = STATUS_ALLOWANCE_FACTOR.get(teacher_status, 0.0)\n   159\t    return round(course_hours * base_rate * multiplier * status_factor, 2)\n"}}
