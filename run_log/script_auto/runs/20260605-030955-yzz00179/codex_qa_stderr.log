lf):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=155)\n        req = _make_request(business_id=\"BIZ-C004\", teacher=teacher, rule_version=\"v2\")\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.PENDING_REVIEW\n        any_v2_hit = any(h.rule_id == \"R005\" for h in result.rule_hits)\n        assert any_v2_hit\n\n    def test_v1_normal_at_155_hours(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=155)\n        req = _make_request(business_id=\"BIZ-C005\", teacher=teacher, rule_version=\"v1\")\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.PASS\n\n\nclass TestExceptionExplanation:\n    def test_blocked_reason_is_human_readable(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(materials_submitted=False)\n        req = _make_request(business_id=\"BIZ-E001\", teacher=teacher)\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.BLOCK\n        assert \"拦截\" in result.readable_reason\n        assert \"材料\" in result.readable_reason\n\n    def test_pending_review_reason_is_human_readable(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(status=TeacherStatus.ON_LEAVE)\n        req = _make_request(business_id=\"BIZ-E002\", teacher=teacher)\n        result = engine.calculate(req)\n\n        assert result.final_action == RuleAction.PENDING_REVIEW\n        assert \"复核\" in result.readable_reason\n\n    def test_pass_reason_includes_teacher_info(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(name=\"李四\", teacher_id=\"T888\", course_hours=90)\n        req = _make_request(business_id=\"BIZ-E003\", teacher=teacher)\n        result = engine.calculate(req)\n\n        assert \"李四\" in result.readable_reason\n        assert \"T888\" in result.readable_reason\n        assert \"90\" in result.readable_reason\n\n\nclass TestTaskStatus:\n    def test_full_lifecycle_pass(self):\n        state = TaskState(business_id=\"ST001\")\n        assert state.current_status == TaskStatus.SUBMITTED\n        state.transition(TaskStatus.PROCESSING)\n        assert state.current_status == TaskStatus.PROCESSING\n        state.transition(TaskStatus.PASSED)\n        assert state.current_status == TaskStatus.PASSED\n        assert state.is_terminal()\n\n    def test_full_lifecycle_review_approved(self):\n        state = TaskState(business_id=\"ST002\")\n        state.transition(TaskStatus.PROCESSING)\n        state.transition(TaskStatus.PENDING_REVIEW)\n        state.transition(TaskStatus.REVIEW_APPROVED)\n        assert state.is_terminal()\n\n    def test_invalid_transition_raises(self):\n        state = TaskState(business_id=\"ST003\")\n        with pytest.raises(InvalidTransitionError):\n            state.transition(TaskStatus.PASSED)\n\n    def test_cannot_transition_from_terminal(self):\n        state = TaskState(business_id=\"ST004\")\n        state.transition(TaskStatus.PROCESSING)\n        state.transition(TaskStatus.PASSED)\n        with pytest.raises(InvalidTransitionError):\n            state.transition(TaskStatus.PROCESSING)\n\n\nclass TestDataReplay:\n    def test_replay_returns_audit_records(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(course_hours=80)\n        req = _make_request(business_id=\"BIZ-RP001\", teacher=teacher)\n        engine.calculate(req)\n\n        replay_data = engine.replay(\"BIZ-RP001\")\n        assert len(replay_data) == 1\n        assert len(replay_data[0][\"audit_records\"]) >= 1\n        assert len(replay_data[0][\"state_transitions\"]) >= 1\n\n    def test_replay_captures_review_flow(self):\n        engine = AllowanceEngine()\n        teacher = _make_teacher(status=TeacherStatus.RETIRED, course_hours=60)\n        req = _make_request(business_id=\"BIZ-RP002\", teacher=teacher)\n        engine.calculate(req)\n        engine.review(\"BIZ-RP002\", approved=True, operator=\"reviewer1\", reason=\"批准\")\n\n        replay_data = engine.replay(\"BIZ-RP002\")\n        assert len(replay_data[0][\"audit_records\"]) == 2\n        transitions = replay_data[0][\"state_transitions\"]\n        assert len(transitions) >= 3\n\n    def test_replay_nonexistent_returns_empty(self):\n        engine = AllowanceEngine()\n        replay_data = engine.replay(\"BIZ-NONEXIST\")\n        assert len(replay_data) == 0\n\n\nclass TestCalculateAllowanceFunction:\n    def test_active_lecture(self):\n        assert calculate_allowance(80, CourseType.LECTURE, TeacherStatus.ACTIVE, 50) == 4000.0\n\n    def test_active_lab(self):\n        assert calculate_allowance(80, CourseType.LAB, TeacherStatus.ACTIVE, 50) == 4800.0\n\n    def test_retired_lecture(self):\n        assert calculate_allowance(80, CourseType.LECTURE, TeacherStatus.RETIRED, 50) == 2000.0\n\n    def test_suspended_zero(self):\n        assert calculate_allowance(80, CourseType.LECTURE, TeacherStatus.SUSPENDED, 50) == 0.0\n\n    def test_on_leave_partial(self):\n        assert calculate_allowance(80, CourseType.LECTURE, TeacherStatus.ON_LEAVE, 50) == 1200.0\n"}}
