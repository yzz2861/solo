"""
学生宿舍晚归统计脚本

将原始晚归记录整理为可复核报告:
- 输入: 业务记录列表、问题字典、去重键、报表模板
- 输出: 统计结果、异常样本、趋势摘要、导出文件
- 缺失/重复/越界数据分别标注
- 保留处理批次和来源标识
"""

import csv
import hashlib
import json
import os
import uuid
from collections import Counter, defaultdict
from copy import deepcopy
from datetime import datetime, date, time, timedelta
from enum import Enum
from typing import Any, Dict, List, Optional, Set, Tuple


class AnomalyType(str, Enum):
    MISSING = "缺失"
    DUPLICATE = "重复"
    OUT_OF_BOUND = "越界"
    OK = "正常"


class TaskStatus(str, Enum):
    PENDING = "pending"
    PROCESSING = "processing"
    COMPLETED = "completed"
    PARTIAL_FAILED = "partial_failed"
    FAILED = "failed"


class LateReturnRecord:
    __slots__ = (
        "student_id", "student_name", "dormitory", "room_number",
        "return_date", "return_time", "reason", "recorder",
        "source_id", "_raw", "_dedup_key_values",
    )

    def __init__(self, raw: Dict[str, Any]):
        self._raw = raw
        self.student_id = str(raw.get("student_id", "")).strip()
        self.student_name = str(raw.get("student_name", "")).strip()
        self.dormitory = str(raw.get("dormitory", "")).strip()
        self.room_number = str(raw.get("room_number", "")).strip()
        self.return_date = str(raw.get("return_date", "")).strip()
        self.return_time = str(raw.get("return_time", "")).strip()
        self.reason = str(raw.get("reason", "")).strip()
        self.recorder = str(raw.get("recorder", "")).strip()
        self.source_id = str(raw.get("source_id", "")).strip()
        self._dedup_key_values = None

    @property
    def raw(self) -> Dict[str, Any]:
        return self._raw

    def dedup_key(self, keys: List[str]) -> str:
        if self._dedup_key_values is not None and not keys:
            return self._dedup_key_values
        parts = []
        for k in keys:
            v = self._raw.get(k, "")
            parts.append(f"{k}={v}")
        return "|".join(parts)

    def missing_fields(self, required: List[str]) -> List[str]:
        missing = []
        for f in required:
            val = self._raw.get(f)
            if val is None or (isinstance(val, str) and val.strip() == ""):
                missing.append(f)
        return missing

    def out_of_bound_fields(self, bounds: Dict[str, Dict[str, Any]]) -> List[str]:
        violations = []
        for field, rule in bounds.items():
            val = self._raw.get(field)
            if val is None or (isinstance(val, str) and val.strip() == ""):
                continue
            if "min" in rule:
                try:
                    if float(val) < float(rule["min"]):
                        violations.append(field)
                        continue
                except (ValueError, TypeError):
                    pass
            if "max" in rule:
                try:
                    if float(val) > float(rule["max"]):
                        violations.append(field)
                        continue
                except (ValueError, TypeError):
                    pass
            if "time_after" in rule:
                try:
                    t = self._parse_time(val)
                    threshold = self._parse_time(rule["time_after"])
                    if t is not None and threshold is not None and t < threshold:
                        violations.append(field)
                        continue
                except (ValueError, TypeError):
                    pass
            if "time_before" in rule:
                try:
                    t = self._parse_time(val)
                    threshold = self._parse_time(rule["time_before"])
                    if t is not None and threshold is not None and t > threshold:
                        violations.append(field)
                        continue
                except (ValueError, TypeError):
                    pass
            if "allowed_values" in rule:
                if str(val) not in [str(v) for v in rule["allowed_values"]]:
                    violations.append(field)
        return violations

    @staticmethod
    def _parse_time(val) -> Optional[time]:
        if isinstance(val, time):
            return val
        s = str(val).strip()
        for fmt in ("%H:%M", "%H:%M:%S"):
            try:
                return datetime.strptime(s, fmt).time()
            except ValueError:
                continue
        return None


class ProcessingBatch:
    def __init__(self, source: str = ""):
        self.batch_id = uuid.uuid4().hex[:12]
        self.source = source
        self.created_at = datetime.now().isoformat()
        self.status = TaskStatus.PENDING
        self.total_input = 0
        self.total_processed = 0
        self.total_anomalies = 0

    def to_dict(self) -> Dict[str, Any]:
        return {
            "batch_id": self.batch_id,
            "source": self.source,
            "created_at": self.created_at,
            "status": self.status.value,
            "total_input": self.total_input,
            "total_processed": self.total_processed,
            "total_anomalies": self.total_anomalies,
        }


class ProblemDictionary:
    def __init__(self, config: Dict[str, Any]):
        self.required_fields: List[str] = config.get("required_fields", [])
        self.dedup_keys: List[str] = config.get("dedup_keys", [])
        self.bounds: Dict[str, Dict[str, Any]] = config.get("bounds", {})
        self.anomaly_descriptions: Dict[str, str] = config.get("anomaly_descriptions", {})
        self.field_labels: Dict[str, str] = config.get("field_labels", {})
        self.time_threshold: str = config.get("time_threshold", "22:30")

    def describe_anomaly(self, anomaly_type: str, field: str = "") -> str:
        key = f"{anomaly_type}.{field}" if field else anomaly_type
        if key in self.anomaly_descriptions:
            return self.anomaly_descriptions[key]
        if anomaly_type in self.anomaly_descriptions:
            return self.anomaly_descriptions[anomaly_type]
        label = self.field_labels.get(field, field)
        if anomaly_type == AnomalyType.MISSING.value:
            return f"字段[{label}]为空"
        if anomaly_type == AnomalyType.DUPLICATE.value:
            return f"记录重复"
        if anomaly_type == AnomalyType.OUT_OF_BOUND.value:
            return f"字段[{label}]越界"
        return f"异常({anomaly_type})"


class ReportTemplate:
    def __init__(self, config: Dict[str, Any]):
        self.title = config.get("title", "学生宿舍晚归统计报告")
        self.summary_fields = config.get("summary_fields", [
            "total_records", "valid_records", "anomaly_count",
            "missing_count", "duplicate_count", "out_of_bound_count",
        ])
        self.group_by = config.get("group_by", ["dormitory"])
        self.trend_field = config.get("trend_field", "return_date")
        self.anomaly_sample_size = config.get("anomaly_sample_size", 10)
        self.export_format = config.get("export_format", "csv")


class AnnotatedRecord:
    def __init__(self, record: LateReturnRecord, batch: ProcessingBatch):
        self.record = record
        self.batch = batch
        self.anomalies: List[Dict[str, str]] = []
        self.is_valid = True
        self.is_duplicate = False

    def add_anomaly(self, anomaly_type: AnomalyType, field: str, description: str):
        self.anomalies.append({
            "type": anomaly_type.value,
            "field": field,
            "description": description,
        })
        if anomaly_type == AnomalyType.DUPLICATE:
            self.is_duplicate = True
        else:
            self.is_valid = False

    def to_dict(self) -> Dict[str, Any]:
        return {
            **self.record.raw,
            "_batch_id": self.batch.batch_id,
            "_source": self.batch.source,
            "_is_valid": self.is_valid,
            "_is_duplicate": self.is_duplicate,

