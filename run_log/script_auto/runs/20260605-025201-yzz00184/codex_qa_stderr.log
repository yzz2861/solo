class StatisticsResult:
    def __init__(self):
        self.total_records = 0
        self.valid_records = 0
        self.anomaly_count = 0
        self.missing_count = 0
        self.duplicate_count = 0
        self.out_of_bound_count = 0
        self.group_stats: Dict[str, Dict[str, Any]] = {}
        self.trend_data: Dict[str, Dict[str, int]] = {}

    def to_dict(self) -> Dict[str, Any]:
        return {
            "total_records": self.total_records,
            "valid_records": self.valid_records,
            "anomaly_count": self.anomaly_count,
            "missing_count": self.missing_count,
            "duplicate_count": self.duplicate_count,
            "out_of_bound_count": self.out_of_bound_count,
            "group_stats": self.group_stats,
            "trend_data": self.trend_data,
        }


class LateReturnProcessor:
    def __init__(
        self,
        problem_dict: ProblemDictionary,
        template: ReportTemplate,
        source: str = "",
    ):
        self.problem_dict = problem_dict
        self.template = template
        self.batch = ProcessingBatch(source=source)
        self.annotated: List[AnnotatedRecord] = []
        self.stats = StatisticsResult()
        self.dedup_tracker: Dict[str, int] = {}

    def process(self, raw_records: List[Dict[str, Any]]) -> Dict[str, Any]:
        self.batch.status = TaskStatus.PROCESSING
        self.batch.total_input = len(raw_records)

        records = [LateReturnRecord(r) for r in raw_records]

        self._dedup_tracker_reset(records)

        anomaly_count = 0
        for rec in records:
            ann = AnnotatedRecord(rec, self.batch)
            self._check_missing(ann)
            self._check_duplicate(ann)
            self._check_bounds(ann)
            self.annotated.append(ann)
            if ann.anomalies:
                anomaly_count += 1

        self.batch.total_processed = len(self.annotated)
        self.batch.total_anomalies = anomaly_count

        self._compute_stats()

        status = self._determine_status()
        self.batch.status = status

        return self._build_output()

    def _dedup_tracker_reset(self, records: List[LateReturnRecord]):
        self.dedup_tracker = {}
        keys = self.problem_dict.dedup_keys
        for rec in records:
            dk = rec.dedup_key(keys)
            self.dedup_tracker[dk] = self.dedup_tracker.get(dk, 0) + 1

    def _check_missing(self, ann: AnnotatedRecord):
        missing = ann.record.missing_fields(self.problem_dict.required_fields)
        for f in missing:
            desc = self.problem_dict.describe_anomaly(AnomalyType.MISSING.value, f)
            ann.add_anomaly(AnomalyType.MISSING, f, desc)

    def _check_duplicate(self, ann: AnnotatedRecord):
        dk = ann.record.dedup_key(self.problem_dict.dedup_keys)
        count = self.dedup_tracker.get(dk, 1)
        if count > 1:
            desc = self.problem_dict.describe_anomaly(AnomalyType.DUPLICATE.value)
            ann.add_anomaly(AnomalyType.DUPLICATE, "__dedup__", desc)
            self.dedup_tracker[dk] = count - 1

    def _check_bounds(self, ann: AnnotatedRecord):
        violations = ann.record.out_of_bound_fields(self.problem_dict.bounds)
        for f in violations:
            desc = self.problem_dict.describe_anomaly(AnomalyType.OUT_OF_BOUND.value, f)
            ann.add_anomaly(AnomalyType.OUT_OF_BOUND, f, desc)

    def _compute_stats(self):
        total = len(self.annotated)
        valid = sum(1 for a in self.annotated if a.is_valid and not a.is_duplicate)
        missing = sum(1 for a in self.annotated if any(an["type"] == AnomalyType.MISSING.value for an in a.anomalies))
        duplicate = sum(1 for a in self.annotated if a.is_duplicate)
        out_of_bound = sum(1 for a in self.annotated if any(an["type"] == AnomalyType.OUT_OF_BOUND.value for an in a.anomalies))
        anomaly = total - valid

        self.stats.total_records = total
        self.stats.valid_records = valid
        self.stats.anomaly_count = anomaly
        self.stats.missing_count = missing
        self.stats.duplicate_count = duplicate
        self.stats.out_of_bound_count = out_of_bound

        self._compute_group_stats()
        self._compute_trend()

    def _compute_group_stats(self):
        group_fields = self.template.group_by
        groups: Dict[str, List[AnnotatedRecord]] = defaultdict(list)
        for ann in self.annotated:
            key_parts = []
            for gf in group_fields:
                key_parts.append(str(ann.record.raw.get(gf, "")))
            key = "|".join(key_parts)
            groups[key].append(ann)

        for key, anns in groups.items():
            g_total = len(anns)
            g_valid = sum(1 for a in anns if a.is_valid and not a.is_duplicate)
            g_missing = sum(1 for a in anns if any(an["type"] == AnomalyType.MISSING.value for an in a.anomalies))
            g_dup = sum(1 for a in anns if a.is_duplicate)
            g_oob = sum(1 for a in anns if any(an["type"] == AnomalyType.OUT_OF_BOUND.value for an in a.anomalies))
            self.stats.group_stats[key] = {
                "total": g_total,
                "valid": g_valid,
                "missing": g_missing,
                "duplicate": g_dup,
                "out_of_bound": g_oob,
            }

    def _compute_trend(self):
        trend_field = self.template.trend_field
        trend: Dict[str, Dict[str, int]] = defaultdict(lambda: {"total": 0, "valid": 0, "anomaly": 0})
        for ann in self.annotated:
            date_val = str(ann.record.raw.get(trend_field, "unknown"))
            trend[date_val]["total"] += 1
            if ann.is_valid and not ann.is_duplicate:
                trend[date_val]["valid"] += 1
            else:
                trend[date_val]["anomaly"] += 1
        self.stats.trend_data = dict(sorted(trend.items()))

    def _determine_status(self) -> TaskStatus:
        if self.stats.total_records == 0:
            return TaskStatus.FAILED
        if self.stats.valid_records == 0:
            return TaskStatus.FAILED
        if self.stats.anomaly_count > 0 and self.stats.valid_records > 0:
            return TaskStatus.PARTIAL_FAILED
        return TaskStatus.COMPLETED

    def _build_output(self) -> Dict[str, Any]:
        anomaly_samples = self._collect_anomaly_samples()
        trend_summary = self._build_trend_summary()
        export_path = self._export_file()

        return {
            "batch": self.batch.to_dict(),
            "statistics": self.stats.to_dict(),
            "anomaly_samples": anomaly_samples,
            "trend_summary": trend_summary,
            "export_file": export_path,
        }

    def _collect_anomaly_samples(self) -> List[Dict[str, Any]]:
        samples = []
        by_type: Dict[str, List[AnnotatedRecord]] = defaultdict(list)
        for ann in self.annotated:
            for an in ann.anomalies:
                by_type[an["type"]].append(ann)

        limit = self.template.anomaly_sample_size
        for atype in [AnomalyType.MISSING.value, AnomalyType.DUPLICATE.value, AnomalyType.OUT_OF_BOUND.value]:
            for ann in by_type.get(atype, [])[:limit]:
                samples.append({
                    "record": ann.record.raw,
                    "batch_id": ann.batch.batch_id,
                    "source": ann.batch.source,
                    "anomaly_type": atype,
                    "anomaly_details": ann.anomalies,
                })
        return samples

    def _build_trend_summary(self) -> str:
        if not self.stats.trend_data:
            return "无趋势数据"
        dates = list(self.stats.trend_data.keys())
        if len(dates) < 2:
            return f"仅有单日数据({dates[0]})，无法计算趋势"
        first = self.stats.trend_data[dates[0]]
        last = self.stats.trend_data[dates[-1]]
        first_rate = first["anomaly"] / first["total"] if first["total"] else 0
        last_rate = last["anomaly"] / last["total"] if last["total"] else 0
        if last_rate > first_rate:
            direction = "上升"
        elif last_rate < first_rate:
            direction = "下降"
        else:
            direction = "持平"
        return (
            f"统计周期: {dates[0]} ~ {dates[-1]}, "
            f"首日异常率 {first_rate:.1%}, 末日异常率 {last_rate:.1%}, "
            f"趋势: {direction}"
        )

    def _export_file(self) -> str:
        fmt = self.template.export_format
        filename = f"late_return_report_{self.batch.batch_id}.{fmt}"
        if fmt == "csv":
            self._export_csv(filename)
        elif fmt == "json":
            self._export_json(filename)
        else:
            self._export_csv(filename)
        return filename

    def _export_csv(self, filename: str):
        if not self.annotated:
            return
        fieldnames = list(self.annotated[0].record.raw.keys())
        meta_fields = ["_batch_id", "_source", "_is_valid", "_is_duplicate", "_anomaly_types", "_anomaly_descriptions"]
        fieldnames += meta_fields

        with open(filename, "w", newline="", encoding="utf-8-sig") as f:
            writer = csv.DictWriter(f, fieldnames=fieldnames)
            writer.writeheader()
            for ann in self.annotated:
                row = ann.to_dict()
                row["_anomaly_types"] = ";".join(a["type"] for a in ann.anomalies)
                row["_anomaly_descriptions"] = ";".join(a["description"] for a in ann.anomalies)
                del row["_anomalies"]
                writer.writerow(row)

    def _export_json(self, filename: str):
        data = {
            "batch": self.batch.to_dict(),
            "statistics": self.stats.to_dict(),
            "records": [ann.to_dict() for ann in self.annotated],
        }
        with open(filename, "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False, indent=2)

    def get_annotated_records(self) -> List[AnnotatedRecord]:
        return self.annotated

    def replay(self, raw_records: List[Dict[str, Any]]) -> Dict[str, Any]:
        self.annotated = []
        self.stats = StatisticsResult()
        self.dedup_tracker = {}
        self.batch = ProcessingBatch(source=self.batch.source)
        return self.process(raw_records)


def run_late_return_stats(
    records: List[Dict[str, Any]],
    problem_dict_config: Dict[str, Any],
    dedup_keys: Optional[List[str]] = None,
    template_config: Optional[Dict[str, Any]] = None,
    source: str = "",
) -> Dict[str, Any]:
    if dedup_keys:
        problem_dict_config.setdefault("dedup_keys", dedup_keys)
    problem_dict = ProblemDictionary(problem_dict_config)
    template = ReportTemplate(template_config or {})
    processor = LateReturnProcessor(problem_dict, template, source=source)
    return processor.process(records)

