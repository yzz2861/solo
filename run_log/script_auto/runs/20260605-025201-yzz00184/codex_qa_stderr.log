def _clean_exports():
    for f in os.listdir("."):
        if f.startswith("late_return_report_"):
            os.remove(f)


class TestLateReturnRecord(unittest.TestCase):
    def test_missing_fields(self):
        rec = LateReturnRecord({"student_id": "", "student_name": "A"})
        missing = rec.missing_fields(["student_id", "student_name", "return_date"])
        self.assertIn("student_id", missing)
        self.assertIn("return_date", missing)
        self.assertNotIn("student_name", missing)

    def test_dedup_key(self):
        rec = LateReturnRecord({"student_id": "001", "return_date": "2025-01-01"})
        key = rec.dedup_key(["student_id", "return_date"])
        self.assertEqual(key, "student_id=001|return_date=2025-01-01")

    def test_out_of_bound_time(self):
        rec = LateReturnRecord({"return_time": "21:00"})
        bounds = {"return_time": {"time_after": "22:30"}}
        violations = rec.out_of_bound_fields(bounds)
        self.assertIn("return_time", violations)

    def test_in_bound_time(self):
        rec = LateReturnRecord({"return_time": "23:00"})
        bounds = {"return_time": {"time_after": "22:30"}}
        violations = rec.out_of_bound_fields(bounds)
        self.assertNotIn("return_time", violations)

    def test_numeric_bounds(self):
        rec = LateReturnRecord({"score": "150"})
        bounds = {"score": {"min": 0, "max": 100}}
        violations = rec.out_of_bound_fields(bounds)
        self.assertIn("score", violations)


class TestSingleSuccess(unittest.TestCase):
    def setUp(self):
        _clean_exports()

    def tearDown(self):
        _clean_exports()

    def test_single_valid_record(self):
        result = run_late_return_stats(
            records=[VALID_RECORD],
            problem_dict_config=SAMPLE_PROBLEM_DICT,
            template_config=SAMPLE_TEMPLATE,
            source="门禁系统A",
        )
        stats = result["statistics"]
        self.assertEqual(stats["total_records"], 1)
        self.assertEqual(stats["valid_records"], 1)
        self.assertEqual(stats["anomaly_count"], 0)
        self.assertEqual(stats["missing_count"], 0)
        self.assertEqual(stats["duplicate_count"], 0)
        self.assertEqual(stats["out_of_bound_count"], 0)
        self.assertEqual(result["batch"]["status"], "completed")
        self.assertEqual(result["batch"]["source"], "门禁系统A")
        self.assertTrue(result["batch"]["batch_id"])

    def test_single_record_with_missing(self):
        result = run_late_return_stats(
            records=[MISSING_FIELD_RECORD],
            problem_dict_config=SAMPLE_PROBLEM_DICT,
            template_config=SAMPLE_TEMPLATE,
        )
        stats = result["statistics"]
        self.assertEqual(stats["total_records"], 1)
        self.assertEqual(stats["valid_records"], 0)
        self.assertEqual(stats["missing_count"], 1)
        self.assertEqual(stats["anomaly_count"], 1)
        self.assertEqual(result["batch"]["status"], "failed")
        samples = result["anomaly_samples"]
        self.assertTrue(any(s["anomaly_type"] == "缺失" for s in samples))

    def test_single_record_out_of_bound(self):
        result = run_late_return_stats(
            records=[OUT_OF_BOUND_RECORD],
            problem_dict_config=SAMPLE_PROBLEM_DICT,
            template_config=SAMPLE_TEMPLATE,
        )
        stats = result["statistics"]
        self.assertEqual(stats["out_of_bound_count"], 1)
        self.assertEqual(stats["valid_records"], 0)
        samples = result["anomaly_samples"]
        self.assertTrue(any(s["anomaly_type"] == "越界" for s in samples))


