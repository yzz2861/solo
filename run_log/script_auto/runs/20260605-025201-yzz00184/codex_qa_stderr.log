   249	class LateReturnProcessor:
   250	    def __init__(
   251	        self,
   252	        problem_dict: ProblemDictionary,
   253	        template: ReportTemplate,
   254	        source: str = "",
   255	    ):
   256	        self.problem_dict = problem_dict
   257	        self.template = template
   258	        self.batch = ProcessingBatch(source=source)
   259	        self.annotated: List[AnnotatedRecord] = []
   260	        self.stats = StatisticsResult()
   261	        self.dedup_tracker: Dict[str, int] = {}
   262	
   263	    def process(self, raw_records: List[Dict[str, Any]]) -> Dict[str, Any]:
   264	        self.batch.status = TaskStatus.PROCESSING
   265	        self.batch.total_input = len(raw_records)
   266	
   267	        records = [LateReturnRecord(r) for r in raw_records]
   268	
   269	        self._dedup_tracker_reset(records)
   270	
   271	        anomaly_count = 0
   272	        for rec in records:
   273	            ann = AnnotatedRecord(rec, self.batch)
   274	            self._check_missing(ann)
   275	            self._check_duplicate(ann)
   276	            self._check_bounds(ann)
   277	            self.annotated.append(ann)
   278	            if ann.anomalies:
   279	                anomaly_count += 1
   280	
   281	        self.batch.total_processed = len(self.annotated)
   282	        self.batch.total_anomalies = anomaly_count
   283	
   284	        self._compute_stats()
   285	
   286	        status = self._determine_status()
   287	        self.batch.status = status
   288	
   289	        return self._build_output()
   290	
   291	    def _dedup_tracker_reset(self, records: List[LateReturnRecord]):
   292	        self.dedup_tracker = {}
   293	        keys = self.problem_dict.dedup_keys
   294	        for rec in records:
   295	            dk = rec.dedup_key(keys)
   296	            self.dedup_tracker[dk] = self.dedup_tracker.get(dk, 0) + 1
   297	
   298	    def _check_missing(self, ann: AnnotatedRecord):
   299	        missing = ann.record.missing_fields(self.problem_dict.required_fields)
   300	        for f in missing:
   301	            desc = self.problem_dict.describe_anomaly(AnomalyType.MISSING.value, f)
   302	            ann.add_anomaly(AnomalyType.MISSING, f, desc)
   303	
   304	    def _check_duplicate(self, ann: AnnotatedRecord):
   305	        dk = ann.record.dedup_key(self.problem_dict.dedup_keys)
   306	        count = self.dedup_tracker.get(dk, 1)
   307	        if count > 1:
   308	            desc = self.problem_dict.describe_anomaly(AnomalyType.DUPLICATE.value)
   309	            ann.add_anomaly(AnomalyType.DUPLICATE, "__dedup__", desc)
   310	            self.dedup_tracker[dk] = count - 1
   311	
   312	    def _check_bounds(self, ann: AnnotatedRecord):
   313	        violations = ann.record.out_of_bound_fields(self.problem_dict.bounds)
   314	        for f in violations:
   315	            desc = self.problem_dict.describe_anomaly(AnomalyType.OUT_OF_BOUND.value, f)
   316	            ann.add_anomaly(AnomalyType.OUT_OF_BOUND, f, desc)
   317	
   318	    def _compute_stats(self):
   319	        total = len(self.annotated)
   320	        valid = sum(1 for a in self.annotated if a.is_valid and not a.is_duplicate)
   321	        missing = sum(1 for a in self.annotated if any(an["type"] == AnomalyType.MISSING.value for an in a.anomalies))
   322	        duplicate = sum(1 for a in self.annotated if a.is_duplicate)
   323	        out_of_bound = sum(1 for a in self.annotated if any(an["type"] == AnomalyType.OUT_OF_BOUND.value for an in a.anomalies))
   324	        anomaly = total - valid
   325	
   326	        self.stats.total_records = total
   327	        self.stats.valid_records = valid
   328	        self.stats.anomaly_count = anomaly
   329	        self.stats.missing_count = missing
   330	        self.stats.duplicate_count = duplicate
   331	        self.stats.out_of_bound_count = out_of_bound
   332	
   333	        self._compute_group_stats()
   334	        self._compute_trend()
   335	
   336	    def _compute_group_stats(self):
   337	        group_fields = self.template.group_by
   338	        groups: Dict[str, List[AnnotatedRecord]] = defaultdict(list)
   339	        for ann in self.annotated:
   340	            key_parts = []
   341	            for gf in group_fields:
   342	                key_parts.append(str(ann.record.raw.get(gf, "")))
   343	            key = "|".join(key_parts)
   344	            groups[key].append(ann)
   345	
   346	        for key, anns in groups.items():
   347	            g_total = len(anns)
   348	            g_valid = sum(1 for a in anns if a.is_valid and not a.is_duplicate)
   349	            g_missing = sum(1 for a in anns if any(an["type"] == AnomalyType.MISSING.value for an in a.anomalies))
   350	            g_dup = sum(1 for a in anns if a.is_duplicate)
   351	            g_oob = sum(1 for a in anns if any(an["type"] == AnomalyType.OUT_OF_BOUND.value for an in a.anomalies))
   352	            self.stats.group_stats[key] = {
   353	                "total": g_total,
   354	                "valid": g_valid,
   355	                "missing": g_missing,
   356	                "duplicate": g_dup,
   357	                "out_of_bound": g_oob,
   358	            }
   359	
   360	    def _compute_trend(self):
   361	        trend_field = self.template.trend_field
   362	        trend: Dict[str, Dict[str, int]] = defaultdict(lambda: {"total": 0, "valid": 0, "anomaly": 0})
   363	        for ann in self.annotated:
   364	            date_val = str(ann.record.raw.get(trend_field, "unknown"))
   365	            trend[date_val]["total"] += 1
   366	            if ann.is_valid and not ann.is_duplicate:
   367	                trend[date_val]["valid"] += 1
   368	            else:
   369	                trend[date_val]["anomaly"] += 1
   370	        self.stats.trend_data = dict(sorted(trend.items()))
   371	
   372	    def _determine_status(self) -> TaskStatus:
   373	        if self.stats.total_records == 0:
   374	            return TaskStatus.FAILED
   375	        if self.stats.valid_records == 0:
   376	            return TaskStatus.FAILED
   377	        if self.stats.anomaly_count > 0 and self.stats.valid_records > 0:
   378	            return TaskStatus.PARTIAL_FAILED
   379	        return TaskStatus.COMPLETED
