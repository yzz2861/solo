                    "quota_type": "users",
                    "quota_key": "s3",
                    "requested_value": 50,
                    "current_value": 40,
                    "unit": "count",
                },
            ],
            "source_channel": "migration",
            "action": "adjust",
            "review_opinion": "汇总验证",
