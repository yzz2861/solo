class TestDuplicateProcessing:
    def test_duplicate_batch_no_returns_same_result(self, client, normal_payload):
        resp1 = client.post("/api/v1/quota/batch", json=normal_payload)
        resp2 = client.post("/api/v1/quota/batch", json=normal_payload)

        assert resp1.status_code == 200
        assert resp2.status_code == 200
        assert resp1.json() == resp2.json()

    def test_duplicate_batch_no_idempotent_summary(self, client, normal_payload):
        client.post("/api/v1/quota/batch", json=normal_payload)
        resp = client.post("/api/v1/quota/batch", json=normal_payload)
        data = resp.json()

        assert data["summary"]["total"] == 2
        assert data["summary"]["processable"] == 2
        assert data["summary"]["needs_supplement"] == 0

    def test_duplicate_does_not_create_extra_audit_logs(self, client, normal_payload):
        resp1 = client.post("/api/v1/quota/batch", json=normal_payload)
        resp2 = client.post("/api/v1/quota/batch", json=normal_payload)
        assert len(resp1.json()["audit_trail"]) == len(resp2.json()["audit_trail"])

    def test_duplicate_batch_no_with_different_action_is_still_idempotent(
        self, client, normal_payload
    ):
        resp1 = client.post("/api/v1/quota/batch", json=normal_payload)
        normal_payload["action"] = "adjust"
        resp2 = client.post("/api/v1/quota/batch", json=normal_payload)

        assert resp2.status_code == 200
        assert resp2.json()["action"] == "apply"

