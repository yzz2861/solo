    def test_risk_labels_match_dispositions(self, client, normal_payload):
        normal_payload["batch_no"] = "BATCH-RISK"
        normal_payload["details"].append(
            {
                "tenant_id": "LOCKED-TEST",
                "quota_type": "users",
                "quota_key": "locked_test",
                "requested_value": 10,
                "current_value": 5,
                "unit": "count",
            }
        )
        resp = client.post("/api/v1/quota/batch", json=normal_payload)
        data = resp.json()

        for d in data["details"]:
            if d["disposition"] == "processable":
                assert d["risk_label"] == "normal"
            elif d["disposition"] == "needs_supplement":
                assert d["risk_label"] == "warning"
            elif d["disposition"] == "locked":
                assert d["risk_label"] == "high_risk"
            elif d["disposition"] == "failed":
                assert d["risk_label"] == "conflict"

