import pytest


class TestNormalRecord:
    def test_normal_apply_returns_processable(self, client, normal_payload):
        resp = client.post("/api/v1/quota/batch", json=normal_payload)
        assert resp.status_code == 200
        data = resp.json()

        assert data["batch_no"] == "BATCH-001"
        assert data["source_channel"] == "admin_portal"
        assert data["action"] == "apply"
        assert data["review_opinion"] == "正常扩容申请"
        assert data["operator"] == "admin_zhangsan"
        assert data["rule_version"] == "v1.0.0"

        summary = data["summary"]
        assert summary["total"] == 2
        assert summary["processable"] == 2
        assert summary["needs_supplement"] == 0
        assert summary["locked"] == 0
        assert summary["failed"] == 0

        for d in data["details"]:
            assert d["disposition"] == "processable"
            assert d["risk_label"] == "normal"
            assert d["failure_reason"] is None
            assert d["rule_version"] == "v1.0.0"

    def test_summary_counts_match_details(self, client, normal_payload):
        resp = client.post("/api/v1/quota/batch", json=normal_payload)
        data = resp.json()
        details = data["details"]
        summary = data["summary"]

        assert summary["total"] == len(details)
        assert summary["processable"] == sum(
            1 for d in details if d["disposition"] == "processable"
        )
        assert summary["needs_supplement"] == sum(
            1 for d in details if d["disposition"] == "needs_supplement"
        )
        assert summary["locked"] == sum(
            1 for d in details if d["disposition"] == "locked"
        )
        assert summary["failed"] == sum(
            1 for d in details if d["disposition"] == "failed"
        )

