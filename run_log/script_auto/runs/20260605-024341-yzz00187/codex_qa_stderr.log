const fs = require('fs');
const path = require('path');
const csv = require('csv-parser');

class DataReader {
  constructor(options = {}) {
    this.options = options;
    this.badRows = [];
  }

  async loadAll() {
    const [mainData, supplementData, rules] = await Promise.all([
      this.readCSV(this.options.main, 'main'),
      this.readCSV(this.options.supplement, 'supplement'),
      this.readRules(this.options.rules)
    ]);

    return {
      mainData,
      supplementData,
      rules,
      badRows: this.badRows
    };
  }

  readCSV(filePath, source) {
    return new Promise((resolve, reject) => {
      const results = [];
      let rowNumber = 0;

      const parserOptions = {
        skipLines: this.options.header === false ? 0 : 0,
        headers: this.options.header === false ? undefined : undefined
      };

      fs.createReadStream(filePath, 'utf8')
        .pipe(csv(parserOptions))
        .on('headers', (headers) => {
          this.headers = headers;
        })
        .on('data', (data) => {
          rowNumber++;
          try {
            const processed = this.processRow(data, rowNumber, source);
            if (processed) {
              results.push(processed);
            }
          } catch (error) {
            this.badRows.push({
              source,
              rowNumber,
              data,
              error: error.message,
              raw: JSON.stringify(data)
            });
          }
        })
        .on('end', () => resolve(results))
        .on('error', reject);
    });
  }

  processRow(data, rowNumber, source) {
    const requiredFields = source === 'main' 
      ? ['batchNo', 'productCode', 'sprayCode', 'sprayTime', 'lineNo']
      : ['batchNo', 'productCode', 'operator', 'materialCode'];

    const missingFields = requiredFields.filter(field => !data[field] || String(data[field]).trim() === '');

    if (missingFields.length > 0) {
      throw new Error(`缺失必填字段: ${missingFields.join(', ')}`);
    }

    return {
      ...data,
      _rowNumber: rowNumber,
      _source: source
    };
  }

  readRules(filePath) {
    return new Promise((resolve, reject) => {
      fs.readFile(filePath, 'utf8', (err, data) => {
        if (err) return reject(err);
        try {
          const rules = JSON.parse(data);
          this.validateRules(rules);
          resolve(rules);
        } catch (e) {
          reject(new Error(`规则文件解析失败: ${e.message}`));
        }
      });
    });
  }

  validateRules(rules) {
    const requiredSections = ['timeBoundary', 'codeFormat', 'requiredFields', 'reviewConditions'];
    const missing = requiredSections.filter(s => !rules[s]);

    if (missing.length > 0) {
      throw new Error(`规则文件缺少必要配置: ${missing.join(', ')}`);
    }

    if (!rules.timeBoundary.startTime || !rules.timeBoundary.endTime) {
      throw new Error('时间边界配置不完整');
    }

    if (!rules.codeFormat.pattern || !rules.codeFormat.length) {
      throw new Error('喷码格式配置不完整');
    }
  }
}

module.exports = DataReader;

