const fs = require('fs');
const path = require('path');
const createCsvWriter = require('csv-writer').createObjectCsvWriter;

class ResultWriter {
  constructor(outputDir, options = {}) {
    this.outputDir = outputDir;
    this.options = options;
    this.ensureOutputDir();
  }

  ensureOutputDir() {
    if (!fs.existsSync(this.outputDir)) {
      fs.mkdirSync(this.outputDir, { recursive: true });
    }
  }

  async writeAll(results, badRows) {
    const outputFiles = {};

    if (this.options.reviewMode) {
      outputFiles.toReview = await this.writeReview(results.toReview);
      return outputFiles;
    }

    outputFiles.normal = await this.writeNormal(results.normal);
    outputFiles.exceptions = await this.writeExceptions(results.exceptions);
    outputFiles.toReview = await this.writeReview(results.toReview);

    if (this.options.exportBadRows && badRows.length > 0) {
      outputFiles.badRows = await this.writeBadRows(badRows);
    }

    outputFiles.summary = await this.writeSummary(results, badRows);

    return outputFiles;
  }

  async writeNormal(records) {
    if (records.length === 0) return null;

    const filePath = path.join(this.outputDir, 'normal.csv');
    const csvWriter = createCsvWriter({
      path: filePath,
      header: [
        { id: 'batchNo', title: '批次号' },
        { id: 'productCode', title: '产品编号' },
        { id: 'sprayCode', title: '喷码' },
        { id: 'sprayTime', title: '喷码时间' },
        { id: 'lineNo', title: '生产线' },
        { id: '_rowNumber', title: '原始行号' }
      ]
    });

    await csvWriter.writeRecords(records.map(r => ({
      ...r,
      _rowNumber: r._rowNumber
    })));

    return filePath;
  }

  async writeExceptions(records) {
    if (records.length === 0) return null;

    const filePath = path.join(this.outputDir, 'exceptions.csv');
    const csvWriter = createCsvWriter({
      path: filePath,
      header: [
        { id: 'batchNo', title: '批次号' },
        { id: 'productCode', title: '产品编号' },
        { id: 'sprayCode', title: '喷码' },
        { id: 'sprayTime', title: '喷码时间' },
        { id: 'lineNo', title: '生产线' },
        { id: '_rowNumber', title: '原始行号' },
        { id: '_source', title: '来源' },
        { id: '_exceptionReason', title: '异常原因' }
      ]
    });

    await csvWriter.writeRecords(records);
    return filePath;
  }

  async writeReview(records) {
    if (records.length === 0) return null;

    const filePath = path.join(this.outputDir, 'review.csv');
    const csvWriter = createCsvWriter({
      path: filePath,
      header: [
        { id: 'batchNo', title: '批次号' },
        { id: 'productCode', title: '产品编号' },
        { id: 'sprayCode', title: '喷码' },
        { id: 'sprayTime', title: '喷码时间' },
        { id: 'lineNo', title: '生产线' },
        { id: '_rowNumber', title: '原始行号' },
        { id: '_reviewReason', title: '复核原因' },
        { id: 'reviewStatus', title: '复核状态' },
        { id: 'reviewComment', title: '复核意见' },
        { id: 'reviewer', title: '复核人' },
        { id: 'reviewTime', title: '复核时间' }
      ]
    });

    await csvWriter.writeRecords(records.map(r => ({
      ...r,
      reviewStatus: '待复核',
      reviewComment: '',
      reviewer: '',
      reviewTime: ''
    })));

    return filePath;
  }

  async writeBadRows(badRows) {
    const filePath = path.join(this.outputDir, 'bad_rows.csv');
    const csvWriter = createCsvWriter({
      path: filePath,
      header: [
        { id: 'source', title: '来源文件' },
        { id: 'rowNumber', title: '行号' },
        { id: 'error', title: '错误原因' },
        { id: 'raw', title: '原始数据' }
      ]
    });

    await csvWriter.writeRecords(badRows);
    return filePath;
  }

  async writeSummary(results, badRows) {
    const filePath = path.join(this.outputDir, 'summary.json');
    const summary = {
      generatedAt: new Date().toISOString(),
      statistics: {
        total: results.normal.length + results.exceptions.length + results.toReview.length,
        normal: results.normal.length,
        exceptions: results.exceptions.length,
        toReview: results.toReview.length,
        badRows: badRows.length
      },
      exceptionTypes: this.countExceptionTypes(results.exceptions),
      reviewReasons: this.countReviewReasons(results.toReview),
      outputFiles: {
        normal: 'normal.csv',
        exceptions: 'exceptions.csv',
        review: 'review.csv',
        badRows: badRows.length > 0 ? 'bad_rows.csv' : null
      }
    };

    fs.writeFileSync(filePath, JSON.stringify(summary, null, 2), 'utf8');
    return filePath;
  }

  countExceptionTypes(exceptions) {
    const counts = {};
    exceptions.forEach(r => {
      r._errors.forEach(err => {
        const type = this.getExceptionType(err);
        counts[type] = (counts[type] || 0) + 1;
      });
    });
    return counts;
  }

  getExceptionType(error) {
    if (error.includes('时间越界')) return 'time_boundary';
    if (error.includes('喷码')) return 'spray_code';
    if (error.includes('配置缺失') || error.includes('补充表')) return 'supplement';
    if (error.includes('字段')) return 'missing_field';
    return 'other';
  }

  countReviewReasons(reviews) {
    const counts = {};
    reviews.forEach(r => {
      r._reviewFlags.forEach(flag => {
        counts[flag] = (counts[flag] || 0) + 1;
      });
    });
    return counts;
  }
}

module.exports = ResultWriter;

