#!/usr/bin/env node

const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const chalk = require('chalk');

const TEST_MODES = {
  full: '完整数据验收',
  time: '时间越界验收',
  code: '编号错误验收',
  config: '配置缺失验收'
};

function runTest(mode) {
  console.log(chalk.bold(`\n${'='.repeat(60)}`));
  console.log(chalk.bold(`  ${TEST_MODES[mode]}`));
  console.log(chalk.bold(`${'='.repeat(60)}\n`));

  const outputDir = `./data/output/${mode}`;
  
  if (fs.existsSync(outputDir)) {
    fs.rmSync(outputDir, { recursive: true, force: true });
  }

  let mainFile = './data/main_list.csv';
  let supplementFile = './data/supplement.csv';
  let rulesFile = './data/rules.json';
  let extraArgs = '--export-bad-rows -v';

  if (mode === 'time') {
    mainFile = './data/test_time_main.csv';
    supplementFile = './data/test_supplement.csv';
    generateTimeTestData();
  } else if (mode === 'code') {
    mainFile = './data/test_code_main.csv';
    supplementFile = './data/test_supplement.csv';
    generateCodeTestData();
  } else if (mode === 'config') {
    mainFile = './data/test_config_main.csv';
    supplementFile = './data/test_config_supplement.csv';
    rulesFile = './data/rules.json';
    generateConfigTestData();
  }

  try {
    const cmd = `node src/index.js -m ${mainFile} -s ${supplementFile} -r ${rulesFile} -o ${outputDir} ${extraArgs}`;
    console.log(chalk.gray(`执行命令: ${cmd}\n`));
    
    const output = execSync(cmd, { encoding: 'utf8', stdio: 'pipe' });
    console.log(output);

    verifyResults(outputDir, mode);
    
  } catch (error) {
    console.log(error.stdout);
    if (error.stderr) console.log(chalk.red(error.stderr));
    console.log(chalk.red(`\n❌ 测试失败: ${error.message}`));
    process.exit(1);
  }
}

function generateTimeTestData() {
  const mainContent = `batchNo,productCode,sprayCode,sprayTime,lineNo
BATCH001,PROD001,SP001202401150001,2024-01-15 07:59:59,LINE01
BATCH002,PROD001,SP001202401150002,2024-01-15 08:00:00,LINE01
BATCH003,PROD001,SP001202401150003,2024-01-15 12:00:00,LINE01
BATCH004,PROD001,SP001202401150004,2024-01-15 18:00:00,LINE01
BATCH005,PROD001,SP001202401150005,2024-01-15 18:00:01,LINE01
BATCH006,PROD001,SP001202401150006,invalid-time,LINE01`;

  fs.writeFileSync('./data/test_time_main.csv', mainContent);

  const supplementContent = `batchNo,productCode,operator,materialCode
BATCH001,PROD001,OP001,MAT001
BATCH002,PROD001,OP001,MAT001
BATCH003,PROD001,OP001,MAT001
BATCH004,PROD001,OP001,MAT001
BATCH005,PROD001,OP001,MAT001
BATCH006,PROD001,OP001,MAT001`;

  fs.writeFileSync('./data/test_supplement.csv', supplementContent);
}

function generateCodeTestData() {
  const mainContent = `batchNo,productCode,sprayCode,sprayTime,lineNo
BATCH001,PROD001,SP001202401150001,2024-01-15 10:00:00,LINE01
BATCH002,PROD001,SP00120240115000,2024-01-15 10:00:00,LINE01
BATCH003,PROD001,AB001202401150003,2024-01-15 10:00:00,LINE01
BATCH004,PROD001,SPXYZ202401150004,2024-01-15 10:00:00,LINE01
BATCH005,PROD001,SP001202401150000,2024-01-15 10:00:00,LINE01`;

  fs.writeFileSync('./data/test_code_main.csv', mainContent);
}

function generateConfigTestData() {
  const mainContent = `batchNo,productCode,sprayCode,sprayTime,lineNo
BATCH001,PROD001,SP001202401150001,2024-01-15 10:00:00,LINE01
BATCH002,PROD001,SP001202401150002,2024-01-15 10:00:00,LINE01
BATCH003,PROD002,SP002202401150003,2024-01-15 10:00:00,LINE01
BATCH004,PROD003,SP003202401150004,2024-01-15 10:00:00,LINE01`;

  fs.writeFileSync('./data/test_config_main.csv', mainContent);

  const supplementContent = `batchNo,productCode,operator,materialCode
BATCH001,PROD001,OP001,MAT001
BATCH002,PROD002,OP001,MAT001
BATCH003,PROD002,OP001,
BATCH004,PROD003,,MAT003`;

  fs.writeFileSync('./data/test_config_supplement.csv', supplementContent);
}

function verifyResults(outputDir, mode) {
  console.log(chalk.bold('\n📋 结果验证:'));

  const files = ['normal.csv', 'exceptions.csv', 'review.csv', 'summary.json', 'bad_rows.csv'];
  files.forEach(file => {
    const filePath = path.join(outputDir, file);
    const exists = fs.existsSync(filePath);
    if (file !== 'bad_rows.csv' || exists) {
      console.log(chalk.gray(`  ${file}: ${exists ? chalk.green('✓ 存在') : chalk.yellow('○ 无数据')}`));
    }
  });

  const summaryPath = path.join(outputDir, 'summary.json');
  if (fs.existsSync(summaryPath)) {
    const summary = JSON.parse(fs.readFileSync(summaryPath, 'utf8'));
    console.log(chalk.cyan('\n📊 统计摘要:'));
    console.log(chalk.gray(`  总记录: ${summary.statistics.total}`));
    console.log(chalk.green(`  正常: ${summary.statistics.normal}`));
    console.log(chalk.red(`  异常: ${summary.statistics.exceptions}`));
    console.log(chalk.yellow(`  待复核: ${summary.statistics.toReview}`));
    console.log(chalk.gray(`  坏行: ${summary.statistics.badRows}`));
  }

  const exceptionsPath = path.join(outputDir, 'exceptions.csv');
  if (fs.existsSync(exceptionsPath) && fs.statSync(exceptionsPath).size > 0) {
    const exceptions = fs.readFileSync(exceptionsPath, 'utf8').split('\n').slice(1, 4);
    console.log(chalk.red('\n🔴 异常示例 (前3条):'));
    exceptions.filter(e => e.trim()).forEach(e => {
      console.log(chalk.gray(`  ${e.split(',').slice(0, 3).join(', ')}...`));
    });
  }

  const reviewPath = path.join(outputDir, 'review.csv');
  if (fs.existsSync(reviewPath) && fs.statSync(reviewPath).size > 0) {
    console.log(chalk.yellow('\n🟡 复核入口:'));
    console.log(chalk.gray(`  文件位置: ${reviewPath}`));
    console.log(chalk.gray(`  包含字段: 批次号,喷码,复核原因,复核状态,复核人`));
  }

  console.log(chalk.green(`\n✅ ${TEST_MODES[mode]} 通过!\n`));
}

function showHelp() {
  console.log(`
包装线喷码错印CLI - 验收测试工具

用法:
  npm run test              运行完整数据验收
  npm run test:full         运行完整数据验收
  npm run test:time         运行时间越界验收
  npm run test:code         运行编号错误验收
  npm run test:config       运行配置缺失验收

验收项:
  ✓ 完整数据验收 - 测试所有场景混合数据
  ✓ 时间越界验收 - 测试开始/结束时间边界、格式错误
  ✓ 编号错误验收 - 测试长度、前缀、格式正则校验
  ✓ 配置缺失验收 - 测试补充表缺失、字段不匹配

输出验证:
  ✓ 控制台输出 - 进度条、统计信息、彩色提示
  ✓ 结果文件 - normal.csv, exceptions.csv, review.csv
  ✓ 坏行隔离 - bad_rows.csv 单独导出
  ✓ 复核入口 - review.csv 含复核状态和意见字段
`);
}

const args = process.argv.slice(2);

if (args.includes('--help') || args.includes('-h')) {
  showHelp();
  process.exit(0);
}

if (args.includes('--full-data') || args.length === 0) {
  runTest('full');
}
if (args.includes('--time-boundary')) {
  runTest('time');
}
if (args.includes('--code-error')) {
  runTest('code');
}
if (args.includes('--config-missing')) {
  runTest('config');
}

if (args.includes('--all')) {
  runTest('full');
  runTest('time');
  runTest('code');
  runTest('config');
  console.log(chalk.bold.green('\n🎉 所有验收测试通过!\n'));
}

