#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import json
import csv
import os
from datetime import datetime
from typing import Dict, List, Any


class ReportGenerator:
    
    def __init__(self, config_dir: str = 'config', output_dir: str = 'output'):
        self.config_dir = config_dir
        self.output_dir = output_dir
        self.load_templates()
        self._ensure_output_dir()
    
    def load_templates(self):
        with open(os.path.join(self.config_dir, 'report_templates.json'), 'r', encoding='utf-8') as f:
            self.templates = json.load(f)
    
    def _ensure_output_dir(self):
        os.makedirs(self.output_dir, exist_ok=True)
        for subdir in ['group_reports', 'bad_data', 'json_results', 'review_tables']:
            os.makedirs(os.path.join(self.output_dir, subdir), exist_ok=True)
    
    def generate_all_reports(self, process_result: Dict[str, Any], 
                              filename_prefix: str = None) -> Dict[str, str]:
        if not process_result.get('success', False):
            return {'error': process_result.get('error', '处理失败')}
        
        if filename_prefix is None:
            filename_prefix = f"batch_{process_result['batch_id']}"
        
        generated_files = {}
        
        group_report_path = self.generate_group_report(
            process_result, 
            os.path.join(self.output_dir, 'group_reports', f"{filename_prefix}_group.csv")
        )
        generated_files['group_report'] = group_report_path
        
        bad_data_path = self.generate_bad_data_report(
            process_result,
            os.path.join(self.output_dir, 'bad_data', f"{filename_prefix}_bad_data.csv")
        )
        generated_files['bad_data_report'] = bad_data_path
        
        json_path = self.generate_json_result(
            process_result,
            os.path.join(self.output_dir, 'json_results', f"{filename_prefix}_result.json")
        )
        generated_files['json_result'] = json_path
        
        review_path = self.generate_review_report(
            process_result,
            os.path.join(self.output_dir, 'review_tables', f"{filename_prefix}_review.csv")
        )
        generated_files['review_report'] = review_path
        
        return generated_files
    
    def generate_group_report(self, process_result: Dict[str, Any], 
                               output_path: str) -> str:
        template = self.templates['group_report']
        group_results = process_result.get('group_results', [])
        
        headers = [d['name'] for d in template['group_dimensions']] + \
                  [d['name'] for d in template['metrics']]
        
        key_mapping = {}
        for d in template['group_dimensions'] + template['metrics']:
            key_mapping[d['name']] = d['key']
        
        with open(output_path, 'w', newline='', encoding='utf-8-sig') as f:
            writer = csv.DictWriter(f, fieldnames=headers)
            writer.writeheader()
            
            for row in group_results:
                output_row = {}
                for header in headers:
                    key = key_mapping[header]
                    value = row.get(key, '')
                    if isinstance(value, float):
                        value = f"{value:.2f}"
                    output_row[header] = value
                writer.writerow(output_row)
        
        return output_path
    
    def generate_bad_data_report(self, process_result: Dict[str, Any], 
                                  output_path: str) -> str:
        template = self.templates['bad_data_report']
        bad_data = process_result.get('bad_data', [])
        
        field_configs = template['fields']
        headers = [f['name'] for f in field_configs]
        key_mapping = {f['name']: f['key'] for f in field_configs}
        
        with open(output_path, 'w', newline='', encoding='utf-8-sig') as f:
            writer = csv.DictWriter(f, fieldnames=headers)
            writer.writeheader()
            
            for error in bad_data:
                output_row = {}
                for header in headers:
                    key = key_mapping[header]
                    output_row[header] = error.get(key, '')
                writer.writerow(output_row)
        
        return output_path
    
    def generate_json_result(self, process_result: Dict[str, Any], 
                              output_path: str) -> str:
        template = self.templates['json_output']
        include_fields = template['include_fields']
        
        output_data = {}
        for field in include_fields:
            if field in process_result:
                output_data[field] = process_result[field]
        
        output_data['batch_info'] = {
            'batch_id': process_result.get('batch_id'),
            'process_time': process_result.get('process_time'),
            'generated_at': datetime.now().isoformat()
        }
        
        with open(output_path, 'w', encoding='utf-8') as f:
            json.dump(output_data, f, ensure_ascii=False, indent=template['indent'])
        
        return output_path
    
    def generate_review_report(self, process_result: Dict[str, Any], 
                                output_path: str) -> str:
        template = self.templates['review_report']
        problems = process_result.get('problem_details', [])
        raw_results = process_result.get('raw_results', [])
        
        record_lookup = {}
        for result in raw_results:
            record_lookup[result['trace_id']] = result.get('record', {})
        
        field_configs = template['fields']
        headers = [f['name'] for f in field_configs]
        key_mapping = {f['name']: f['key'] for f in field_configs}
        
        with open(output_path, 'w', newline='', encoding='utf-8-sig') as f:
            writer = csv.DictWriter(f, fieldnames=headers)
            writer.writeheader()
            
            for problem in problems:
                record = record_lookup.get(problem['trace_id'], {})
                output_row = {}
                
                for header in headers:
                    key = key_mapping[header]
                    
                    if key in problem:
                        value = problem[key]
                    elif key in record:
                        value = record[key]
                    elif key == 'review_status':
                        value = '待复核'
                    else:
                        value = ''
                    
                    if isinstance(value, float):
                        value = f"{value:.4f}"
                    elif isinstance(value, bool):
                        value = '是' if value else '否'
                    
                    output_row[header] = value
                
                writer.writerow(output_row)
        
        return output_path

