#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import json
import hashlib
import uuid
import csv
import os
from datetime import datetime, timedelta
from typing import Dict, List, Any, Tuple, Optional
from collections import defaultdict


class PickMismatchProcessor:
    
    def __init__(self, config_dir: str = 'config'):
        self.config_dir = config_dir
        self.load_configs()
        self.processed_records = set()
        self.trace_counter = 0
    
    def load_configs(self):
        with open(os.path.join(self.config_dir, 'problem_dictionary.json'), 'r', encoding='utf-8') as f:
            self.problem_dict = json.load(f)
        
        with open(os.path.join(self.config_dir, 'deduplication_keys.json'), 'r', encoding='utf-8') as f:
            self.dedup_config = json.load(f)
        
        with open(os.path.join(self.config_dir, 'report_templates.json'), 'r', encoding='utf-8') as f:
            self.report_templates = json.load(f)
    
    def generate_trace_id(self, record: Dict[str, Any], batch_id: str) -> str:
        self.trace_counter += 1
        timestamp = datetime.now().strftime('%Y%m%d%H%M%S')
        record_hash = hashlib.md5(
            json.dumps(record, sort_keys=True, ensure_ascii=False).encode()
        ).hexdigest()[:8]
        return f"PICK-{timestamp}-{batch_id}-{self.trace_counter:04d}-{record_hash}"
    
    def validate_admission(self, record: Dict[str, Any]) -> Tuple[bool, List[Dict[str, Any]]]:
        errors = []
        required_fields = self.problem_dict['admission_criteria']['required_fields']
        
        for field in required_fields:
            if field not in record or record[field] in (None, '', []):
                errors.append({
                    'error_type': 'missing_required_field',
                    'field_name': field,
                    'field_value': record.get(field, ''),
                    'error_message': f'必填字段缺失: {field}'
                })
        
        if 'pick_time' in record and record['pick_time']:
            try:
                if isinstance(record['pick_time'], str):
                    datetime.fromisoformat(record['pick_time'].replace('Z', '+00:00'))
            except ValueError:
                errors.append({
                    'error_type': 'invalid_date_format',
                    'field_name': 'pick_time',
                    'field_value': record['pick_time'],
                    'error_message': '日期格式无效，需为ISO格式'
                })
        
        if 'actual_qty' in record and record['actual_qty'] is not None:
            try:
                qty = float(record['actual_qty'])
                if qty < 0:
                    errors.append({
                        'error_type': 'value_out_of_range',
                        'field_name': 'actual_qty',
                        'field_value': record['actual_qty'],
                        'error_message': '数量不能为负数'
                    })
            except (ValueError, TypeError):
                errors.append({
                    'error_type': 'invalid_data_type',
                    'field_name': 'actual_qty',
                    'field_value': record['actual_qty'],
                    'error_message': '数量应为数值类型'
                })
        
        return len(errors) == 0, errors
    
    def generate_dedup_key(self, record: Dict[str, Any], key_type: str = 'default') -> str:
        rule = self.dedup_config['deduplication_rules'][key_type]
        
        if rule['key_type'] == 'primary_key':
            key_fields = self.dedup_config['primary_key']
        else:
            key_fields = self.dedup_config['composite_keys'].get(rule['key_type'], [])
        
        key_values = []
        for field in key_fields:
            val = record.get(field, '')
            key_values.append(str(val))
        
        raw_key = '|'.join(key_values)
        return hashlib.md5(raw_key.encode('utf-8')).hexdigest()
    
    def check_duplicate(self, record: Dict[str, Any], dedup_key: str) -> Tuple[bool, Optional[str]]:
        if dedup_key in self.processed_records:
            return True, 'record_already_processed'
        
        if self.dedup_config['time_based_deduplication']['enabled']:
            pass
        
        return False, None
    
    def calculate_difference(self, record: Dict[str, Any], problem_type: str) -> Tuple[float, bool, str]:
        problem_config = self.problem_dict['problem_types'][problem_type]
        fields = problem_config['fields']
        formula = problem_config['formula']
        threshold = problem_config['threshold']
        compare_type = problem_config.get('compare', '>=')
        
        field_values = {f: record.get(f) for f in fields}
        
        if None in field_values.values():
            return 0.0, False, '字段缺失，无法计算'
        
        try:
            diff_value = self._evaluate_formula(formula, field_values)
            
            if isinstance(threshold, (int, float)):
                if compare_type == '<=':
                    is_hit = diff_value <= threshold
                elif compare_type == '<':
                    is_hit = diff_value < threshold
                elif compare_type == '>':
                    is_hit = diff_value > threshold
                else:
                    is_hit = diff_value >= threshold
            else:
                is_hit = bool(diff_value)
            
            explanation = self._generate_explanation(
                problem_type, field_values, diff_value, threshold, is_hit, compare_type
            )
            
            return diff_value, is_hit, explanation
        except Exception as e:
            return 0.0, False, f'计算异常: {str(e)}'
    
    def _evaluate_formula(self, formula: str, values: Dict[str, Any]) -> float:
        if '!=' in formula:
            field1, field2 = formula.split(' != ')
            field1 = field1.strip()
            field2 = field2.strip()
            return 1.0 if values.get(field1) != values.get(field2) else 0.0
        
        if 'abs(' in formula and ') / ' in formula:
            close_paren_idx = formula.find(')')
            abs_content = formula[4:close_paren_idx]
            field1, field2 = abs_content.split(' - ')
            field1 = field1.strip()
            field2 = field2.strip()
            divisor_part = formula[close_paren_idx+3:].strip()
            v1 = float(values.get(field1, 0))
            v2 = float(values.get(field2, 0))
            divisor = float(values.get(divisor_part, 1))
            return abs(v1 - v2) / divisor if divisor != 0 else 999.0
        
        if 'abs(' in formula and ' - ' in formula:
            inner = formula[4:-1]
            field1, field2 = inner.split(' - ')
            field1 = field1.strip()
            field2 = field2.strip()
            return abs(float(values.get(field1, 0)) - float(values.get(field2, 0)))
        
        if 'days_between' in formula:
            field1 = formula[formula.index('(')+1:formula.index(',')].strip()
            field2 = formula[formula.index(',')+1:formula.index(')')].strip()
            d1 = datetime.fromisoformat(str(values.get(field1)).replace('Z', '+00:00'))
            d2 = datetime.fromisoformat(str(values.get(field2)).replace('Z', '+00:00'))
            return (d1 - d2).days
        
        if 'minutes_between' in formula:
            field1 = formula[formula.index('(')+1:formula.index(',')].strip()
            field2 = formula[formula.index(',')+1:formula.index(')')].strip()
            d1 = datetime.fromisoformat(str(values.get(field1)).replace('Z', '+00:00'))
            d2 = datetime.fromisoformat(str(values.get(field2)).replace('Z', '+00:00'))
            return max(0, (d1 - d2).total_seconds() / 60)
        
        return 0.0
    
    def _generate_explanation(self, problem_type: str, values: Dict[str, Any], 
                              diff_value: float, threshold: Any, is_hit: bool,
                              compare_type: str = '>=') -> str:
        problem_config = self.problem_dict['problem_types'][problem_type]
        problem_name = problem_config['name']
        time_window = problem_config['time_window_hours']
        
        if problem_type == 'quantity_mismatch':
            exp = f"预期数量{values.get('expected_qty')}，实际数量{values.get('actual_qty')}，差异{diff_value}件"
        elif problem_type == 'location_mismatch':
            exp = f"预期库位{values.get('expected_location')}，实际库位{values.get('actual_location')}"
        elif problem_type == 'sku_mismatch':
            exp = f"预期SKU{values.get('expected_sku')}，实际SKU{values.get('actual_sku')}"
        elif problem_type == 'batch_mismatch':
            exp = f"预期批次{values.get('expected_batch')}，实际批次{values.get('actual_batch')}"
        elif problem_type == 'expiry_mismatch':
            exp = f"效期剩余{diff_value}天"
        elif problem_type == 'weight_mismatch':
            exp = f"重量偏差率{diff_value*100:.2f}%"
        elif problem_type == 'delay_pick':
            exp = f"拣货超时{diff_value:.1f}分钟"
        else:
            exp = f"差异值{diff_value}"
        
        if isinstance(threshold, (int, float)):
            threshold_text = f"阈值{compare_type}{threshold}"
        else:
            threshold_text = "不相等"
        hit_text = "命中" if is_hit else "未命中"
        return f"{problem_name}: {exp}，{threshold_text}，{hit_text}。时间窗口：{time_window}小时"
    
    def check_time_window(self, record: Dict[str, Any], problem_type: str, 
                          reference_time: datetime) -> Tuple[bool, str]:
        problem_config = self.problem_dict['problem_types'][problem_type]
        window_hours = problem_config['time_window_hours']
        
        pick_time_str = record.get('pick_time', '')
        if not pick_time_str:
            return False, '拣货时间缺失'
        
        try:
            pick_time = datetime.fromisoformat(pick_time_str.replace('Z', '+00:00'))
        except ValueError:
            return False, '拣货时间格式错误'
        
        if reference_time.tzinfo is None:
            reference_time = reference_time.replace(tzinfo=pick_time.tzinfo)
        
        time_diff = abs((reference_time - pick_time).total_seconds() / 3600)
        within_window = time_diff <= window_hours
        
        return within_window, f"拣货时间距参考时间{time_diff:.1f}小时，时间窗口{window_hours}小时，{'在窗口内' if within_window else '超出窗口'}"
    
    def process_record(self, record: Dict[str, Any], batch_id: str, 
                       reference_time: datetime = None) -> Dict[str, Any]:
        if reference_time is None:
