#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import json
import sys
import os
import argparse

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from src.pick_mismatch_processor import PickMismatchProcessor
from src.report_generator import ReportGenerator


def load_records_from_file(file_path: str) -> list:
    with open(file_path, 'r', encoding='utf-8') as f:
        data = json.load(f)
    return data.get('records', []), data.get('batch_id')


def process_file(input_file: str, output_prefix: str = None, config_dir: str = 'config'):
    print(f"\n{'='*60}")
    print(f"处理文件: {input_file}")
    print(f"{'='*60}")
    
    records, batch_id = load_records_from_file(input_file)
    print(f"加载记录数: {len(records)}")
    
    processor = PickMismatchProcessor(config_dir=config_dir)
    result = processor.process_batch(records, batch_id=batch_id)
    
    if not result.get('success', False):
        print(f"处理失败: {result.get('error', '未知错误')}")
        return result
    
    summary = result['summary']
    print(f"\n处理摘要:")
    print(f"  总记录数: {summary['total_records']}")
    print(f"  有效记录: {summary['valid_records']}")
    print(f"  无效记录: {summary['invalid_records']}")
    print(f"  有问题记录: {summary['records_with_problems']}")
    print(f"  无问题记录: {summary['problem_free_records']}")
    print(f"\n严重度分布:")
    print(f"  高风险: {summary['severity_breakdown']['high']}")
    print(f"  中风险: {summary['severity_breakdown']['medium']}")
    print(f"  低风险: {summary['severity_breakdown']['low']}")
    print(f"  总严重度评分: {summary['total_severity_score']}")
    
    if output_prefix is None:
        output_prefix = os.path.splitext(os.path.basename(input_file))[0]
    
    report_gen = ReportGenerator(config_dir=config_dir)
    generated_files = report_gen.generate_all_reports(result, filename_prefix=output_prefix)
    
    print(f"\n生成的报表文件:")
    for report_type, file_path in generated_files.items():
        print(f"  {report_type}: {file_path}")
    
    return result


def main():
    parser = argparse.ArgumentParser(description='仓库拣货错位记录处理脚本')
    parser.add_argument('input_file', nargs='?', help='输入JSON文件路径')
    parser.add_argument('--output', '-o', help='输出文件前缀')
    parser.add_argument('--config', '-c', default='config', help='配置目录')
    parser.add_argument('--test', action='store_true', help='运行所有测试样例')
    
    args = parser.parse_args()
    
    if args.test:
        print("运行所有测试样例...")
        test_files = [
            'test_data/compliant_samples.json',
            'test_data/over_threshold_samples.json',
            'test_data/missing_material_samples.json',
            'test_data/history_replay_samples.json'
        ]
        
        all_results = []
        for test_file in test_files:
            if os.path.exists(test_file):
                result = process_file(test_file, config_dir=args.config)
                all_results.append(result)
        
        print(f"\n{'='*60}")
        print("测试完成，共运行 %d 个测试样例" % len(all_results))
        print(f"{'='*60}")
        return
    
    if not args.input_file:
        parser.print_help()
        return
    
    if not os.path.exists(args.input_file):
        print(f"错误: 输入文件不存在: {args.input_file}")
        sys.exit(1)
    
    process_file(args.input_file, output_prefix=args.output, config_dir=args.config)


if __name__ == '__main__':
    main()

