            if is_hit:
                within_window, window_explanation = self.check_time_window(
                    record, problem_type, reference_time
                )
                
                if not within_window:
                    continue
                
                problem_config = self.problem_dict['problem_types'][problem_type]
                problems.append({
                    'trace_id': trace_id,
                    'problem_type': problem_type,
                    'problem_name': problem_config['name'],
                    'problem_level': problem_config['level'],
                    'threshold': problem_config['threshold'],
                    'threshold_hit': is_hit,
                    'difference_value': diff_value,
                    'time_window_hours': problem_config['time_window_hours'],
                    'within_time_window': within_window,
                    'explanation': f"{explanation}。{window_explanation}",
                    'severity_weight': self.problem_dict['severity_weights'][problem_config['level']]
                })
        
        self.processed_records.add(dedup_key)
        
        return {
            'trace_id': trace_id,
            'record': record,
            'is_valid': True,
            'errors': [],
            'problems': problems,
            'dedup_key': dedup_key
        }
    
    def process_batch(self, records: List[Dict[str, Any]], 
                      batch_id: str = None) -> Dict[str, Any]:
        if batch_id is None:
            batch_id = hashlib.md5(
                str(datetime.now().timestamp()).encode()
            ).hexdigest()[:8].upper()
        
        max_records = self.problem_dict['admission_criteria']['max_records_per_batch']
        min_records = self.problem_dict['admission_criteria']['min_records_per_batch']
        
        if len(records) > max_records:
            return {
                'success': False,
                'error': f'批次记录数超过限制: {len(records)} > {max_records}'
            }
        if len(records) < min_records:
            return {
                'success': False,
                'error': f'批次记录数不足: {len(records)} < {min_records}'
            }
        
        self.processed_records.clear()
        self.trace_counter = 0
        reference_time = datetime.now()
        
        results = []
        bad_data = []
        problem_details = []
        
        for record in records:
            result = self.process_record(record, batch_id, reference_time)
            results.append(result)
            
            if not result['is_valid']:
                bad_data.extend(result['errors'])
            
            problem_details.extend(result['problems'])
        
        group_results = self._generate_group_results(results)
        summary = self._generate_summary(results, bad_data, problem_details)
        
        return {
            'success': True,
            'batch_id': batch_id,
            'process_time': reference_time.isoformat(),
            'metadata': {
                'total_records': len(records),
                'config_version': self.problem_dict['version']
            },
            'summary': summary,
            'group_results': group_results,
            'problem_details': problem_details,
            'bad_data': bad_data,
            'raw_results': results
        }
    
    def _generate_group_results(self, results: List[Dict[str, Any]]) -> Dict[str, Any]:
        groups = defaultdict(lambda: {
            'total_count': 0,
            'problem_count': 0,
            'high_severity_count': 0,
            'severity_score': 0
        })
        
        for result in results:
            record = result['record']
            has_problem = len(result['problems']) > 0
            
            wh = record.get('warehouse_code', 'UNKNOWN')
            picker = record.get('picker_id', 'UNKNOWN')
            
            if has_problem:
                for problem in result['problems']:
                    key = (wh, picker, problem['problem_type'])
                    groups[key]['total_count'] += 1
                    groups[key]['problem_count'] += 1
                    if problem['problem_level'] == 'high':
                        groups[key]['high_severity_count'] += 1
                    groups[key]['severity_score'] += problem['severity_weight']
            else:
                key = (wh, picker, 'none')
                groups[key]['total_count'] += 1
        
        formatted_groups = []
        for (warehouse, picker, problem_type), metrics in groups.items():
            metrics['problem_rate'] = (
                metrics['problem_count'] / metrics['total_count'] * 100 
                if metrics['total_count'] > 0 else 0
            )
            formatted_groups.append({
                'warehouse_code': warehouse,
                'picker_id': picker,
                'problem_type': problem_type,
                **metrics
            })
        
        return formatted_groups
    
    def _generate_summary(self, results: List[Dict[str, Any]], 
                          bad_data: List[Dict[str, Any]], 
                          problems: List[Dict[str, Any]]) -> Dict[str, Any]:
        valid_count = sum(1 for r in results if r['is_valid'])
        problem_count = sum(1 for r in results if r['problems'])
        
        high_count = sum(1 for p in problems if p['problem_level'] == 'high')
        medium_count = sum(1 for p in problems if p['problem_level'] == 'medium')
        low_count = sum(1 for p in problems if p['problem_level'] == 'low')
        
        problem_type_counts = defaultdict(int)
        for p in problems:
            problem_type_counts[p['problem_type']] += 1
        
        return {
            'total_records': len(results),
            'valid_records': valid_count,
            'invalid_records': len(bad_data),
            'records_with_problems': problem_count,
            'problem_free_records': valid_count - problem_count,
            'severity_breakdown': {
                'high': high_count,
                'medium': medium_count,
                'low': low_count
            },
            'problem_type_breakdown': dict(problem_type_counts),
            'total_severity_score': sum(p['severity_weight'] for p in problems)
        }

