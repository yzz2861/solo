{
  "name": "museum-loan-manager",
  "version": "1.0.0",
  "description": "博物馆借展管理系统 - 展品借出、在展、回馆、复核全流程管理",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"npm run electron\"",
    "vite": "vite",
    "electron": "wait-on http://localhost:5173 && NODE_ENV=development electron .",
    "build": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["museum", "loan", "exhibit", "management"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.museum.loan.manager",
    "productName": "博物馆借展管理系统",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "papaparse": "^5.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
